---
// h:\Javiermix_web_v2\frontend\components\MagazineSection.astro
const PUBLIC_DIRECTUS_URL = 'https://admin.javiermix.ar';
const INTERNAL_DOCKER_URL = 'http://directus:8055';
let connectionError = null;

let fetchedArticles = [];
try {
  // 🚀 Intentar primero por la red interna de Docker (más rápido)
  let response = await fetch(`${INTERNAL_DOCKER_URL}/items/magazine?sort=-date_created`);
  
  // 🔄 Si falla la red interna, intentamos por la URL pública
  if (!response.ok) {
      response = await fetch(`${PUBLIC_DIRECTUS_URL}/items/magazine?sort=-date_created`);
  }
  
  const data = await response.json();
  fetchedArticles = data.data || [];
} catch (e) {
  // 🚑 Último recurso: URL pública directa
  try {
      const resPublic = await fetch(`${PUBLIC_DIRECTUS_URL}/items/magazine`);
      const dataPublic = await resPublic.json();
      fetchedArticles = dataPublic.data || [];
  } catch (err) {
      connectionError = `Error crítico de conexión: ${err.message}`;
  }
}

function resolveMedia(id: any): { url: string, type: 'image' | 'video' } {
  const url = id?.id ? `${PUBLIC_DIRECTUS_URL}/assets/${id.id}` : (typeof id === 'string' ? (id.startsWith('http') ? id : `${PUBLIC_DIRECTUS_URL}/assets/${id}`) : '/img/placeholder.jpg');
  const type = (url?.toLowerCase().endsWith('.mp4') || url?.includes('video')) ? 'video' : 'image';
  return { url: url || '/img/placeholder.jpg', type };
}

const articles = fetchedArticles.map(a => {
  let slideshow = [resolveMedia(a.featured_image)];
  if (a.media_json) {
    try {
        const extraRaw = typeof a.media_json === 'string' ? JSON.parse(a.media_json) : a.media_json;
        if (Array.isArray(extraRaw)) {
            const extra = extraRaw.map(m => resolveMedia(m));
            slideshow = [...slideshow, ...extra].slice(0, 5);
        }
    } catch(e) {}
  }

  return {
    title: a.title,
    excerpt: a.content_html ? a.content_html.replace(/<[^>]*>/g, '').substring(0, 160) + '...' : '',
    slideshow,
    link: `/revista/${a.id}-${a.slug}`,
    location: "Buenos Aires",
    readTime: "5 min"
  };
});
---

<section class="magazine-section">
  <div class="section-header reveal">
    <h2 class="section-title">REVISTA DIGITAL</h2>
    <p class="section-subtitle">Crónicas de luz, memoria y potencia estética en la vanguardia contemporánea.</p>
    
    {connectionError && (
      <div style="color: #c94c4c; font-size: 0.7rem; margin-top: 1.5rem; opacity: 0.8; letter-spacing: 2px; border: 1px solid rgba(201, 76, 76, 0.3); padding: 0.5rem 1rem; display: inline-block; border-radius: 2px;">
        DIAGNÓSTICO: {connectionError}
      </div>
    )}
  </div>
  <div class="articles-container">
    {articles.length > 0 ? (
      articles.map((article, index) => (
        <article class={`magazine-card ${index % 2 === 0 ? 'row' : 'row-reverse'} reveal`}>
          <div class="card-image-wrapper" data-article-card>
            <div class="tilt-container" data-tilt-container>
                <div class="slideshow-wrapper">
                    {article.slideshow.map((media, i) => (
                        media.type === 'video' ? (
                            <video src={media.url} class={`article-media ${i === 0 ? 'active' : ''}`} muted playsinline loop autoplay></video>
                        ) : (
                            <img src={media.url} alt={`${article.title} - view ${i}`} class={`article-media ${i === 0 ? 'active' : ''}`} loading="lazy" />
                        )
                    ))}
                    <div class="vignette-overlay"></div>
                </div>
                <div class="image-glare"></div>
            </div>
          </div>

          <div class="card-content-block">
            <span class="article-location">{article.location}</span>
            <h3 class="article-title">{article.title}</h3>
            <p class="article-excerpt">{article.excerpt}</p>
            
            <div class="article-meta">
              <div class="time-indicator">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="clock-icon">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <span>{article.readTime} LECTURA</span>
              </div>
              <a href={article.link} class="btn-read-premium">
                <span class="btn-label">LEER</span>
                <span class="btn-line"></span>
              </a>
            </div>
          </div>
        </article>
      ))
    ) : (
      <div style="text-align: center; width: 100%; color: rgba(255,255,255,0.3); letter-spacing: 3px; font-size: 0.8rem; margin-top: 5rem;">
        NO SE ENCONTRARON ARTÍCULOS PUBLICADOS
      </div>
    )}
  </div>
</section>

<style>
  .magazine-section {
    padding: 10rem 5%;
    background-color: var(--color-onyx-deep);
    position: relative;
    overflow: hidden;
  }
  .section-header { text-align: center; margin-bottom: 8rem; max-width: 800px; margin-inline: auto; }
  .section-title { font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: 12px; font-weight: 300; margin-bottom: 1.5rem; color: var(--color-white); }
  .section-subtitle { color: var(--color-text-muted); font-family: var(--font-secondary); font-size: 0.9rem; letter-spacing: 3px; text-transform: uppercase; line-height: 1.6; }
  .articles-container { max-width: var(--container-max); margin: 0 auto; display: flex; flex-direction: column; gap: 15rem; }
  .magazine-card { display: flex; align-items: center; gap: 4%; position: relative; } /* Gap reducido */
  .magazine-card.row { flex-direction: row; }
  .magazine-card.row-reverse { flex-direction: row-reverse; }
  .card-image-wrapper { flex: 0 0 50%; position: relative; z-index: 1; }
  .tilt-container { 
      position: relative; width: 100%; height: 550px; background-color: #080808; 
      box-shadow: 0 30px 60px rgba(0,0,0,0.5); perspective: 1000px; overflow: hidden; 
      border: 1px solid rgba(220, 177, 74, 0.05);
      transition: transform 0.2s ease-out;
  }
  .slideshow-wrapper { 
      position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000;
      z-index: 1;
  }
  .vignette-overlay {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      box-shadow: inset 0 0 80px rgba(0,0,0,0.8);
      pointer-events: none;
      z-index: 10;
  }
  .article-media { 
      position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; 
      filter: grayscale(20%) brightness(0.85); transition: opacity 1.5s ease; 
      opacity: 0;
      z-index: 2;
      mask-image: radial-gradient(circle, black 70%, transparent 100%);
      -webkit-mask-image: radial-gradient(circle, black 70%, transparent 100%);
  }
  .article-media.active { opacity: 1; filter: grayscale(0%) brightness(1); z-index: 5; }
  .image-glare { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 15; opacity: 0; }
  .card-content-block { flex: 1; padding: 4rem; background: rgba(17, 17, 17, 0.6); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.05); position: relative; z-index: 2; margin-left: -5%; }
  .row-reverse .card-content-block { margin-left: 0; margin-right: -5%; }
  .article-location { color: var(--color-accent); font-size: 0.75rem; letter-spacing: 3px; text-transform: uppercase; font-weight: 700; margin-bottom: 2rem; display: block; }
  .article-title { font-size: clamp(2rem, 3vw, 3rem); font-family: var(--font-primary); line-height: 1.1; margin-bottom: 2rem; color: var(--color-white); }
  .article-excerpt { color: var(--color-travertine-light); font-size: 1rem; line-height: 1.8; margin-bottom: 3rem; max-width: 90%; }
  .article-meta { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; }
  .time-indicator { display: flex; align-items: center; gap: 0.75rem; color: var(--color-text-muted); font-size: 0.75rem; letter-spacing: 2px; }
  .clock-icon { width: 14px; height: 14px; color: var(--color-accent); }
  .btn-read-premium { position: relative; display: inline-flex; flex-direction: column; color: var(--color-white); text-decoration: none; font-weight: 700; letter-spacing: 3px; font-size: 0.8rem; transition: var(--transition-premium); }
  .btn-line { width: 30px; height: 2px; background-color: var(--color-accent); margin-top: 8px; transition: width 0.4s ease; }
  .btn-read-premium:hover .btn-label { color: var(--color-accent); }
  .btn-read-premium:hover .btn-line { width: 100%; }
  .reveal { opacity: 0; transform: translateY(30px); transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1); }
  .reveal.active { opacity: 1; transform: translateY(0); }
  @media (max-width: 1024px) {
    .magazine-card { flex-direction: column !important; gap: 0; }
    .card-image-wrapper { width: 100%; flex: none; }
    .card-content-block { width: 95%; margin: -50px auto 0 !important; padding: 2.5rem; }
    .articles-container { gap: 5rem; }
    .tilt-container { height: 400px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    reveals.forEach(r => observer.observe(r));

    function initHomeMagazine() {
      const articles = document.querySelectorAll('[data-article-card]');
      articles.forEach(art => {
          const media = art.querySelectorAll('.article-media');
          if (media.length <= 1) {
              if(media[0]) media[0].classList.add('active');
              return;
          }
          let current = 0;
          setInterval(() => {
              media[current].classList.remove('active');
              current = (current + 1) % media.length;
              media[current].classList.add('active');
              if (media[current].tagName === 'VIDEO') {
                  (media[current] as HTMLVideoElement).play().catch(() => {});
              }
          }, 5000);
      });

      const handleTilt = (e: MouseEvent) => {
          const container = (e.target as HTMLElement).closest('[data-tilt-container]') as HTMLElement;
          if (!container) return;
          const r = container.getBoundingClientRect();
          const x = e.clientX - r.left; 
          const y = e.clientY - r.top;
          const rx = (y - r.height/2) / 45; // Mucho más sutil
          const ry = (r.width/2 - x) / 45;
          container.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.02, 1.02, 1.02)`;
          const glare = container.querySelector('.image-glare') as HTMLElement;
          if (glare) {
              const px = (x / r.width) * 100;
              const py = (y / r.height) * 100;
              glare.style.background = `radial-gradient(circle at ${px}% ${py}%, rgba(255,255,255,0.15) 0%, transparent 80%)`;
              glare.style.opacity = "1";
          }
      };

      const resetTilt = (e: MouseEvent) => {
          const container = (e.target as HTMLElement).closest('[data-tilt-container]') as HTMLElement;
          if (!container) return;
          container.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
          const glare = container.querySelector('.image-glare') as HTMLElement;
          if (glare) glare.style.opacity = "0";
      };

      document.querySelectorAll('[data-tilt-container]').forEach(container => {
          container.addEventListener('mousemove', (e:any) => handleTilt(e));
          container.addEventListener('mouseleave', (e:any) => resetTilt(e));
      });
    }

    initHomeMagazine();
  });
</script>
