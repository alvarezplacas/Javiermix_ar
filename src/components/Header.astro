---
// src/components/Header.astro
import CartNavButton from './ecommerce/CartNavButton.tsx';
const { currentPath = '/', theme = 'dark' } = Astro.props;
---

<header class={`site-header theme-${theme}`}>
	<nav class="nav-container" aria-label="Navegación principal">
		{currentPath === '/' ? (
			<a href="/" class="nav-logo" aria-label="Ir al Inicio">
				<span class="brand-name">JHM</span>
			</a>
		) : <div class="nav-spacer"></div>}
		
		<div class="nav-links">
            <a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
            <a href="/galeria" class={currentPath.startsWith('/galeria') ? 'active' : ''}>Colección</a>
            <a href="/rescate" class={currentPath.startsWith('/rescate') ? 'active' : ''}>Rescate</a>
            <a href="/royal-gallery" class={currentPath.startsWith('/royal-gallery') ? 'active' : ''}>Royal</a>
            <a href="/revista" class={currentPath.startsWith('/revista') ? 'active' : ''}>Revista</a>
            <div class="cart-wrapper">
			    <CartNavButton client:load />
            </div>
		</div>
	</nav>
</header>

<style>
.site-header {
	position: absolute; /* Para que flote sobre el contenido sin fondo sólido */
	top: 0;
	z-index: 1000;
	background: transparent; /* Fondo eliminado */
	border-bottom: none;
	padding: 2rem 0;
	width: 100%;
	transition: var(--transition-premium);
}

.nav-container {
    width: 100%;
    padding: 3rem 4rem;
    display: flex;
    justify-content: flex-start;
}

.brand-name {
	font-family: var(--font-primary);
	font-size: 1.8rem;
	font-weight: 300;
	font-style: italic;
	color: var(--color-white);
	letter-spacing: 6px;
	transition: var(--transition-premium);
	display: block;
	text-shadow: 0 4px 10px rgba(0,0,0,0.5);
}

.nav-links {
    position: fixed;
    right: 4rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column; /* VERTICAL */
    gap: 2.5rem;
    align-items: flex-end;
    z-index: 2000;
}

.nav-links a {
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    padding-right: 1.5rem;
}

.nav-links a:hover, 
.nav-links a.active {
    color: var(--color-white);
    letter-spacing: 4px;
}

/* Indicador lateral minimalista */
.nav-links a::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 0;
    background: var(--color-accent);
    transition: height 0.5s ease;
}

.nav-links a:hover::after,
.nav-links a.active::after {
    height: 100%;
}

.cart-wrapper {
    margin-top: 1rem;
    opacity: 0.7;
    transition: 0.3s;
}
.cart-wrapper:hover { opacity: 1; }

/* 🏷️ Premium Tooltip */
[data-tooltip] {
    position: relative;
}

[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: rgba(0, 0, 0, 0.9);
    color: var(--color-accent);
    padding: 0.5rem 1rem;
    font-size: 0.6rem;
    font-weight: 800;
    white-space: nowrap;
    letter-spacing: 1px;
    border: 1px solid rgba(220, 177, 74, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 1000;
}

[data-tooltip]:hover::before {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
}
</style>
