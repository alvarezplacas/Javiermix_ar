---
// src/components/Header.astro
import CartNavButton from './ecommerce/CartNavButton.tsx';
const { currentPath = '/', theme = 'dark' } = Astro.props;
---

<header class={`site-header theme-${theme}`}>
	<nav class="nav-container" aria-label="Navegación principal">
		{currentPath === '/' ? (
			<a href="/" class="nav-logo" aria-label="Ir al Inicio">
				<span class="brand-name">JHM</span>
			</a>
		) : <div class="nav-spacer"></div>}
		
		<div class="nav-links">
            <a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
            <a href="/galeria" class={currentPath.startsWith('/galeria') ? 'active' : ''}>Colección</a>
            <a href="/rescate" class={currentPath.startsWith('/rescate') ? 'active' : ''} data-tooltip="Restauración y rescate de fotografías antiguas">Rescate</a>
            <a href="/royal-gallery" class={currentPath.startsWith('/royal-gallery') ? 'active' : ''}>Royal</a>
            <a href="/revista" class={currentPath.startsWith('/revista') ? 'active' : ''}>Revista</a>
			<CartNavButton client:load />
		</div>
	</nav>
</header>

<style>
.site-header {
	position: absolute; /* Para que flote sobre el contenido sin fondo sólido */
	top: 0;
	z-index: 1000;
	background: transparent; /* Fondo eliminado */
	border-bottom: none;
	padding: 2rem 0;
	width: 100%;
	transition: var(--transition-premium);
}

.nav-container {
	width: 100%;
	padding: 0 4rem;
	display: flex;
	justify-content: flex-end; /* Empuja el menú a la derecha absoluta */
	align-items: center;
    position: relative;
}

.nav-logo {
    position: absolute;
    left: 4rem;
}

.brand-name {
	font-family: var(--font-primary);
	font-size: 1.8rem; /* Un poco más pequeño para evitar pises */
	font-weight: 300;
	font-style: italic;
	color: var(--color-white);
	letter-spacing: 6px;
	transition: var(--transition-premium);
	display: block;
	text-shadow: 0 4px 10px rgba(0,0,0,0.5);
}


.nav-links {
	display: flex;
	gap: 3.5rem; /* Espaciado elegante */
	align-items: center;
}

.nav-links a {
	color: var(--color-text-muted);
	text-decoration: none;
	transition: all 0.4s ease;
	position: relative;
	padding: 0.5rem 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: capitalize;
}

.nav-links a:hover, 
.nav-links a.active {
	color: var(--color-white);
}

.nav-links a::after {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	width: 0;
	height: 1px;
	background-color: var(--color-accent);
	transition: var(--transition-premium);
}

.nav-links a:hover::after,
.nav-links a.active::after {
	width: 100%;
}

/* 🏷️ Premium Tooltip */
[data-tooltip] {
    position: relative;
}

[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: rgba(0, 0, 0, 0.9);
    color: var(--color-accent);
    padding: 0.5rem 1rem;
    font-size: 0.6rem;
    font-weight: 800;
    white-space: nowrap;
    letter-spacing: 1px;
    border: 1px solid rgba(220, 177, 74, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 1000;
}

[data-tooltip]:hover::before {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
}
</style>
