---
// src/components/Header.astro
import CartNavButton from './ecommerce/CartNavButton.tsx';
const { currentPath = '/', theme = 'dark' } = Astro.props;
---

<header class={`site-header theme-${theme}`}>
	<nav class="nav-container" aria-label="Navegación principal">
		{currentPath === '/' ? (
			<a href="/" class="nav-logo" aria-label="Ir al Inicio">
				<span class="brand-name">JHM</span>
			</a>
		) : <div class="nav-spacer"></div>}
		
		<div class="nav-links">
            <div class="nav-pill">
                <a href="/" class={currentPath === '/' ? 'active' : ''}>
                    <span class="nav-idx">01</span>Inicio
                </a>
                <a href="/galeria" class={currentPath.startsWith('/galeria') ? 'active' : ''}>
                    <span class="nav-idx">02</span>Colección
                </a>
                <a href="/rescate" class={currentPath.startsWith('/rescate') ? 'active' : ''} data-tooltip="Restauración y rescate de fotografías antiguas">
                    <span class="nav-idx">03</span>Rescate
                </a>
                <a href="/royal-gallery" class={currentPath.startsWith('/royal-gallery') ? 'active' : ''}>
                    <span class="nav-idx">04</span>Royal
                </a>
                <a href="/revista" class={currentPath.startsWith('/revista') ? 'active' : ''}>
                    <span class="nav-idx">05</span>Revista
                </a>
            </div>
			<CartNavButton client:load />
		</div>
	</nav>
</header>

<style>
.site-header {
	position: absolute; /* Para que flote sobre el contenido sin fondo sólido */
	top: 0;
	z-index: 1000;
	background: transparent; /* Fondo eliminado */
	border-bottom: none;
	padding: 2rem 0;
	width: 100%;
	transition: var(--transition-premium);
}

.nav-container {
	max-width: var(--container-max);
	margin: 0 auto;
	padding: 0 5%;
	display: flex;
	justify-content: space-between;
	align-items: center;
    gap: 15vw;
}

.brand-name {
	font-family: var(--font-primary);
	font-size: 1.8rem; /* Un poco más pequeño para evitar pises */
	font-weight: 300;
	font-style: italic;
	color: var(--color-white);
	letter-spacing: 6px;
	transition: var(--transition-premium);
	display: block;
	text-shadow: 0 4px 10px rgba(0,0,0,0.5);
}


.nav-links {
	display: flex;
	gap: 1.5rem;
	font-family: var(--font-secondary);
	font-size: 0.7rem;
	text-transform: uppercase;
	letter-spacing: 2px;
    font-weight: 500;
    align-items: center;
}

.nav-pill {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.6rem 2rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.nav-pill:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
}

.nav-idx {
    font-family: monospace;
    font-size: 0.5rem;
    color: var(--color-accent);
    margin-right: 0.5rem;
    opacity: 0.6;
    font-weight: 400;
}

.nav-links a {
	color: var(--color-text-muted);
	text-decoration: none;
	transition: var(--transition-premium);
	position: relative;
	padding: 0.5rem 0;
}

.nav-links a:hover, 
.nav-links a.active {
	color: var(--color-white);
}

.nav-links a::after {
	content: '';
	position: absolute;
	bottom: 0;
	left: 0;
	width: 0;
	height: 1px;
	background-color: var(--color-accent);
	transition: var(--transition-premium);
}

.nav-links a:hover::after,
.nav-links a.active::after {
	width: 100%;
}

.nav-pill a {
    display: flex;
    align-items: center;
}

/* 🏷️ Premium Tooltip */
[data-tooltip] {
    position: relative;
}

[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: rgba(0, 0, 0, 0.9);
    color: var(--color-accent);
    padding: 0.5rem 1rem;
    font-size: 0.6rem;
    font-weight: 800;
    white-space: nowrap;
    letter-spacing: 1px;
    border: 1px solid rgba(220, 177, 74, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 1000;
}

[data-tooltip]:hover::before {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
}
</style>
