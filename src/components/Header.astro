---
// src/components/Header.astro
import CartNavButton from './ecommerce/CartNavButton.tsx';
const { currentPath = '/', theme = 'dark' } = Astro.props;
---

<header class={`site-header theme-${theme}`}>
	<nav class="nav-container" aria-label="Navegación principal">
		<div class="nav-links">
            <a href="/" class={currentPath === '/' ? 'active' : ''}>Inicio</a>
            <a href="/galeria" class={currentPath.startsWith('/galeria') ? 'active' : ''}>Colección</a>
            <a href="/rescate" class={currentPath.startsWith('/rescate') ? 'active' : ''}>Rescate</a>
            <a href="/royal-gallery" class={currentPath.startsWith('/royal-gallery') ? 'active' : ''}>Royal</a>
            <a href="/revista" class={currentPath.startsWith('/revista') ? 'active' : ''}>Revista</a>
            <div class="cart-wrapper">
			    <CartNavButton client:load />
            </div>
		</div>
	</nav>
</header>

<style>
.site-header {
	position: absolute;
	top: 0;
	z-index: 1000;
	background: transparent;
	width: 100%;
	transition: var(--transition-premium);
}

.nav-container {
    width: 100%;
    padding: 2rem 4rem;
    display: flex;
    justify-content: flex-end; /* Aligned to the right */
    align-items: center;
}

.nav-links {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: center;
    z-index: 2000;
}

.nav-links a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    padding: 0.5rem 0;
}

.nav-links a:hover, 
.nav-links a.active {
    color: var(--color-white);
    letter-spacing: 3px;
}

/* Indicador inferior minimalista */
.nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.5s ease;
}

.nav-links a:hover::after,
.nav-links a.active::after {
    width: 100%;
}

.cart-wrapper {
    margin-left: 1rem;
    opacity: 0.7;
    transition: 0.3s;
}
.cart-wrapper:hover { opacity: 1; }

/* 🏷️ Premium Tooltip */
[data-tooltip] {
    position: relative;
}

[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: rgba(0, 0, 0, 0.9);
    color: var(--color-accent);
    padding: 0.5rem 1rem;
    font-size: 0.6rem;
    font-weight: 800;
    white-space: nowrap;
    letter-spacing: 1px;
    border: 1px solid rgba(220, 177, 74, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 1000;
}

[data-tooltip]:hover::before {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
}

@media (max-width: 1024px) {
    .nav-container {
        padding: 2rem;
    }
    .nav-links {
        gap: 1.5rem;
    }
    .nav-links a {
        font-size: 0.8rem;
        letter-spacing: 1px;
    }
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
}
</style>
</style>
