---
import { getFooterSettings, getSeries, getArticles } from '@conexion/directus';

const currentYear = new Date().getFullYear();
const footerSettings = await getFooterSettings();
const allSeries = await getSeries();
const latestArticles = await getArticles();

// Limitar a los que necesitamos
const footerSeries = allSeries.slice(0, 5);
const footerArticles = latestArticles.slice(0, 3);

// Fallbacks
const brandText = footerSettings?.brand_text || "Colecciones exclusivas donde la luz, el metal y la memoria convergen en obra de autor. Para coleccionistas y decoradores de interiores que buscan una presencia sólida y honesta.";
const services = footerSettings?.services?.split('\n').filter((s: string) => s.trim() !== '') || ["Carrito de Ventas", "Prueba tu Obra en tu Espacio", "Laboratorio de Diseño 2026", "Ediciones Limitadas"];
const instagram = footerSettings?.instagram_url || "https://instagram.com/javiermix";
const whatsapp = footerSettings?.whatsapp_url || "#";
const behance = footerSettings?.behance_url || "#";
const contactEmail = footerSettings?.contact_email || "info@javiermix.com";
const contactWhatsapp = footerSettings?.contact_whatsapp || "+54 9 11 XXXX XXXX";
const studioAddress = footerSettings?.contact_studio_address || "Buenos Aires, Argentina";
---

<footer class="site-footer">
  <div class="footer-sitemap">
    <div class="sitemap-inner">      <div class="footer-brand">
        <p class="brand-signature">Javier Mix</p>
        <p class="brand-tagline">Fotografía Fine Art · Buenos Aires</p>
        <p class="brand-desc">
          {brandText}
        </p>
        <div class="footer-socials">
          <a href={instagram} target="_blank" aria-label="Instagram" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            Instagram
          </a>
          <a href={whatsapp} target="_blank" aria-label="WhatsApp" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            WhatsApp
          </a>
          <a href={behance} target="_blank" aria-label="Behance" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12C1 5.9 5.9 1 12 1s11 5 11 11-5 11-11 11S1 18.1 1 12z"/><path d="M10 8H6v8h4.5a2.5 2.5 0 0 0 0-5H6"/><line x1="14" y1="9" x2="18" y2="9"/><path d="M18 13h-4c0 1.1.9 2 2 2s2-.5 2-2z"/></svg>
            Behance
          </a>
        </div>
      </div>

      <nav class="footer-nav-col" aria-label="Colecciones de obras">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Colecciones
        </h4>
        <ul>
          <li><a href="/galeria">Ver Portfolio Completo</a></li>
          {footerSeries.map((serie: any) => (
             <li><a href={`/galeria/${serie.name.replace(/ /g, '_')}`}>{serie.name}</a></li>
          ))}
          <li><a href="/galeria" class="link-all">→ Ver todas las series</a></li>
        </ul>
      </nav>

      <nav class="footer-nav-col" aria-label="Servicios">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Servicios
        </h4>
        <ul>
          {services.map((service: string) => (
            <li><a href="#">{service}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="footer-nav-col" aria-label="Revista">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Revista Digital
        </h4>
        <ul>
          <li><a href="/revista">Últimas Notas</a></li>
          {footerArticles.map((article: any) => (
            <li><a href={`/revista/${article.slug}`}>{article.title}</a></li>
          ))}
          <li><a href="/revista" class="link-all">→ Ver todas las notas</a></li>
        </ul>
      </nav>

      <nav class="footer-nav-col" aria-label="Contacto">
        <h4 class="footer-nav-title">
          <span class="nav-title-line"></span>
          Contacto
        </h4>
        <ul>
          <li class="contact-item">
            <span class="contact-label">Consultas de Obra</span>
            <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
          </li>
          <li class="contact-item">
            <span class="contact-label">WhatsApp</span>
            <a href={whatsapp}>{contactWhatsapp}</a>
          </li>
          <li class="contact-item">
            <span class="contact-label">Estudio</span>
            <span>{studioAddress}</span>
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <div class="footer-divider">
    <span class="divider-line"></span>
    <span class="divider-mark">JM</span>
    <span class="divider-line"></span>
  </div>

  <div class="curaduria-link-container">
    <a href="/curaduria" class="curaduria-link">Consultas para Artistas / Curaduría</a>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="copyright">&copy; {currentYear} Javier Mix. Todos los derechos reservados.</p>
      <div class="bottom-links">
        <a href="#">Política de Privacidad</a>
        <a href="#">Términos de Uso</a>
        <a href="#">Envíos y Devoluciones</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #080808;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    font-family: var(--font-secondary);
    color: var(--color-text-muted);
  }

  .footer-sitemap {
    padding: 8rem 5% 6rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .sitemap-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 5rem;
  }

  .brand-signature {
    font-family: var(--font-primary);
    font-size: 2.5rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-white);
    margin-bottom: 0.5rem;
    letter-spacing: 2px;
  }

  .brand-tagline {
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 2rem;
  }

  .brand-desc {
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    max-width: 300px;
  }

  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 1px;
    transition: var(--transition-premium);
  }

  .social-link:hover {
    color: var(--color-accent);
    transform: translateX(5px);
  }

  .footer-nav-col {
    padding-top: 0.5rem;
  }

  .footer-nav-title {
    font-family: var(--font-primary);
    font-size: 1.3rem;
    color: var(--color-white);
    font-weight: 400;
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-title-line {
    display: block;
    width: 24px;
    height: 1px;
    background-color: var(--color-accent);
    flex-shrink: 0;
  }

  .footer-nav-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .footer-nav-col a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    transition: var(--transition-premium);
    display: block;
  }

  .footer-nav-col a:hover {
    color: var(--color-white);
    padding-left: 6px;
  }

  .link-all {
    color: var(--color-accent) !important;
    margin-top: 0.5rem;
    font-weight: 600;
  }

  .link-all:hover {
    padding-left: 10px !important;
  }

  .link-lab {
    color: var(--ok-gold) !important;
    font-weight: 600;
    position: relative;
  }

  .link-lab::after {
    content: 'NEW';
    font-size: 0.5rem;
    background: var(--ok-burgundy);
    color: white;
    padding: 2px 4px;
    border-radius: 2px;
    margin-left: 8px;
    vertical-align: middle;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-label {
    font-size: 0.65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-travertine-dark);
  }

  .contact-item a,
  .contact-item span {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.3s;
  }

  .contact-item a:hover {
    color: var(--color-accent);
  }

  .footer-divider {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0 5%;
    max-width: 1600px;
    margin: 0 auto 4rem;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.06));
  }

  .footer-divider .divider-line:last-child {
    background: linear-gradient(to left, transparent, rgba(255,255,255,0.06));
  }

  .divider-mark {
    font-family: var(--font-primary);
    font-size: 1.2rem;
    font-style: italic;
    color: rgba(255,255,255,0.15);
    letter-spacing: 4px;
    flex-shrink: 0;
  }

  .curaduria-link-container {
    text-align: center;
    margin-bottom: 4rem;
  }

  .curaduria-link {
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-travertine-dark);
    text-decoration: none;
    transition: var(--transition-premium);
    opacity: 0.5;
  }

  .curaduria-link:hover {
    color: var(--color-accent);
    opacity: 1;
    letter-spacing: 4px;
  }

  .footer-bottom {
    padding: 2rem 5%;
    border-top: 1px solid rgba(255,255,255,0.04);
    max-width: 1600px;
    margin: 0 auto;
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .copyright {
    font-size: 0.75rem;
    color: var(--color-travertine-dark);
    letter-spacing: 1px;
  }

  .bottom-links {
    display: flex;
    gap: 2rem;
  }

  .bottom-links a {
    font-size: 0.72rem;
    color: var(--color-travertine-dark);
    text-decoration: none;
    letter-spacing: 1px;
    transition: color 0.3s;
  }

  .bottom-links a:hover {
    color: var(--color-text-muted);
  }

  @media (max-width: 1200px) {
    .sitemap-inner {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 3rem;
    }
    .footer-brand {
      grid-column: span 3;
    }
  }

  @media (max-width: 768px) {
    .sitemap-inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .footer-brand {
      grid-column: span 2;
    }
    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }
    .bottom-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .sitemap-inner {
      grid-template-columns: 1fr;
    }
    .footer-brand {
      grid-column: span 1;
    }
  }
</style>
