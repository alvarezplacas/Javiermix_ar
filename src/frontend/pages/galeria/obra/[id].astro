---
// h:\Javiermix_web_v2\frontend\/galeria/obra/\[id].astro
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import FramingStudio from '@components/FramingStudio.astro';
import { getArtworkDetails, getSerieDetails, getArtworkLikes } from '@conexion/directus';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

const { id } = Astro.params; // Directus File ID
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL || 'https://admin.javiermix.ar';

let title = "Obra";
let serieName = "Colección";
let serieId = "";
let coverImage = "";
let roomImage = null;
let precio = 0;
let meta = null;
let sizes = [];
let likes = 0;

const artworkData = await getArtworkDetails(id as string);

if (!artworkData) return Astro.redirect('/galeria');

const { mainFile, meta: dbMeta } = artworkData;
coverImage = getOptimizedImageURL(mainFile.id);
serieId = mainFile.folder;
title = mainFile.title || mainFile.filename_download.split('.')[0];
meta = dbMeta;
likes = await getArtworkLikes(id as string);

if (serieId) {
    const { name, items } = await getSerieDetails(serieId);
    serieName = name;

    // Buscar imagen de sala (_2)
    const baseName = mainFile.filename_download.split('.')[0].toLowerCase();
    const roomFile = items.find(f => f.filename_download.toLowerCase().startsWith(`${baseName}_2.`));
    if (roomFile) {
        roomImage = getOptimizedImageURL(roomFile.id);
    }
}

if (meta) {
    title = meta.title || title;
    if (meta.precio_small) sizes.push({ label: 'Fine Art Print', dimensions: '30 x 45 cm', price: meta.precio_small });
    if (meta.precio_medium) sizes.push({ label: 'Fine Art Print', dimensions: '40 x 60 cm', price: meta.precio_medium });
    if (meta.precio_large) sizes.push({ label: 'Canson Museum Pro Canvas', dimensions: '60 x 90 cm', price: meta.precio_large });
    precio = sizes.length > 0 ? sizes[0].price : 0;
}

const whatsappNumber = "5491100000000"; 
const waLink = `https://wa.me/${whatsappNumber}?text=Hola,%20estoy%20interesado%20en%20adquirir%20la%20obra%20${encodeURIComponent(title)}%20de%20la%20colección%20${encodeURIComponent(serieName)}.`;
---

<Layout title={`${title} | Obra Fine Art`}>
  <Header currentPath="/galeria" />

  <article class="obra-container">
    <div class="split-layout">
      
      <section class="image-column">
        <div class="sticky-image-container">
          <div class="image-wrapper">
            <img src={coverImage} alt="" class="main-artwork" id="primary-image" />
            {roomImage && (
              <img src={roomImage} alt="" class="room-artwork" id="secondary-image" />
            )}
            <button class="like-btn floating-like" data-artwork-id={id} aria-label="Dar Like">
              <svg class="heart-svg" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <span class="like-count-float" id="float-like-count">{likes}</span>
            </button>
          </div>
          
          <div class="image-controls">
            {roomImage ? (
               <button class="control-btn active" id="btn-obra">VER EN SALA</button>
            ) : (
               <button class="control-btn" style="opacity: 0.3; cursor: not-allowed;" disabled>SIN VISTA EN SALA</button>
            )}
            <button class="control-btn" id="btn-3d">VER EN 3D</button>
            <button class="control-btn" id="btn-marco">PROBAR MARCO</button>
          </div>

          <div class="share-controls">
            <span>COMPARTIR:</span>
            <div class="social-icons">
               <svg class="social-svg" viewBox="0 0 24 24"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.816 9.816 0 0 0 12.04 2zm5.82 14.1c-.25.7-.25 1.25-.33 1.5-.08.25-.17.58-.58.91-.41.33-1.07.41-1.65.16s-1 .16-2.58-.5c-1.58-.66-2.58-2.23-2.66-2.31-.08-.08-.66-.83-.66-1.58 0-.75.33-1.16.5-1.41.17-.25.33-.33.41-.33h.33c.08 0 .17 0 .25.08.08.08.17.25.25.41l.58 1.41c.08.17.08.33 0 .41-.08.08-.17.17-.25.25l-.41.33c-.08.08-.08.25.08.41.66.91 1.41 1.58 2.31 1.99.17.08.33.08.41 0l.91-.83c.08-.08.25-.08.41 0l1.41.66c.17.08.25.17.33.25.08.08.17.17 0 .41z"/></svg>
               <svg class="social-svg" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
               <svg class="social-svg" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.335 3.608 1.31.975.975 1.248 2.242 1.31 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.335 2.633-1.31 3.608-.975.975-2.242 1.248-3.608 1.31-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.335-3.608-1.31-.975-.975-1.248-2.242-1.31-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.335-2.633 1.31-3.608.975-.975 2.242-1.248 3.608-1.31 1.266-.058 1.646-.07 4.85-.07M12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.2 4.358 2.618 6.777 6.947 6.977 1.28.058 1.688.072 4.947.072s3.667-.014 4.947-.072c4.351-.2 6.777-2.618 6.977-6.947.058-1.28.072-1.688.072-4.947s-.014-3.667-.072-4.947c-.2-4.349-2.619-6.777-6.977-6.977C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4.162 4.162 0 1 1 0-8.324A4.162 4.162 0 0 1 12 16zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </div>
          </div>
        </div>
      </section>

      <section class="info-column">
        <a href={`/galeria/${serieId}`} class="back-link">← VOLVER A {serieName}</a>
        
        <div class="serie-label">SERIE: {serieName}</div>
        <div class="title-row">
            <h1 class="obra-title">{title}</h1>
            <div class="likes-badge">
                <span class="likes-count-display">{likes} <span class="likes-label">Personas les gusta esto</span></span>
            </div>
        </div>
        
        <div class="tags-container">
          <span class="tag-accent">FINE ART PRINT</span>
          <span class="tag-outline">CERTIFICADO DE AUTENTICIDAD</span>
          <span class="tag-outline">CALIDAD MUSEO</span>
        </div>
        
        <div class="tabs-header">
          <button class="tab-btn active" data-target="historia">HISTORIA</button>
          <button class="tab-btn" data-target="ficha">FICHA TÉCNICA</button>
          <button class="tab-btn" data-target="terminos">TÉRMINOS</button>
        </div>
        
        <div class="tab-content" id="tab-historia">
          <div class="prose-content">
            <h2 class="prose-title">La Historia detrás de la Imagen</h2>
            <p class="prose-text">{meta?.description || "Esta pieza de autor es parte de una selección curada rigurosamente. Refleja nuestro compromiso con el legado fotográfico y el diseño contemporáneo a nivel internacional."}</p>
          </div>
        </div>

        <div class="tab-content" id="tab-ficha" style="display: none;">
          <div class="technical-details">
            <div class="tech-row">
              <span class="tech-icon-label">
                <svg class="tech-svg" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
              </span>
              <span class="tech-value">{meta?.paper || 'Papel Algodón 100%'}</span>
            </div>
            <div class="tech-row">
              <span class="tech-icon-label">
                <svg class="tech-svg" viewBox="0 0 24 24"><path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 10H3V8h2v2h2V8h2v2h2V8h2v2h2V8h2v2h2V8h2v8z"/></svg>
              </span>
              <span class="tech-value">{meta?.dimensions || 'A convenir'}</span>
            </div>
            <div class="tech-row">
              <span class="tech-icon-label">
                <svg class="tech-svg" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
              </span>
              <span class="tech-value">Certificado de Autenticidad</span>
            </div>
            
            <div class="tech-grid-mini">
              <div class="mini-item">
                <svg class="mini-svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.2"/><path d="M9 2L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2h-3.17L15 2H9zm3 15c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5z"/></svg>
                <span class="mini-value">{meta?.camera || 'Fine Art'}</span>
              </div>
              <div class="mini-item">
                <svg class="mini-svg" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 12 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-12.5c-2.48 0-4.5 2.02-4.5 4.5s2.02 4.5 4.5 4.5 4.5-2.02 4.5-4.5-2.02-4.5-4.5-4.5z"/></svg>
                <span class="mini-value">{meta?.lens || 'Prime'}</span>
              </div>
              <div class="mini-item">
                <svg class="mini-svg" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 1.99 2H19c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z"/></svg>
                <span class="mini-value">{meta?.date || '2024'}</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="tab-content" id="tab-terminos" style="display: none;">
           <div class="legal-content">
              <p>El valor corresponde a la pieza impresa. No incluye marco ni envío.</p>
              <p>Cada obra se entrega con un certificado de autenticidad firmado por el autor.</p>
           </div>
        </div>

        <div class="canvas-info" id="canvas-info">
          <div class="canvas-info-inner">
            <span class="canvas-badge">GRAN FORMATO · EDICIÓN LIMITADA</span>
            <h4 class="canvas-title">Canson Museum Pro Canvas · 385 g/m²</h4>
            <p class="canvas-body">
              El formato Grande se imprime sobre un canvas <strong>100% algodón libre de ácidos</strong>, pensado para durar décadas sin perder ni un tono. Su textura profunda añade presencia táctil a cada imagen —el óxido, el metal, la luz capturada cobran un relieve que el papel no puede igualar. El acabado mate resistente al agua elimina la necesidad de vidrio.
            </p>
          </div>
        </div>
        
        <!-- Eliminado hr.divider disruptivo -->

        {sizes.length > 0 && (
          <div class="size-selector-section">
            <span class="size-selector-label">SELECCIONA TAMAÑO:</span>
            <div class="size-options" id="size-options">
              {sizes.map((s, i) => (
                <button
                  class={`size-option${i === 0 ? ' active' : ''}`}
                  data-price={s.price}
                  data-dimensions={s.dimensions}
                  data-label={s.label}
                >
                  <span class="size-dimensions">{s.dimensions}</span>
                  <span class="size-label-text">{s.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <div class="checkout-area">
          <div class="price-box">
             <span class="price-label">PRECIO</span>
             <div class="price-value">
               <span class="number" id="price-display">{precio}</span>
               <span class="currency">U$D</span>
             </div>
          </div>
          
          <div class="action-buttons">
             <a href={waLink} target="_blank" class="btn-buy" id="btn-buy-link">ADQUIRIR OBRA</a>
          </div>
        </div>
      </section>

    </div>
  </article>

  <FramingStudio imageSrc={coverImage} title={title} />
  <Footer />
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // Tabs Logic Refined
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    
    function switchTab(btn: HTMLElement) {
        const targetId = btn.getAttribute('data-target');
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        tabContents.forEach(c => {
            const content = c as HTMLElement;
            if (content.id === `tab-${targetId}`) {
                content.style.display = 'block';
                content.classList.add('fade-in-content');
                setTimeout(() => content.classList.remove('fade-in-content'), 600);
            } else {
                content.style.display = 'none';
            }
        });
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn as HTMLElement));
    });

    // Room view hover simulation
    const btnObra = document.getElementById('btn-obra');
    const imgPrim = document.getElementById('primary-image');
    const imgSec = document.getElementById('secondary-image');
    if(btnObra && imgPrim && imgSec) {
        btnObra.addEventListener('mouseenter', () => { imgPrim.style.opacity = '0'; imgSec.style.opacity = '1'; });
        btnObra.addEventListener('mouseleave', () => { imgPrim.style.opacity = '1'; imgSec.style.opacity = '0'; });
    }

    // Framing Studio
    const btnMarco = document.getElementById('btn-marco');
    const studio = document.getElementById('framing-studio');
    if (btnMarco && studio) {
      btnMarco.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    }

    // 3D View
    const btn3D = document.getElementById('btn-3d');
    if (btn3D && studio) {
      btn3D.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden';
        if ((window as any).activate3DInStudio) (window as any).activate3DInStudio();
      });
    }

    // Smart Orientation Detection Algorithm
    const primaryImg = document.getElementById('primary-image') as HTMLImageElement;
    const wrapper = document.querySelector('.image-wrapper');

    function updateOrientation() {
      if (!primaryImg || !wrapper) return;
      const isPortrait = primaryImg.naturalHeight > primaryImg.naturalWidth;
      wrapper.classList.toggle('is-portrait', isPortrait);
      wrapper.classList.toggle('is-landscape', !isPortrait);
    }

    if (primaryImg) {
      if (primaryImg.complete) updateOrientation();
      else primaryImg.addEventListener('load', updateOrientation);
    }

    // Master-level Refined Zoom 1.6x dengan Panning
    function handleMove(e: any) {
      if (!wrapper || !primaryImg) return;
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      const { left, top, width, height } = wrapper.getBoundingClientRect();
      const x = (clientX - left) / width;
      const y = (clientY - top) / height;
      const moveX = (x - 0.5) * -60;
      const moveY = (y - 0.5) * -60;
      primaryImg.style.transition = 'transform 0.8s cubic-bezier(0.19, 1, 0.22, 1)';
      primaryImg.style.transform = `scale(1.6) translate(${moveX}px, ${moveY}px)`;
    }

    function handleReset() {
      if (!primaryImg) return;
      primaryImg.style.transition = 'transform 0.8s cubic-bezier(0.19, 1, 0.22, 1)';
      primaryImg.style.transform = `scale(1) translate(0, 0)`;
    }

    if (wrapper) {
      wrapper.addEventListener('mousemove', handleMove);
      wrapper.addEventListener('mouseleave', handleReset);
      wrapper.addEventListener('touchmove', (e) => {
        handleMove(e);
        if (e.cancelable) e.preventDefault();
      }, { passive: false });
      wrapper.addEventListener('touchend', handleReset);
    }

    // Size Selector & Canvas Info
    const sizeButtons = document.querySelectorAll('.size-option');
    const priceDisplay = document.getElementById('price-display');
    const canvasInfo = document.getElementById('canvas-info');

    sizeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        sizeButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const newPrice = btn.getAttribute('data-price');
        const label = btn.getAttribute('data-label');
        
        if (priceDisplay && newPrice) {
          priceDisplay.textContent = newPrice;
          priceDisplay.classList.add('price-pop');
          setTimeout(() => priceDisplay.classList.remove('price-pop'), 400);
        }

        if (canvasInfo) {
          if (label === 'Large') canvasInfo.classList.add('visible');
          else canvasInfo.classList.remove('visible');
        }
      });
    });

    // Likes Logic Simplified
    const likeButtons = document.querySelectorAll('.like-btn');
    likeButtons.forEach(btn => {
        btn.addEventListener('click', async () => {
            const artworkId = btn.getAttribute('data-artwork-id');
            btn.classList.add('animating');
            setTimeout(() => btn.classList.remove('animating'), 400);
            
            try {
                const res = await fetch('/api/like', {
                    method: 'POST',
                    body: JSON.stringify({ artworkId })
                });
                if (res.ok) {
                    const countEl = document.querySelector('.likes-count-display');
                    const floatCountEl = document.getElementById('float-like-count');
                    [countEl, floatCountEl].forEach(el => {
                        if (el) {
                            const current = parseInt(el.textContent || '0');
                            if (el.id === 'float-like-count') el.textContent = String(current + 1);
                            else el.innerHTML = `${current + 1} <span class="likes-label">Personas les gusta esto</span>`;
                        }
                    });
                    btn.classList.add('liked');
                }
            } catch (err) { console.error("Error liking:", err); }
        });
    });
  });
</script>

<style>
.obra-container { min-height: 100vh; }
.split-layout { display: flex; width: 100%; position: relative; }
.image-column { 
    position: sticky; 
    top: 0; 
    width: 50vw; 
    height: 100vh; 
    background: #0d0d0d; 
    padding: 0 5%; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    z-index: 10;
}
.info-column { 
    width: 50vw; 
    padding: 160px 8% 10rem; 
    background: #050505; 
    min-height: 100vh; 
}

.image-wrapper { 
    position: relative; 
    width: 100%; 
    height: 70vh; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
}

/* Regla del 80% Smart V1 */
.image-wrapper.is-portrait .main-artwork { height: 80%; width: auto; }
.image-wrapper.is-landscape .main-artwork { width: 80%; height: auto; }

.main-artwork, .room-artwork { 
    max-width: 100%; 
    max-height: 100%; 
    object-fit: contain; 
    transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1), opacity 0.5s ease;
    will-change: transform;
}

.room-artwork { position: absolute; opacity: 0; }

.floating-like {
    position: absolute;
    top: 3rem;
    left: 3rem;
    background: rgba(191, 21, 52, 0.2);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(191, 21, 52, 0.4);
    padding: 0 1.5rem;
    height: 62px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    z-index: 100;
    transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    cursor: pointer;
}

.floating-like:hover {
    background: rgba(191, 21, 52, 0.35);
    transform: scale(1.05);
}

.like-count-float {
    color: #fff;
    font-size: 1rem;
    font-weight: 500;
    font-family: var(--font-secondary);
}

.floating-like .heart-svg {
    width: 22px;
    height: 22px;
    fill: #fff;
    opacity: 0.9;
}

.image-controls { display: flex; gap: 1rem; margin-top: 2rem; width: 100%; }
.control-btn { 
    flex: 1; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); 
    color: var(--color-travertine-light); padding: 1rem; cursor: pointer; font-size: 0.65rem; letter-spacing: 2px;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    opacity: 0.8;
}
.control-btn:hover { opacity: 1; border-color: #C5A059; color: #fff; }
.control-btn.active { border-color: #C5A059; color: #C5A059; opacity: 1; }

.share-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 3rem;
    font-size: 0.55rem;
    color: var(--color-travertine-mid);
    letter-spacing: 2px;
    opacity: 0.6;
}

.social-svg {
    width: 14px;
    height: 14px;
    fill: var(--color-travertine-mid);
    transition: fill 0.3s ease;
    cursor: pointer;
}

.social-svg:hover {
    fill: #C5A059;
}

.back-link { display: block; margin-bottom: 2rem; font-size: 0.65rem; letter-spacing: 2px; color: #C5A059; opacity: 0.7; }
.back-link:hover { opacity: 1; }
