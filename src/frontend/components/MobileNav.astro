---
// MobileNav.astro — Barra de navegación flotante para móvil
const currentPath = Astro.url?.pathname ?? '/';

const navItems = [
  {
    label: 'Inicio',
    href: '/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9.5L12 3l9 6.5V21a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
    </svg>`
  },
  {
    label: 'Buscar',
    href: '/galeria',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>`
  },
  {
    label: 'Revista',
    href: '/revista',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
    </svg>`
  },
  {
    label: 'Contactar',
    href: 'https://wa.me/5491100000000',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>`
  }
];
---

<nav class="mobile-nav" id="mobile-nav" aria-label="Navegación móvil">
  {navItems.map(item => {
    const isActive = currentPath === item.href || 
      (item.href !== '/' && currentPath.startsWith(item.href));
    return (
      <a href={item.href} class={`mobile-nav-item ${isActive ? 'active' : ''}`} aria-label={item.label}>
        <span class="nav-icon" set:html={item.icon} />
        <span class="nav-label">{item.label}</span>
        {isActive && <span class="active-dot" />}
      </a>
    );
  })}
</nav>

<style>
  .mobile-nav {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-nav {
      display: flex;
      position: fixed;
      bottom: 1.2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 9999;
      width: calc(100% - 3rem);
      max-width: 420px;
      background: rgba(10, 10, 10, 0.88);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.6),
        0 0 0 0.5px rgba(255, 255, 255, 0.04) inset;
      padding: 0.6rem 0.5rem;
      justify-content: space-around;
      align-items: center;
      gap: 0.25rem;
      animation: slideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateX(-50%) translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
    }

    .mobile-nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      padding: 0.6rem 1rem;
      border-radius: 16px;
      text-decoration: none;
      color: rgba(255, 255, 255, 0.4);
      transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      flex: 1;
      min-width: 0;
    }

    .mobile-nav-item:active {
      transform: scale(0.94);
    }

    .mobile-nav-item.active {
      color: var(--color-accent);
      background: rgba(220, 177, 74, 0.08);
    }

    .nav-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }

    .nav-icon svg {
      width: 100%;
      height: 100%;
      transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .mobile-nav-item.active .nav-icon svg {
      transform: translateY(-1px);
    }

    .nav-label {
      font-family: var(--font-secondary);
      font-size: 0.6rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      font-weight: 600;
      white-space: nowrap;
      transition: color 0.35s ease;
    }

    .active-dot {
      position: absolute;
      bottom: 0.3rem;
      left: 50%;
      transform: translateX(-50%);
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background-color: var(--color-accent);
      animation: dotPop 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes dotPop {
      from { transform: translateX(-50%) scale(0); }
      to   { transform: translateX(-50%) scale(1); }
    }
  }
</style>
