---
// h:\Javiermix_web_v2\frontend\layouts\AdminLayout.astro
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// Verificación de Sesión (SSR) - Solo extracción de token
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | BÓVEDA JHM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <ClientRouter />
</head>
<body class="admin-body">
    <div class="admin-interface">
        <aside class="compact-sidebar" transition:persist>
            <div class="sidebar-top">
                <a href="/dashboard" class="logo-box">
                    <span class="logo-text">JM</span>
                </a>
            </div>
            
            <nav class="sidebar-main-nav">
                <a href="/dashboard" class={currentPath === '/dashboard' ? 'active' : ''} data-tooltip="Resumen">
                    <i class="fas fa-th-large"></i>
                </a>
                <a href="/dashboard/ventas" class={currentPath.startsWith('/dashboard/ventas') ? 'active' : ''} data-tooltip="Ventas">
                    <i class="fas fa-shopping-bag"></i>
                </a>
                <a href="/dashboard/obras" class={currentPath.startsWith('/dashboard/obras') ? 'active' : ''} data-tooltip="Colección">
                    <i class="fas fa-layer-group"></i>
                </a>
                <a href="/dashboard/revista" class={currentPath.startsWith('/dashboard/revista') ? 'active' : ''} data-tooltip="Revista">
                    <i class="fas fa-pen-nib"></i>
                </a>
                <a href="/dashboard/certificados" class={currentPath.startsWith('/dashboard/certificados') ? 'active' : ''} data-tooltip="Certificados">
                    <i class="fas fa-certificate"></i>
                </a>
            </nav>
            
            <div class="sidebar-bottom">
                <a href="/" class="btn-external" data-tooltip="Ir a la Web">
                    <i class="fas fa-external-link-alt"></i>
                </a>
                <button id="btn-logout" class="btn-logout" data-tooltip="Salir">
                    <i class="fas fa-power-off"></i>
                </button>
            </div>
        </aside>

        <main class="main-workspace">
            <header class="workspace-header">
                <div class="header-left">
                    <span class="system-tag">H-OS v2.0</span>
                    <h1 class="page-title">{title}</h1>
                </div>
                <div class="header-right">
                    <div class="user-badge">
                        <div class="user-info">
                            <span class="user-name">Javier Mix</span>
                            <span class="user-role">ADMINISTRADOR</span>
                        </div>
                        <div class="user-avatar">JM</div>
                    </div>
                </div>
            </header>
            
            <div class="workspace-body" transition:animate="fade">
                <slot />
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('astro:page-load', () => {
            document.getElementById('btn-logout')?.addEventListener('click', () => {
                document.cookie = "jhm_admin_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Strict;";
                window.location.href = '/dashboard/login';
            });
        });
    </script>
</body>
</html>

<style is:global>
    :root {
        --c-bg: #050505;
        --c-sidebar: #0a0a0a;
        --c-accent: #C5A059;
        --c-text: #F2EFE9;
        --c-muted: rgba(242, 239, 233, 0.4);
        --c-border: rgba(255, 255, 255, 0.04);
        --sidebar-w: 80px;
        --header-h: 70px;
    }

    * { box-sizing: border-box; }

    body.admin-body {
        margin: 0;
        background-color: var(--c-bg);
        color: var(--c-text);
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    .admin-interface {
        display: flex;
        min-height: 100vh;
    }

    /* Sidebar Slim */
    .compact-sidebar {
        width: var(--sidebar-w);
        background-color: var(--c-sidebar);
        border-right: 1px solid var(--c-border);
        position: fixed;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem 0;
        z-index: 100;
    }

    .sidebar-top { margin-bottom: 3rem; }
    .logo-box {
        width: 40px;
        height: 40px;
        border: 1px solid var(--c-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }
    .logo-text { color: var(--c-accent); font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; }

    .sidebar-main-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .sidebar-main-nav a, .sidebar-bottom a, .sidebar-bottom button {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--c-muted);
        text-decoration: none;
        font-size: 1.2rem;
        border-radius: 8px;
        transition: all 0.3s ease;
        position: relative;
        background: transparent;
        border: none;
        cursor: pointer;
    }

    .sidebar-main-nav a:hover, .sidebar-bottom a:hover, .sidebar-bottom button:hover {
        color: var(--c-text);
        background: rgba(255,255,255,0.03);
    }

    .sidebar-main-nav a.active {
        color: var(--c-accent);
        background: rgba(197, 160, 89, 0.1);
    }

    /* Tooltips */
    [data-tooltip]::before {
        content: attr(data-tooltip);
        position: absolute;
        left: 100%;
        margin-left: 15px;
        background: var(--c-accent);
        color: #000;
        padding: 4px 10px;
        font-size: 0.7rem;
        border-radius: 4px;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        transition: all 0.2s ease;
        pointer-events: none;
        font-weight: 600;
        z-index: 200;
    }

    [data-tooltip]:hover::before {
        opacity: 1;
        visibility: visible;
        transform: translateX(0);
    }

    /* Workspace */
    .main-workspace {
        flex: 1;
        margin-left: var(--sidebar-w);
        display: flex;
        flex-direction: column;
    }

    .workspace-header {
        height: var(--header-h);
        padding: 0 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--c-border);
        background: rgba(5,5,5,0.5);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 90;
    }

    .system-tag {
        font-size: 0.55rem;
        letter-spacing: 2px;
        color: var(--c-accent);
        opacity: 0.6;
        text-transform: uppercase;
    }

    .page-title {
        font-size: 1.1rem;
        margin: 0.2rem 0 0;
        font-weight: 300;
        letter-spacing: 1px;
        color: var(--c-text);
    }

    .user-badge {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .user-info {
        text-align: right;
    }

    .user-name {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .user-role {
        display: block;
        font-size: 0.55rem;
        color: var(--c-accent);
        letter-spacing: 1px;
    }

    .user-avatar {
        width: 35px;
        height: 35px;
        background: var(--c-accent);
        color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 800;
        border-radius: 50%;
    }

    .workspace-body {
        padding: 3rem;
        max-width: 1600px;
        margin: 0 auto;
        width: 100%;
    }

    /* Componentes Globales del Dashboard */
    .dashboard-card {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--c-border);
        padding: 2rem;
        border-radius: 4px;
    }

    .btn-action {
        background: var(--c-accent);
        color: #000;
        border: none;
        padding: 0.8rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        cursor: pointer;
        transition: opacity 0.3s ease;
    }

    .btn-action:hover { opacity: 0.9; }

    .sidebar-bottom {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--c-border);
    }

    .btn-logout:hover { color: #ef4444 !important; }
</style>
