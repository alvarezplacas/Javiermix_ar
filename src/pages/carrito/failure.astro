---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Pago Fallido | Javier Mix">
  <Header currentPath="/carrito" />
  
  <main class="status-container">
    <div class="status-card">
      <div class="status-icon failure">
        <i class="fas fa-exclamation-circle"></i>
      </div>
      <h1 class="status-title">Hubo un problema con el pago</h1>
      <p class="status-message">Lo sentimos, no pudimos procesar tu transacción. Por favor, intenta de nuevo o comunícate directamente con Javier Mix si el problema persiste.</p>
      
      <div class="status-actions">
        <a href="/galeria" class="btn-primary">INTENTAR DE NUEVO</a>
        <a href="/" class="btn-secondary">INICIO</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .status-container {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: #050505;
  }
  .status-card {
    max-width: 600px;
    text-align: center;
    background: rgba(255, 255, 255, 0.02);
    padding: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
  }
  .status-icon {
    font-size: 5rem;
    margin-bottom: 2rem;
  }
  .status-icon.failure {
    color: #e74c3c;
  }
  .status-title {
    font-family: var(--font-primary);
    font-size: 2.5rem;
    color: var(--color-white);
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
  }
  .status-message {
    color: var(--color-text-muted);
    font-family: var(--font-secondary);
    line-height: 1.6;
    margin-bottom: 3rem;
  }
  .status-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .btn-primary, .btn-secondary {
    padding: 1rem 2rem;
    text-decoration: none;
    font-family: var(--font-secondary);
    font-size: 0.75rem;
    letter-spacing: 2px;
    font-weight: 700;
    transition: all 0.3s ease;
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-white);
  }
  .btn-secondary {
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-white);
  }
  .btn-primary:hover {
    background: var(--color-white);
    color: var(--color-black);
  }
</style>
