---
// src/pages/obra/[id].astro
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import FramingStudio from '@components/FramingStudio.astro';
import AddToCartButton from '@components/ecommerce/AddToCartButton';
import { getArtworkDetails, getAssetUrl, DirectusManager } from '@conexion/directus';
import { readFolders, readItems } from '@directus/sdk';

const { id } = Astro.params;
const details = await getArtworkDetails(id as string);
const client = await DirectusManager.getClient();

if (!details || !details.mainFile) {
    return Astro.redirect('/404');
}

const { mainFile, meta } = details;

// 1. Obtener Nombre de la Serie (Carpeta) vía SDK
let serieName = "Colección Privada";
try {
    const folders = await client.request(readFolders({ filter: { id: { _eq: mainFile.folder } }, limit: 1 }));
    const folder = folders[0];
    serieName = folder?.name || "Serie";
} catch (e) {
    console.error('[ObraDetail] Error obteniendo serie:', e);
}

const title = mainFile.title || "Obra Javier Mix";
const coverImage = getAssetUrl(mainFile.id) || '';

// 2. Descubrir variante de ambiente (_2) vía SDK
let roomImage = null;
try {
    const rawBase = mainFile.filename_download.split('.')[0].toLowerCase();
    const cleanBase = rawBase.replace(/[\s\-_]/g, '');
    
    const variants = await client.request(readItems('directus_files' as any, {
        filter: { 
            folder: { _eq: mainFile.folder },
            filename_download: { _contains: '_2' }
        }
    }));
    
    const hoverVariant = (variants as any[])?.find((f: any) => {
        const name = f.filename_download.toLowerCase().replace(/[\s\-_]/g, '');
        return name.includes(cleanBase + '2') || name.startsWith(cleanBase + '2');
    });
    
    if (hoverVariant) roomImage = getAssetUrl(hoverVariant.id);
} catch (e) {
    console.error("❌ Error buscando variante _2:", e);
}

// Build sizes array
const sizes = [];
if (meta?.size_small && meta?.precio_small) {
    sizes.push({ label: 'Small', dimensions: meta.size_small, price: meta.precio_small });
}
if (meta?.size_medium && meta?.precio_medium) {
    sizes.push({ label: 'Medium', dimensions: meta.size_medium, price: meta.precio_medium });
}
if (meta?.size_large && meta?.precio_large) {
    sizes.push({ label: 'Large', dimensions: meta.size_large, price: meta.precio_large });
}

const precio = sizes.length > 0 ? sizes[0].price : (meta?.price || 0);
const etiqueta = "Fine Art Print";
---

<Layout title={`${title} | Obra Fine Art`}>
  <Header currentPath="/galeria" />

  <article class="obra-container">
    <div class="split-layout">
      
      <!-- 🖼️ Columna Izquierda: Imagen Interactiva (RESTAURACION PIXEL-PERFECT V1) -->
      <section class="image-column">
        <div class="sticky-image-container">
          <div class="image-wrapper" id="artwork-wrapper">

            <img src={coverImage} alt={`Obra ${title}`} class="main-artwork" id="primary-image" />
            {roomImage && (
              <img src={roomImage} alt={`Vista en Ambiente de ${title}`} class="room-artwork" id="secondary-image" />
            )}
          </div>
          
          <div class="image-controls">
            {roomImage ? (
               <button class="control-btn" id="btn-obra">VER EN SALA</button>
            ) : (
               <button class="control-btn" style="opacity: 0.3; cursor: not-allowed;" disabled>SIN VISTA EN SALA</button>
            )}
            <button class="control-btn" id="btn-framing-config">CONFIGURAR MARCO ARTESANAL</button>
            <button class="control-btn btn-like-glass" id="btn-like-premium" data-id={id}>
                <svg class="heart-icon-glass" viewBox="0 0 24 24">
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
            </button>
          </div>
          
          <div class="share-controls-left">
            <span>COMPARTIR:</span>
            <div class="social-icons">
               <i class="fab fa-whatsapp"></i>
               <i class="fab fa-x-twitter"></i>
               <i class="fab fa-facebook-f"></i>
               <i class="fab fa-instagram"></i>
            </div>
          </div>
        </div>
      </section>

      <!-- 📜 Columna Derecha: Información y Venta (RESTAURACION PIXEL-PERFECT V1) -->
      <section class="info-column">
        <a href="/galeria" class="back-link">← VOLVER AL CATÁLOGO</a>
        
        <div class="serie-label-top">SERIE: {serieName}</div>
        <h1 class="obra-title">{title}</h1>
        
        <!-- Badge Superior de Visualizaciones -->
        <div class="social-feedback-badge">
             <i class="fas fa-eye"></i>
             <span class="social-count" id="social-view-count">0 PERSONAS LES GUSTA ESTO</span>
        </div>

        <div class="tags-container">
          <span class="tag-accent">{etiqueta}</span>
          <span class="tag-outline">CERTIFICADO DE AUTENTICIDAD</span>
          <span class="tag-outline">CALIDAD MUSEO</span>
        </div>
        
        <hr class="divider" />
        
        <!-- Tabs Estilo Fichero (RESTAURACION V1) -->
        <div class="tabs-header">
          <button class="tab-btn active" data-target="historia">HISTORIA</button>
          <button class="tab-btn" data-target="ficha">FICHA TÉCNICA</button>
          <button class="tab-btn" data-target="envios">ENVÍOS</button>
        </div>
        
        <div class="tab-content" id="tab-historia" style="display: block;">
          <div class="prose-content">
            <h4 class="prose-subtitle">LA HISTORIA DETRÁS DE LA IMAGEN</h4>
            {mainFile.description || meta?.description ? (
              <p>{mainFile.description || meta.description}</p>
            ) : (
              <p>Esta pieza de autor es parte de una selección curada rigurosamente. Refleja nuestro compromiso con el legado fotográfico y el diseño contemporáneo a nivel internacional. La edición es estricta y controlada, asegurando el valor de obra única a lo largo del tiempo.</p>
            )}
          </div>
        </div>

        <div class="tab-content" id="tab-ficha" style="display: none;">
          <div class="technical-grid">
            <div class="tech-section">
              <h3 class="tech-category">THE PRINT (CALIDAD MUSEO)</h3>
              <ul class="tech-list">
                <li><i class="fas fa-scroll"></i> {meta?.paper || 'Papel Algodón 100% (Hahnemühle)'}</li>
                <li><i class="fas fa-expand-arrows-alt"></i> Dimensiones: {meta?.dimensions || 'A convenir'}</li>
                <li><i class="fas fa-certificate"></i> Certificado de Autenticidad</li>
                <li><i class="fas fa-infinity"></i> Calidad Fine Art</li>
              </ul>
            </div>
            
            <div class="tech-section">
              <h3 class="tech-category">THE SHOT (DATOS TÉCNICOS)</h3>
              <div class="shot-data-grid">
                <div class="shot-item">
                   <i class="fas fa-camera"></i>
                   <span class="label">CÁMARA</span>
                   <span class="value">{meta?.camera || 'Fine Art'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-circle-notch"></i>
                   <span class="label">LENTE</span>
                   <span class="value">{meta?.lens || 'Prime'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-calendar-alt"></i>
                   <span class="label">FECHA</span>
                   <span class="value">{meta?.date || '2026'}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="tab-content" id="tab-envios" style="display: none;">
          <div class="legal-content">
            <h2 class="legal-title">Logística y Preservación</h2>
            <div class="legal-section">
              <h3>1. Embalaje de Seguridad</h3>
              <p>Cada obra se transporta en tubos de alta resistencia o cajas rígidas diseñadas específicamente para obras de arte, envueltas en papel neutro libre de ácido para garantizar que la emulsión llegue intacta.</p>
            </div>
            <div class="legal-section">
              <h3>2. Cobertura Nacional e Internacional</h3>
              <p>Realizamos envíos a todo el mundo a través de couriers premium (DHL/FedEx). Para Argentina, el envío es coordinado de forma personalizada para asegurar la máxima puntualidad y cuidado.</p>
            </div>
            <div class="legal-section">
              <h3>3. Certificación</h3>
              <p>Junto a la obra se envía el certificado de autenticidad físico firmado y sellado por Javier Mix.</p>
            </div>
          </div>
        </div>
        
        <hr class="divider" />

        <!-- Selector de Tamaño -->
        {sizes.length > 0 && (
          <div class="size-selector-section">
            <span class="size-selector-label">SELECCIONA TAMAÑO:</span>
            <div class="size-options" id="size-options">
              {sizes.map((s: any, i: number) => (
                <button
                  class={`size-option${i === 0 ? ' active' : ''}`}
                  data-price={s.price}
                  data-dimensions={s.dimensions}
                  data-label={s.label}
                >
                  <span class="size-dimensions">{s.dimensions}</span>
                  <span class="size-label-text">{s.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Canvas Material Info -->
        <div class="canvas-info" id="canvas-info">
          <div class="canvas-info-inner">
            <span class="canvas-badge">GRAN FORMATO · EDICIÓN LIMITADA</span>
            <h4 class="canvas-title">Canson Museum Pro Canvas · 385 g/m²</h4>
            <p class="canvas-body">
              El formato Grande se imprime sobre un canvas <strong>100% algodón libre de ácidos</strong>.
            </p>
          </div>
        </div>

        <!-- 🛒 Area de Pago (Fuerza ARS) -->
        <div class="checkout-area">
          <div class="price-box">
              <span class="price-label">PRECIO</span>
              <div class="selected-size-display" id="selected-size-display">
                {sizes.length > 0 ? sizes[0].dimensions : (meta?.dimensions || 'FINE ART PRINT')}
              </div>
              <div class="price-value">
               <span class="currency-symbol">$</span>
               <span class="number" id="price-display">{precio.toLocaleString()}</span>
               <span class="currency-label">ARS</span>
             </div>
          </div>
          
          <div class="action-buttons">
             <div class="v8-cart-wrapper">
                <AddToCartButton 
                    client:load
                    item={{ 
                        id: mainFile.id, 
                        title: title, 
                        price: precio, 
                        image: coverImage,
                        category: serieName 
                    }} 
                />
             </div>
          </div>
        </div>
        
      </section>

    </div>
  </article>

  <FramingStudio imageSrc={coverImage} title={title} />
</Layout>

<script>
  import { currentSelection } from '@store/cartStore';

  document.addEventListener('astro:page-load', () => {
    // --- TABS LOGIC ---
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        tabContents.forEach(c => {
             const content = c as HTMLElement;
             if (content.id === `tab-${targetId}`) {
                content.style.display = 'block';
                content.classList.add('fade-in-content');
             } else {
                content.style.display = 'none';
             }
        });
      });
    });

    // --- FRAMING & 3D STUDIO TRIGGERS (UNIFICADO) ---
    const btnFraming = document.getElementById('btn-framing-config');
    const studio = document.getElementById('framing-studio');

    if (btnFraming && studio) {
      btnFraming.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    }

    // --- ZOOM & PAN LOGIC (PREMIUM V1) ---
    const wrapper = document.getElementById('artwork-wrapper');
    const primaryImg = document.getElementById('primary-image') as HTMLImageElement;

    function handleMove(e: any) {
      if (!wrapper || !primaryImg) return;
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      const { left, top, width, height } = wrapper.getBoundingClientRect();
      const x = (clientX - left) / width;
      const y = (clientY - top) / height;
      const moveX = (x - 0.5) * -80;
      const moveY = (y - 0.5) * -80;
      primaryImg.style.transform = `scale(1.6) translate(${moveX}px, ${moveY}px)`;
    }

    function handleReset() {
      if (!primaryImg) return;
      primaryImg.style.transform = `scale(1) translate(0, 0)`;
    }

    if (wrapper) {
      wrapper.addEventListener('mousemove', handleMove);
      wrapper.addEventListener('mouseleave', handleReset);
      
      // Touch support
      wrapper.addEventListener('touchmove', (e: any) => {
        handleMove(e);
        if (e.cancelable) e.preventDefault();
      }, { passive: false });
      wrapper.addEventListener('touchend', handleReset);
    }

    // --- ORIENTATION DETECTION ---
    function updateOrientation() {
      if (!primaryImg || !wrapper) return;
      const isPortrait = primaryImg.naturalHeight > primaryImg.naturalWidth;
      wrapper.classList.toggle('is-portrait', isPortrait);
      wrapper.classList.toggle('is-landscape', !isPortrait);
    }
    if (primaryImg) {
      if (primaryImg.complete) updateOrientation();
      else primaryImg.addEventListener('load', updateOrientation);
    }

    // --- ROOM VIEW HOVER ---
    const btnObra = document.getElementById('btn-obra');
    const imgSec = document.getElementById('secondary-image');
    if(btnObra && primaryImg && imgSec) {
        btnObra.addEventListener('mouseenter', () => { primaryImg.style.opacity = '0'; (imgSec as HTMLElement).style.opacity = '1'; });
        btnObra.addEventListener('mouseleave', () => { primaryImg.style.opacity = '1'; (imgSec as HTMLElement).style.opacity = '0'; });
    }

    // --- LIKE BUTTON LOGIC (FERRARI & GOLD) ---
    const btnLike = document.getElementById('btn-like-premium');
    const viewCountEl = document.getElementById('social-view-count');

    btnLike?.addEventListener('click', async () => {
        const artworkId = btnLike.getAttribute('data-id');
        btnLike.classList.add('animating');
        
        try {
            const res = await fetch('/api/like', {
                method: 'POST',
                body: JSON.stringify({ artworkId })
            });
            const data = await res.json();
            if (res.ok) {
                btnLike.classList.add('liked');
                if (viewCountEl) {
                    const current = parseInt(viewCountEl.textContent?.match(/\d+/)?.join('') || '0');
                    viewCountEl.textContent = `${current + 1} PERSONAS LES GUSTA ESTO`;
                }
            }
        } catch (e) {
            console.error("Error liking:", e);
        } finally {
            setTimeout(() => btnLike.classList.remove('animating'), 500);
        }
    });

    // --- SIZE SELECTOR ---
    const sizeOptions = document.querySelectorAll('.size-option');
    const priceDisplay = document.getElementById('price-display');
    const canvasInfo = document.getElementById('canvas-info');

    sizeOptions.forEach((btn: any) => {
      btn.addEventListener('click', () => {
        sizeOptions.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const price = btn.getAttribute('data-price');
        const label = btn.getAttribute('data-label');
        const dimensions = btn.getAttribute('data-dimensions');
        if (priceDisplay) priceDisplay.textContent = parseInt(price).toLocaleString();
        const sizeDisplay = document.getElementById('selected-size-display');
        if (sizeDisplay && dimensions) {
          sizeDisplay.textContent = dimensions;
        }
        if (canvasInfo) label === 'Large' ? canvasInfo.classList.add('visible') : canvasInfo.classList.remove('visible');
        currentSelection.set({ price: parseInt(price), label, dimensions });
      });
    });
  });
</script>

<style>
/* 🏺 RESTAURACIÓN PREMIUM JMX - ASTRO 6 🏺 */
:root {
  --color-accent: #dcb14a;
  --color-onyx-deep: #050505;
  --color-onyx-charcoal: #0d0d0d;
  --color-travertine-light: #d9cfcc;
  --color-travertine-muted: #a69c94;
  --color-white: #ffffff;
  --color-text-muted: #595351;
  --font-primary: 'Cormorant Garamond', serif;
  --font-secondary: 'Montserrat', sans-serif;
}

.obra-container {
  max-width: 100%;
  margin: 0 auto;
  color: var(--color-travertine-light);
  min-height: 100vh;
  background: var(--color-onyx-deep);
}

.split-layout { display: flex; width: 100%; position: relative; }

/* 🖼️ Columna Izquierda Fija */
.image-column {
  width: 50vw;
  height: 100vh;
  background: var(--color-onyx-charcoal);
  position: sticky;
  top: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0; 
  border-right: 1px solid rgba(255,255,255,0.05);
}

.sticky-image-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.image-wrapper {
  position: relative;
  width: 95%; /* MÁXIMA ANCHURA HORIZONTAL */
  aspect-ratio: 1 / 1; /* CONTENEDOR CUADRADO */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  cursor: zoom-in;
  background: rgba(0,0,0,0.2); /* Sutil fondo para el área de la obra */
  flex-shrink: 0;
}

/* 🚀 REGLA UNIVERSAL DE ESCALADO MÁXIMO */
.main-artwork, .room-artwork {
  position: absolute;
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 20px 60px rgba(0,0,0,0.8));
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), opacity 0.6s ease;
  will-change: transform, opacity;
}

.room-artwork { opacity: 0; z-index: 2; }

.image-controls {
    position: absolute;
    bottom: 12vh;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 1.2rem;
    z-index: 100;
    width: fit-content;
}

.control-btn {
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--color-white);
    padding: 1.2rem 2.2rem; /* Más grandes */
    font-size: 0.75rem; /* Más legibles */
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    flex-shrink: 0;
    white-space: nowrap;
}

.btn-like-glass {
    width: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: transparent;
    border: none;
    backdrop-filter: none;
    margin-left: 1rem;
    flex-shrink: 0;
}

.heart-icon-glass {
    width: 32px; /* Más grande como pediste */
    height: 32px;
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.5;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    filter: drop-shadow(0 0 5px rgba(220, 177, 74, 0.3));
}

.btn-like-glass:hover .heart-icon-glass {
    transform: scale(1.2);
    filter: drop-shadow(0 0 12px var(--color-accent));
}

.btn-like-glass.liked .heart-icon-glass {
    fill: var(--color-accent);
    stroke: var(--color-accent);
    filter: drop-shadow(0 0 15px var(--color-accent));
}

.control-btn:hover {
    border-color: var(--color-accent);
    background: rgba(220, 177, 74, 0.15);
    transform: translateY(-3px);
}

.share-controls-left {
    position: absolute;
    bottom: 3vh; /* Más abajo para despejar */
    left: 4%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.6rem;
    color: var(--color-text-muted);
    letter-spacing: 2px;
    z-index: 100;
}

.social-icons { display: flex; gap: 1.5rem; }
.social-icons i { cursor: pointer; transition: color 0.3s; font-size: 0.9rem; }
.social-icons i:hover { color: var(--color-accent); }

/* 📜 Columna Derecha Scroll */
.info-column {
  width: 50vw;
  padding: 180px 8% 10rem;
  background: var(--color-onyx-deep); 
}

.back-link {
  font-size: 0.65rem;
  letter-spacing: 2px;
  color: var(--color-accent);
  text-decoration: none;
  display: block;
  margin-bottom: 3rem;
  text-transform: uppercase;
  font-weight: 600;
}

.serie-label-top {
  font-size: 0.6rem;
  letter-spacing: 4px;
  color: var(--color-travertine-muted);
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}

.obra-title {
  font-family: var(--font-primary);
  font-size: 4rem;
  color: var(--color-white);
  margin-bottom: 2rem;
  line-height: 1;
  font-weight: 300;
}

.social-feedback-badge {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: rgba(255,255,255,0.03);
    padding: 0.6rem 1rem;
    width: fit-content;
    border-radius: 4px;
    margin-bottom: 3rem;
}

.social-count { font-size: 0.55rem; letter-spacing: 2px; color: var(--color-text-muted); }

.tags-container { display: flex; gap: 1rem; margin-bottom: 4rem; }
.tag-accent { font-size: 0.6rem; letter-spacing: 2px; border: 1px solid var(--color-accent); color: var(--color-accent); padding: 0.5rem 1rem; }
.tag-outline { font-size: 0.6rem; letter-spacing: 2px; border: 1px solid rgba(255,255,255,0.1); color: var(--color-text-muted); padding: 0.5rem 1rem; }

.divider { border: none; height: 1px; background: rgba(255,255,255,0.05); margin: 4rem 0; }

/* TABS FICHERO */
.tabs-header { display: flex; border-bottom: 1px solid var(--color-accent); margin-bottom: 4rem; }
.tab-btn {
  background: transparent;
  border: none;
  padding: 1rem 2rem;
  color: var(--color-text-muted);
  font-size: 0.65rem;
  letter-spacing: 2px;
  cursor: pointer;
  transition: all 0.4s;
  border-radius: 8px 8px 0 0;
}
.tab-btn.active { background: var(--color-accent); color: #000; font-weight: 700; }

.prose-subtitle { font-family: var(--font-primary); color: var(--color-accent); font-style: italic; margin-bottom: 2rem; letter-spacing: 4px; }
.prose-content { font-size: 1.1rem; line-height: 2; color: var(--color-travertine-muted); }
.prose-content :global(p):first-of-type::first-letter {
    float: left;
    font-size: 5rem;
    line-height: 0.7;
    padding: 0.5rem 1rem 0 0;
    color: var(--color-accent);
    font-family: var(--font-primary);
    font-weight: 600;
