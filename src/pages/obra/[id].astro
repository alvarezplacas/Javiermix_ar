---
// src/pages/obra/[id].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getArtworkDetails, fetchFromDirectus, getAssetUrl } from '../../conexion/directus';
import FramingStudio from '../../components/FramingStudio.astro';
import AddToCartButton from '../../components/ecommerce/AddToCartButton.tsx';

// 🚀 Motor V8: SSR (No more 404s)
export const prerender = false;

const { id } = Astro.params;
const details = await getArtworkDetails(id as string);

if (!details || !details.mainFile) {
    return Astro.redirect('/404');
}

const { mainFile, meta } = details;

// Get Serie Name from folder
let serieName = "Colección Privada";
try {
    const folderRes = await fetchFromDirectus(`/folders/${mainFile.folder}`);
    const folderData = await folderRes.json();
    serieName = folderData.data?.name || "Serie";
} catch (e) {}

const title = mainFile.title || "Obra Javier Mix";
const coverImage = getAssetUrl(mainFile.id) || '';

// Discover variant hover if exists
let roomImage = null;
try {
    const baseName = mainFile.filename_download.split('.')[0].toLowerCase();
    const variantsRes = await fetchFromDirectus(`/files?filter[folder][_eq]=${mainFile.folder}&filter[filename_download][_contains]=_2.`);
    const variantsData = await variantsRes.json();
    const hoverVariant = variantsData.data?.find((f: any) => f.filename_download.toLowerCase().startsWith(`${baseName}_2.`));
    if (hoverVariant) roomImage = getAssetUrl(hoverVariant.id);
} catch (e) {}

// Build sizes array
const sizes = [];
if (meta?.size_small && meta?.precio_small) {
    sizes.push({ label: 'Small', dimensions: meta.size_small, price: meta.precio_small });
}
if (meta?.size_medium && meta?.precio_medium) {
    sizes.push({ label: 'Medium', dimensions: meta.size_medium, price: meta.precio_medium });
}
if (meta?.size_large && meta?.precio_large) {
    sizes.push({ label: 'Large', dimensions: meta.size_large, price: meta.precio_large });
}

const precio = sizes.length > 0 ? sizes[0].price : (meta?.price || 0);
const etiqueta = "Fine Art Print";
---

<Layout title={`${title} | Obra Fine Art`}>
  <Header currentPath="/galeria" />

  <article class="obra-container">
    <div class="split-layout">
      
      <!-- 🖼️ Columna Izquierda: Imagen Interactiva (RESTAURACION PIXEL-PERFECT V1) -->
      <section class="image-column">
        <div class="sticky-image-container">
          <div class="image-wrapper">
            <!-- Badge de Favoritos Superior Izquierda (Captura v1) -->
            <div class="likes-badge-float">
                <i class="fas fa-heart"></i>
                <span id="like-count-float">0</span>
            </div>

            <img src={coverImage} alt={`Obra ${title}`} class="main-artwork" id="primary-image" />
            {roomImage && (
              <img src={roomImage} alt={`Vista en Ambiente de ${title}`} class="room-artwork" id="secondary-image" />
            )}
          </div>
          
          <div class="image-controls">
            {roomImage ? (
               <button class="control-btn active" id="btn-obra">VER EN SALA</button>
            ) : (
               <button class="control-btn" style="opacity: 0.3; cursor: not-allowed;" disabled>SIN VISTA EN SALA</button>
            )}
            <button class="control-btn" id="btn-3d">VER EN 3D</button>
            <button class="control-btn" id="btn-marco">PROBAR MARCO</button>
          </div>
          
          <div class="share-controls">
            <span>COMPARTIR:</span>
            <div class="social-icons">
               <i class="fab fa-whatsapp"></i>
               <i class="fab fa-x-twitter"></i>
               <i class="fab fa-facebook-f"></i>
               <i class="fab fa-instagram"></i>
            </div>
          </div>
        </div>
      </section>

      <!-- 📜 Columna Derecha: Información y Venta (RESTAURACION PIXEL-PERFECT V1) -->
      <section class="info-column">
        <a href={`/galeria/${mainFile.folder}`} class="back-link">← VOLVER A {serieName}</a>
        
        <div class="serie-label">SERIE: {serieName}</div>
        <h1 class="obra-title">{title}</h1>
        
        <!-- Badge Superior de Likes (Captura v1) -->
        <div class="social-feedback-badge">
             <i class="fas fa-eye"></i>
             <span class="social-count" id="social-view-count">0 PERSONAS LES GUSTA ESTO</span>
        </div>

        <div class="tags-container">
          {etiqueta && <span class="tag-accent">{etiqueta}</span>}
          <span class="tag-outline">CERTIFICADO DE AUTENTICIDAD</span>
          <span class="tag-outline">CALIDAD MUSEO</span>
        </div>
        
        <hr class="divider" />
        
        <!-- Tabs Estilo Fichero (RESTAURACION V1) -->
        <div class="tabs-header">
          <button class="tab-btn active" data-target="historia">HISTORIA</button>
          <button class="tab-btn" data-target="ficha">FICHA TÉCNICA</button>
          <button class="tab-btn" data-target="terminos">TÉRMINOS</button>
        </div>
        
        <div class="tab-content fade-in-content" id="tab-historia" style="display: block;">
          <div class="prose-content">
            <h4 class="prose-subtitle">LA HISTORIA DETRÁS DE LA IMAGEN</h4>
            {meta?.description ? (
              <p>{meta.description}</p>
            ) : (
              <p>Esta pieza de autor es parte de una selección curada rigurosamente. Refleja nuestro compromiso con el legado fotográfico y el diseño contemporáneo a nivel internacional.</p>
            )}
            <p>La edición es estricta y controlada, asegurando el valor de obra única a lo largo del tiempo.</p>
          </div>
        </div>

        <div class="tab-content" id="tab-ficha" style="display: none;">
          <div class="technical-grid">
            <div class="tech-section">
              <h3 class="tech-category">THE PRINT (CALIDAD MUSEO)</h3>
              <ul class="tech-list">
                <li><i class="fas fa-scroll"></i> {meta?.paper || 'Papel Algodón 100%'}</li>
                <li><i class="fas fa-expand-arrows-alt"></i> Dimensiones: {meta?.dimensions || 'A convenir'}</li>
                <li><i class="fas fa-certificate"></i> Certificado de Autenticidad</li>
                <li><i class="fas fa-infinity"></i> Calidad Fine Art</li>
              </ul>
            </div>
            
            <div class="tech-section">
              <h3 class="tech-category">THE SHOT (DATOS TÉCNICOS)</h3>
              <div class="shot-data-grid">
                <div class="shot-item">
                   <i class="fas fa-camera"></i>
                   <span class="label">CÁMARA</span>
                   <span class="value">{meta?.camera || 'Fine Art'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-circle-notch"></i>
                   <span class="label">LENTE</span>
                   <span class="value">{meta?.lens || 'Prime'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-calendar-alt"></i>
                   <span class="label">FECHA</span>
                   <span class="value">{meta?.date || '2024'}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="tab-content" id="tab-terminos" style="display: none;">
          <div class="legal-content">
            <h2 class="legal-title">Términos y Condiciones de Venta</h2>
            <div class="legal-section">
              <h3>1. Naturaleza del Producto</h3>
              <p>Cada fotografía es una impresión de alta calidad (Fine Art) realizada bajo estándares profesionales para garantizar su longevidad y fidelidad cromática. El valor expresado corresponde exclusivamente a la pieza impresa.</p>
            </div>
            <div class="legal-section">
              <h3>2. Enmarcado y Envío</h3>
              <p>La obra se entrega como una lámina impresa lista para ser enmarcada a gusto del comprador. El costo de envío se coordina de forma privada tras la compra.</p>
            </div>
          </div>
        </div>
        
        <hr class="divider" />

        <!-- Selector de Tamaño -->
        {sizes.length > 0 && (
          <div class="size-selector-section">
            <span class="size-selector-label">SELECCIONA TAMAÑO:</span>
            <div class="size-options" id="size-options">
              {sizes.map((s: any, i: number) => (
                <button
                  class={`size-option${i === 0 ? ' active' : ''}`}
                  data-price={s.price}
                  data-dimensions={s.dimensions}
                  data-label={s.label}
                >
                  <span class="size-dimensions">{s.dimensions}</span>
                  <span class="size-label-text">{s.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Canvas Material Info (Transition V1) -->
        <div class="canvas-info" id="canvas-info" aria-live="polite">
          <div class="canvas-info-inner">
            <span class="canvas-badge">GRAN FORMATO · EDICIÓN LIMITADA</span>
            <h4 class="canvas-title">Canson Museum Pro Canvas · 385 g/m²</h4>
            <p class="canvas-body">
              El formato Grande se imprime sobre un canvas <strong>100% algodón libre de ácidos</strong>, pensado para durar décadas.
            </p>
          </div>
        </div>
        
        <!-- 🛒 Area de Pago (RESTAURACION ESTRUCTURA LIGERA V1) -->
        <div class="checkout-area">
          <div class="price-box">
             <span class="price-label">PRECIO</span>
             <div class="price-value">
               <span class="currency-symbol">$</span>
               <span class="number" id="price-display">{precio}</span>
               <span class="currency-label">ARS</span>
             </div>
          </div>
          
          <div class="action-buttons">
             <div class="v8-cart-wrapper">
                <AddToCartButton 
                    client:load
                    item={{ 
                        id: mainFile.id, 
                        title: title, 
                        price: precio, 
                        image: coverImage,
                        category: serieName 
                    }} 
                />
             </div>
          </div>
        </div>
        
      </section>

    </div>
  </article>

  <FramingStudio imageSrc={coverImage} title={title} />
</Layout>

<script>
  import { currentSelection } from '../../store/cartStore';

  document.addEventListener('astro:page-load', () => {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        tabContents.forEach(c => {
             const content = c as HTMLElement;
             if (content.id === `tab-${targetId}`) {
                content.style.display = 'block';
                content.classList.add('fade-in-content');
             } else {
                content.style.display = 'none';
             }
        });
      });
    });

    const btnObra = document.getElementById('btn-obra');
    const imgPrim = document.getElementById('primary-image');
    const imgSec = document.getElementById('secondary-image');
    if(btnObra && imgPrim && imgSec) {
        btnObra.addEventListener('mouseenter', () => { imgPrim.style.opacity = '0'; imgSec.style.opacity = '1'; });
        btnObra.addEventListener('mouseleave', () => { imgPrim.style.opacity = '1'; imgSec.style.opacity = '0'; });
    }

    const btnMarco = document.getElementById('btn-marco');
    const studio = document.getElementById('framing-studio');
    if (btnMarco && studio) {
      btnMarco.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    }

    const sizeOptions = document.querySelectorAll('.size-option');
    const priceDisplay = document.getElementById('price-display');
    const canvasInfo = document.getElementById('canvas-info');

    sizeOptions.forEach((btn: any) => {
      btn.addEventListener('click', () => {
        sizeOptions.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const price = btn.getAttribute('data-price');
        const label = btn.getAttribute('data-label');
        if (priceDisplay) priceDisplay.textContent = price;
        if (canvasInfo) label === 'Large' ? canvasInfo.classList.add('visible') : canvasInfo.classList.remove('visible');
        currentSelection.set({ price: parseInt(price), label, dimensions: btn.getAttribute('data-dimensions') });
      });
    });
    if (sizeOptions[0]) (sizeOptions[0] as HTMLElement).click();
  });
</script>

<style>
/* 🏺 DISEÑO PIXEL-PERFECT JMX (RESTAURACION ABSOLUTA) 🏺 */
.obra-container {
  max-width: 100%;
  margin: 0 auto;
  color: var(--color-travertine-light);
  min-height: 100vh;
}

.split-layout { display: block; width: 100%; position: relative; }

.image-column {
  position: fixed;
  left: 0;
  top: 0;
  width: 50vw;
  height: 100dvh;
  background: #0d0d0d;
  padding: 0 5%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-right: 1px solid rgba(255,255,255,0.03);
  z-index: 5;
}

.info-column {
  margin-left: 50vw;
  width: 50vw;
  padding: 160px 8% 10rem;
  background: #050505; 
  min-height: 100dvh;
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: calc(100dvh - 350px);
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.likes-badge-float {
    position: absolute;
    top: 20px;
    left: 20px;
    background: rgba(191, 21, 52, 0.4);
    padding: 1rem 1.8rem;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    backdrop-filter: blur(10px);
    z-index: 10;
    font-size: 1rem;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
}

.main-artwork, .room-artwork {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 20px 60px rgba(0,0,0,0.6));
  transition: opacity 0.8s ease;
}

.room-artwork { position: absolute; top: 0; left: 0; opacity: 0; }

.obra-title {
  font-family: var(--font-primary);
  font-size: 3.5rem; /* Píxel-Perfect v1 */
  font-weight: 300;
  margin-bottom: 1.5rem;
  line-height: 1.1;
  color: var(--color-travertine-light);
  letter-spacing: -1px;
}

.social-feedback-badge {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: rgba(255,255,255,0.03);
    padding: 0.8rem 1.2rem;
    width: fit-content;
    border-radius: 50px;
    margin-bottom: 2rem;
    border: 1px solid rgba(255,255,255,0.05);
}

.social-count {
    font-size: 0.55rem;
    letter-spacing: 2px;
    color: var(--color-text-muted);
}

/* 🏺 TABS ESTILO FICHERO (SOLAPA V1) */
.tabs-header {
  display: flex;
  margin-bottom: 4rem;
  border-bottom: 1px solid var(--color-accent);
  padding-left: 0.5rem;
}

.tab-btn {
  background: transparent;
  border: 1px solid transparent;
  color: var(--color-text-muted);
  font-family: var(--font-secondary);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  padding: 1rem 2.5rem;
  cursor: pointer;
  border-radius: 8px 8px 0 0;
  margin-bottom: -1px;
  transition: all 0.4s ease;
}

.tab-btn.active {
  color: var(--color-accent);
  background: var(--color-onyx-deep);
  border: 1px solid var(--color-accent);
  border-bottom: 2px solid var(--color-onyx-deep);
  z-index: 2;
}

/* 🏺 HISTORIA CON LETRA CAPITAL */
.prose-subtitle {
    font-family: var(--font-primary);
    color: var(--color-accent);
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 3px;
    margin-bottom: 3rem;
    text-align: center;
    font-weight: 400;
}

.prose-content {
  font-size: 1.1rem;
  line-height: 2;
  color: var(--color-text-muted);
}

.prose-content :global(p):first-of-type::first-letter {
  float: left;
  font-size: 4.8rem;
  line-height: 0.8;
  padding-right: 1rem;
  padding-top: 0.6rem;
  color: var(--color-accent);
  font-family: var(--font-primary);
  font-weight: 600;
}

/* 🏺 FICHA TECNICA ICONOGRAFICA */
.tech-category {
    font-size: 0.65rem;
    letter-spacing: 3px;
    color: var(--color-text-muted);
    margin: 3rem 0 1.5rem;
}

.tech-list { list-style: none; padding: 0; }
.tech-list li { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; font-size: 0.95rem; }
.tech-list i { color: var(--color-accent); font-size: 1rem; width: 25px; text-align: center; }

.shot-data-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
.shot-item { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
.shot-item i { color: var(--color-accent); font-size: 0.9rem; opacity: 0.6; }
.shot-item .label { font-size: 0.5rem; letter-spacing: 2px; color: rgba(255,255,255,0.3); }
.shot-item .value { font-size: 0.75rem; color: var(--color-travertine-muted); }

/* 🛒 CHECKOUT LIGERO (GRAN FORMATO) */
.checkout-area {
  display: flex;
  align-items: center;
  gap: 5rem;
  margin-top: 5rem;
}

.price-label { font-size: 0.6rem; letter-spacing: 3px; color: var(--color-text-muted); margin-bottom: 1rem; display: block; }
.price-value { display: flex; align-items: baseline; gap: 0.8rem; }
.price-value .currency-symbol { font-size: 1.8rem; color: var(--color-accent); font-weight: 200; }
.price-value .number { font-size: 4.5rem; font-weight: 200; line-height: 1; color: var(--color-travertine-light); }
.price-value .currency-label { font-size: 0.9rem; color: var(--color-text-muted); letter-spacing: 2px; }

.v8-cart-wrapper :global(.btn-buy) {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 1.8rem 4rem;
    font-size: 0.75rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    font-weight: 600;
    transition: all 0.6s ease;
    cursor: pointer;
}

.v8-cart-wrapper :global(.btn-buy:hover) {
    background: var(--color-accent);
    color: #000;
}

.fade-in-content { animation: fadeIn 0.8s ease forwards; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

@media (max-width: 1024px) {
  .info-column { margin-left: 0; width: 100%; padding: 4rem 5%; }
  .image-column { position: relative; width: 100%; height: 60dvh; }
  .checkout-area { flex-direction: column; gap: 2rem; align-items: flex-start; }
}
</style>
