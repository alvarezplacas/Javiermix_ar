---
// src/pages/obra/[id].astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getArtworkDetails, fetchFromDirectus, getAssetUrl } from '../../conexion/directus';
import FramingStudio from '../../components/FramingStudio.astro';
import AddToCartButton from '../../components/ecommerce/AddToCartButton.tsx';

// 🚀 Motor V8: SSR (No more 404s)
export const prerender = false;

const { id } = Astro.params;
const details = await getArtworkDetails(id as string);

if (!details || !details.mainFile) {
    return Astro.redirect('/404');
}

const { mainFile, meta } = details;

// Get Serie Name from folder
let serieName = "Colección Privada";
try {
    const folderRes = await fetchFromDirectus(`/folders/${mainFile.folder}`);
    const folderData = await folderRes.json();
    serieName = folderData.data?.name || "Serie";
} catch (e) {}

const title = mainFile.title || "Obra Javier Mix";
const coverImage = getAssetUrl(mainFile.id) || '';

// Discover variant hover if exists (look for filename_2)
let roomImage = null;
try {
    const baseName = mainFile.filename_download.split('.')[0].toLowerCase();
    const variantsRes = await fetchFromDirectus(`/files?filter[folder][_eq]=${mainFile.folder}&filter[filename_download][_contains]=_2.`);
    const variantsData = await variantsRes.json();
    const hoverVariant = variantsData.data?.find((f: any) => f.filename_download.toLowerCase().startsWith(`${baseName}_2.`));
    if (hoverVariant) roomImage = getAssetUrl(hoverVariant.id);
} catch (e) {}

// Build sizes array from Directus metadata
const sizes = [];
if (meta?.size_small && meta?.precio_small) {
    sizes.push({ label: 'Small', dimensions: meta.size_small, price: meta.precio_small });
}
if (meta?.size_medium && meta?.precio_medium) {
    sizes.push({ label: 'Medium', dimensions: meta.size_medium, price: meta.precio_medium });
}
if (meta?.size_large && meta?.precio_large) {
    sizes.push({ label: 'Large', dimensions: meta.size_large, price: meta.precio_large });
}

// Fallback price
const precio = sizes.length > 0 ? sizes[0].price : (meta?.price || 0);
const etiqueta = "Fine Art Print";
---

<Layout title={`${title} | Obra Fine Art`}>
  <Header currentPath="/galeria" />

  <article class="obra-container">
    <div class="split-layout">
      
      <!-- 🖼️ Columna Izquierda: Imagen Interactiva (Fija 50%) -->
      <section class="image-column">
        <div class="sticky-image-container">
          <div class="image-wrapper">
            <img src={coverImage} alt={`Obra ${title}`} class="main-artwork" id="primary-image" />
            {roomImage && (
              <img src={roomImage} alt={`Vista en Ambiente de ${title}`} class="room-artwork" id="secondary-image" />
            )}
          </div>
          
          <div class="image-controls">
            {roomImage ? (
               <button class="control-btn active" id="btn-obra">VER EN SALA</button>
            ) : (
               <button class="control-btn" style="opacity: 0.3; cursor: not-allowed;" disabled>SIN VISTA EN SALA</button>
            )}
            <button class="control-btn" id="btn-3d">VER EN 3D</button>
            <button class="control-btn" id="btn-marco">PROBAR MARCO</button>
          </div>
          
          <div class="share-controls">
            <span>COMPARTIR:</span>
            <div class="social-icons">
               <i class="fab fa-whatsapp"></i>
               <i class="fab fa-x-twitter"></i>
               <i class="fab fa-facebook-f"></i>
               <i class="fab fa-instagram"></i>
            </div>
          </div>
        </div>
      </section>

      <!-- 📜 Columna Derecha: Información y Venta (Scrolling 50%) -->
      <section class="info-column">
        <a href={`/galeria/${mainFile.folder}`} class="back-link">← VOLVER A {serieName}</a>
        
        <div class="serie-label">SERIE: {serieName}</div>
        <h1 class="obra-title">{title}</h1>
        
        <div class="tags-container">
          {etiqueta && <span class="tag-accent">{etiqueta}</span>}
          <span class="tag-outline">CERTIFICADO DE AUTENTICIDAD</span>
          <span class="tag-outline">CALIDAD MUSEO</span>
        </div>
        
        <hr class="divider" />
        
        <!-- Tabs de información Estilo Fichero -->
        <div class="tabs-header">
          <button class="tab-btn active" data-target="historia">HISTORIA</button>
          <button class="tab-btn" data-target="ficha">FICHA TÉCNICA</button>
          <button class="tab-btn" data-target="terminos">TÉRMINOS</button>
        </div>
        
        <div class="tab-content" id="tab-historia" style="display: block;">
          <div class="prose-content">
            <h2 class="prose-title">La Historia detrás de la Imagen</h2>
            {meta?.description ? (
              <p>{meta.description}</p>
            ) : (
              <p>Esta pieza de autor es parte de una selección curada rigurosamente. Refleja nuestro compromiso con el legado fotográfico y el diseño contemporáneo, donde cada textura, sombra y captura de luz está cuidada bajo los más altos estándares Fine Art.</p>
            )}
            <p>La edición es estricta y controlada, asegurando el valor de obra única a lo largo del tiempo.</p>
          </div>
        </div>

        <div class="tab-content" id="tab-ficha" style="display: none;">
          <div class="technical-grid">
            <div class="tech-section">
              <h3 class="tech-category">THE PRINT (CALIDAD MUSEO)</h3>
              <ul class="tech-list">
                <li><i class="fas fa-scroll"></i> {meta?.paper || 'Papel Algodón 100% (Hahnemühle)'}</li>
                <li><i class="fas fa-expand-arrows-alt"></i> Dimensiones: {meta?.dimensions || 'A convenir'}</li>
                <li><i class="fas fa-certificate"></i> Certificado de Autenticidad</li>
                <li><i class="fas fa-infinity"></i> Pigmentos Minerales (+100 Años)</li>
              </ul>
            </div>
            
            <div class="tech-section">
              <h3 class="tech-category">THE SHOT (DATOS TÉCNICOS)</h3>
              <div class="shot-data-grid">
                <div class="shot-item">
                   <i class="fas fa-camera"></i>
                   <span class="label">CÁMARA</span>
                   <span class="value">{meta?.camera || 'Nikon Fine Art'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-circle-notch"></i>
                   <span class="label">LENTE</span>
                   <span class="value">{meta?.lens || 'Finesse Optics'}</span>
                </div>
                <div class="shot-item">
                   <i class="fas fa-calendar-alt"></i>
                   <span class="label">FECHA</span>
                   <span class="value">{meta?.date || '2024'}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="tab-content" id="tab-terminos" style="display: none;">
          <div class="legal-content">
            <h2 class="legal-title">Términos y Condiciones de Venta | Javier Mix Fine Art</h2>
            <p>Al adquirir una obra de la serie <strong>"{serieName}"</strong> o cualquier pieza del catálogo de <strong>javiermix.ar</strong>, el comprador acepta los siguientes términos:</p>
            
            <div class="legal-section">
              <h3>1. Naturaleza del Producto</h3>
              <p>Cada fotografía es una impresión de alta calidad (Fine Art) realizada bajo estándares profesionales para garantizar su longevidad y fidelidad cromática. El valor expresado en el catálogo corresponde exclusivamente a la pieza impresa en el formato seleccionado (Estándar, Mediano o Grande).</p>
            </div>
            
            <div class="legal-section">
              <h3>2. Exclusiones Importantes</h3>
              <p><strong>Enmarcado:</strong> El precio de venta no incluye marco, paspartú, ni ningún tipo de montaje o estructura de exhibición por el momento. La obra se entrega como una lámina impresa lista para ser enmarcada a gusto del comprador.</p>
              <p><strong>Envío:</strong> El costo de envío no está incluido en el valor de la obra. Los gastos de logística, embalaje especial para obras de arte y transporte correrán por cuenta del comprador y serán coordinados de forma privada tras la compra.</p>
            </div>
            
            <div class="legal-section">
              <h3>3. Autenticidad y Derechos</h3>
              <p>Todas las obras se entregan firmadas por el autor bajo el nombre artístico <strong>Javier Mix</strong>. La compra de la impresión física no transfiere derechos de reproducción comercial sobre la imagen, los cuales permanecen como propiedad intelectual del autor.</p>
            </div>
          </div>
        </div>
        
        <hr class="divider" />

        <!-- Selector de Tamaño -->
        {sizes.length > 0 && (
          <div class="size-selector-section">
            <span class="size-selector-label">SELECCIONA TAMAÑO:</span>
            <div class="size-options" id="size-options">
              {sizes.map((s: any, i: number) => (
                <button
                  class={`size-option${i === 0 ? ' active' : ''}`}
                  data-price={s.price}
                  data-dimensions={s.dimensions}
                  data-label={s.label}
                >
                  <span class="size-dimensions">{s.dimensions}</span>
                  <span class="size-label-text">{s.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Canvas Material Info -->
        <div class="canvas-info" id="canvas-info" aria-live="polite">
          <div class="canvas-info-inner">
            <span class="canvas-badge">GRAN FORMATO · EDICIÓN LIMITADA</span>
            <h4 class="canvas-title">Canson Museum Pro Canvas · 385 g/m²</h4>
            <p class="canvas-body">
              El formato Grande se imprime sobre un canvas <strong>100% algodón libre de ácidos</strong>, pensado para durar décadas sin perder ni un tono.
            </p>
          </div>
        </div>
        
        <!-- Checkout Area -->
        <div class="checkout-area">
          <div class="price-box">
             <span class="price-label">INVERSIÓN</span>
             <div class="price-value-container">
               <span class="currency">ARS</span>
               <span class="number" id="price-display">{precio > 0 ? precio : '—'}</span>
             </div>
             {precio === 0 && <p class="price-notice">Obra exclusiva · Consultar disponibilidad</p>}
          </div>
          
          <div class="action-buttons">
             <AddToCartButton 
                client:load
                item={{ 
                    id: mainFile.id, 
                    title: title, 
                    price: precio, 
                    image: coverImage,
                    category: serieName 
                }} 
             />
             
             <div class="secondary-actions">
                <button class="btn-favorite" id="btn-like" aria-label="Añadir a favoritos" data-filename={mainFile.filename_download} data-serie={mainFile.folder} data-title={title}>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="heart-icon"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                  <span id="like-count" class="like-number">0</span>
                </button>
                <button class="btn-collection">
                   AGREGAR A MINI COLECCIÓN
                </button>
             </div>
          </div>
        </div>
        
      </section>

    </div>
  </article>

  <FramingStudio imageSrc={coverImage} title={title} />
</Layout>

<script>
  import { currentSelection } from '../../store/cartStore';

  document.addEventListener('astro:page-load', () => {
    // Tabs Logic
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        tabContents.forEach(c => {
             const content = c as HTMLElement;
             content.style.display = content.id === `tab-${targetId}` ? 'block' : 'none';
        });
      });
    });

    // Room view hover simulate
    const btnObra = document.getElementById('btn-obra');
    const imgPrim = document.getElementById('primary-image');
    const imgSec = document.getElementById('secondary-image');
    
    if(btnObra && imgPrim && imgSec) {
        btnObra.addEventListener('mouseenter', () => {
             imgPrim.style.opacity = '0';
             imgSec.style.opacity = '1';
        });
        btnObra.addEventListener('mouseleave', () => {
             imgPrim.style.opacity = '1';
             imgSec.style.opacity = '0';
        });
    }

    // Framing Studio Trigger
    const btnMarco = document.getElementById('btn-marco');
    const studio = document.getElementById('framing-studio');
    if (btnMarco && studio) {
      btnMarco.addEventListener('click', () => {
        studio.style.display = 'block';
        document.body.style.overflow = 'hidden';
      });
    }

    // Size Selector Logic & Sync
    const sizeOptions = document.querySelectorAll('.size-option');
    const priceDisplay = document.getElementById('price-display');
    const canvasInfo = document.getElementById('canvas-info');

    sizeOptions.forEach((btn: any) => {
      btn.addEventListener('click', () => {
        sizeOptions.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const price = btn.getAttribute('data-price');
        const dimensions = btn.getAttribute('data-dimensions');
        const label = btn.getAttribute('data-label');

        if (priceDisplay) priceDisplay.textContent = price;
        if (canvasInfo) label === 'Large' ? canvasInfo.classList.add('visible') : canvasInfo.classList.remove('visible');

        // 🔥 Sync with Cart Shop
        currentSelection.set({ 
            price: parseInt(price), 
            label: label, 
            dimensions: dimensions 
        });
      });
    });

    // Set first as default
    if (sizeOptions[0]) (sizeOptions[0] as HTMLElement).click();
  });
</script>

<style>
.obra-container {
  max-width: 100%;
  margin: 0;
  padding: 0;
  color: var(--color-travertine-light);
  min-height: 100vh;
  background: #050505;
}

.split-layout {
  display: flex;
  width: 100%;
}

.image-column {
  position: fixed;
  left: 0;
  top: 0;
  width: 50vw;
  height: 100dvh;
  background: #0d0d0d;
  padding: 0 5%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-right: 1px solid rgba(255,255,255,0.03);
  z-index: 5;
}

.info-column {
  margin-left: 50vw;
  width: 50vw;
  padding: 160px 8% 10rem;
  background: #050505; 
  min-height: 100dvh;
}

@media (max-width: 1024px) {
  .split-layout { flex-direction: column; }
  .image-column { position: relative; width: 100%; height: 70dvh; }
  .info-column { margin-left: 0; width: 100%; padding: 4rem 8%; }
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: calc(100dvh - 350px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rem;
}

.main-artwork, .room-artwork {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  transition: opacity 0.8s ease;
  filter: drop-shadow(0 20px 60px rgba(0,0,0,0.6));
}

.room-artwork {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
}

.control-btn {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  color: var(--color-travertine-muted);
  padding: 1rem 1.4rem;
  font-family: var(--font-secondary);
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 3px;
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.4s ease;
  flex: 1;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-btn:hover {
  background: var(--gold-metallic);
  color: #000;
  transform: translateY(-2px);
}

.checkout-area {
  margin-top: 4rem;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.price-box {
  border-left: 2px solid var(--color-accent);
  padding-left: 1.5rem;
}

.price-value-container .number {
  font-family: var(--font-primary);
  font-size: 3rem;
  color: var(--color-white);
}

.tabs-header {
  display: flex;
  margin-bottom: 4rem;
  border-bottom: 1px solid var(--color-accent);
}

.tab-btn {
  background: transparent;
  border: none;
  color: var(--color-text-muted);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  padding: 0.8rem 2rem;
  cursor: pointer;
}

.tab-btn.active {
  color: var(--color-accent);
  border-bottom: 2px solid var(--color-accent);
}

.tag-accent {
  color: var(--color-accent);
  border: 1px solid var(--color-accent);
  padding: 0.5rem 1rem;
}

.back-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    margin-bottom: 2rem;
    display: inline-block;
}
</style>
