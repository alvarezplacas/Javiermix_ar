---
import Layout from '../../layouts/Layout.astro';
import { getLaboratorioFiles, getAssetUrl } from '../../conexion/directus';

const artworks = await getLaboratorioFiles();
// Filtramos solo las obras principales y limitamos campos (Directus ya lo hace en la función, pero nos aseguramos aquí)
const filteredArtworks = artworks.filter(f => !(f.filename_download || "").match(/[\s_]2\.[^.]+$/i)).slice(0, 12);
---

<Layout title="Royal Gallery | Experimentación Inmersiva">
  <main class="royal-gallery-wrapper">
    <!-- 🧭 Menú Supremo -->
    <nav class="supreme-nav">
        <a href="/">INICIO</a>
        <a href="/galeria">GALERÍA</a>
        <a href="/revista">REVISTA</a>
        <a href="/laboratorio">LABORATORIO</a>
    </nav>

    <!-- 💡 Canvas para Iluminación Ambiental -->
    <canvas id="lighting-canvas"></canvas>

    <div class="horizontal-scroll-container" id="scroll-container">
        <div class="gallery-wall" id="wall">
            {filteredArtworks.map((art, i) => (
                <article class="wall-spot">
                    <div class="ceiling-light"></div>
                    <div class="artwork-frame">
                        <div class="loading-spinner"></div>
                        <a href={`/galeria/${art.id}`} class="art-link">
                            <img 
                              src={getAssetUrl(art.id, { width: 900, quality: 80, format: 'webp' })} 
                              alt={art.title} 
                              class="art-image"
                              loading="lazy"
                              decoding="async"
                              onload="this.parentElement.parentElement.querySelector('.loading-spinner').remove()"
                            />
                        </a>
                        <div class="frame-shadow"></div>
                    </div>
                    <div class="artwork-label">
                        <span class="index">0{i+1}</span>
                        <h3>{art.title || 'Obra Javier Mix'}</h3>
                        <p>Fine Art Selection 2026</p>
                        
                        <div class="action-area">
                            <a href={`/galeria/${art.id}`} class="btn-collect">
                                COLECCIONAR
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 4v16m8-8H4"/></svg>
                            </a>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>

    <!-- 🎨 Selector de Estilos -->
    <div class="theme-selector">
        <button class="theme-btn active" data-theme="dark" title="Dark Museum"><span style="background: #0a0a0a;"></span></button>
        <button class="theme-btn" data-theme="white" title="White Gallery"><span style="background: #f0f0f0;"></span></button>
        <button class="theme-btn" data-theme="marble" title="Carrara Marble"><span style="background: linear-gradient(45deg, #fff, #ddd);"></span></button>
        <button class="theme-btn" data-theme="brick" title="Urban Brick"><span style="background: #5d2a1e;"></span></button>
        <button class="theme-btn" data-theme="red" title="Classic Maroon"><span style="background: #4a0a0a;"></span></button>
        <button class="theme-btn" data-theme="worn" title="Old Loft"><span style="background: #333; border: 1px dashed #777;"></span></button>
    </div>

    <!-- Guía de Navegación -->
    <div class="scroll-guide">
        <div class="guide-line"></div>
        <span>DESLIZA PARA RECORRER LA PARED</span>
    </div>
  </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const wall = document.getElementById('wall');
        const container = document.getElementById('scroll-container');
        
        let scrollY = 0;
        let targetScrollY = 0;
        
        // --- 🧊 MOTOR DE DESPLAZAMIENTO LATERAL ---
        window.addEventListener('wheel', (e) => {
            targetScrollY += e.deltaY;
            // Limitamos el scroll según el ancho de la pared
            const maxScroll = wall ? wall.scrollWidth - window.innerWidth : 0;
            targetScrollY = Math.max(0, Math.min(targetScrollY, maxScroll));
        }, { passive: true });

        function updateWall() {
            scrollY += (targetScrollY - scrollY) * 0.05;
            if (wall) {
                wall.style.transform = `translateX(-${scrollY}px)`;
            }
            requestAnimationFrame(updateWall);
        }

        updateWall();

        // --- 🎨 GESTIÓN DE TEMAS ---
        const wrapper = document.querySelector('.royal-gallery-wrapper');
        const themeBtns = document.querySelectorAll('.theme-btn');
        let currentLightColor = 'rgba(220, 177, 74, 0.03)';

        themeBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const theme = btn.getAttribute('data-theme');
                wrapper?.setAttribute('data-theme', theme || 'dark');
                
                themeBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                // Ajustamos la luz según el tema
                if (theme === 'white') currentLightColor = 'rgba(0, 0, 0, 0.05)';
                else currentLightColor = 'rgba(220, 177, 74, 0.03)';
                
                drawLight(); // Redibujamos solo al cambiar de tema
            });
        });

        // --- 💡 MOTOR DE ILUMINACIÓN OPTIMIZADO ---
        const canvas = document.getElementById('lighting-canvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            drawLight(); // Solo dibujamos al redimensionar
        }

        function drawLight() {
            if (!ctx) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const ambient = ctx.createRadialGradient(
                canvas.width / 2, canvas.height / 2, 0,
                canvas.width / 2, canvas.height / 2, canvas.width
            );
            ambient.addColorStop(0, currentLightColor);
            ambient.addColorStop(1, 'rgba(0, 0, 0, 0)');
            ctx.fillStyle = ambient;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        }

        window.addEventListener('resize', resize);
        resize();
        // Eliminamos el requestAnimationFrame de aquí para ahorrar energía
    });
</script>

<style>
  :root {
    --lab-gold: #dcb14a;
    --wall-color: #0a0a0a;
  }

  .royal-gallery-wrapper {
    width: 100vw;
    height: 100vh;
    background-color: var(--wall-color); /* 💎 Color global */
    overflow: hidden;
    position: relative;
    cursor: grab;
    transition: background-color 1s ease;
  }

  /* 🌫️ Capa de Grano Optimizado (Detrás de las obras) */
  .royal-gallery-wrapper::after {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0.04;
      pointer-events: none;
      z-index: 1; /* 💎 Debajo de la galería */
      background-image: url("data:image/png;base64,");
  }

  #lighting-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* 🧭 Menú Supremo */
  .supreme-nav {
      position: fixed;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 999;
      display: flex;
      gap: 3rem;
      padding: 1rem 3rem;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 50px;
  }

  .supreme-nav a {
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      font-size: 0.6rem;
      letter-spacing: 3px;
      font-weight: 700;
      transition: all 0.3s;
  }

  .supreme-nav a:hover { color: var(--lab-gold); }

  .gallery-wall {
    display: flex;
    padding: 0 20vw;
    height: 100vh;
    align-items: center;
    gap: 30vw;
    will-change: transform;
    z-index: 2;
    position: relative;
    background: transparent; /* Ahora el fondo es del wrapper */
  }

  /* 💎 Variaciones de Pared */
  :root { --wall-color: #050505; }
  .royal-gallery-wrapper[data-theme="dark"] { --wall-color: #050505; }
  .royal-gallery-wrapper[data-theme="white"] { --wall-color: #f5f5f5; }
  .royal-gallery-wrapper[data-theme="red"] { --wall-color: #2d0505; }
  .royal-gallery-wrapper[data-theme="worn"] { --wall-color: #1a1a1a; }
  .royal-gallery-wrapper[data-theme="marble"] { --wall-color: #e8e8e8; }
  .royal-gallery-wrapper[data-theme="brick"] { --wall-color: #3d1b14; }

  /* 💎 TEXTURAS AVANZADAS */
  
  /* MÁRMOL CARRARA RE-REALISTA */
  .royal-gallery-wrapper[data-theme="marble"] {
      background-image: 
        radial-gradient(circle at 50% 0%, rgba(255,255,255,0.8), transparent),
        url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.005' numOctaves='5' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncR type='discrete' tableValues='0 1'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E"),
        linear-gradient(45deg, #fff 0%, #eee 50%, #ddd 100%);
  }

  /* LADRILLO URBAN RE-REALISTA */
  .royal-gallery-wrapper[data-theme="brick"] {
      background-color: #3d1b14;
      background-image: 
        linear-gradient(90deg, rgba(0,0,0,0.1) 2px, transparent 2px),
        linear-gradient(rgba(0,0,0,0.1) 2px, transparent 2px),
        url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.5' numOctaves='2'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.1'/%3E%3C/svg%3E");
      background-size: 80px 40px, 80px 40px, auto;
  }

  .royal-gallery-wrapper[data-theme="white"] .artwork-label h3,
  .royal-gallery-wrapper[data-theme="marble"] .artwork-label h3 { color: #111; }
  
  .royal-gallery-wrapper[data-theme="white"] .artwork-label p,
  .royal-gallery-wrapper[data-theme="marble"] .artwork-label p { color: #888; }
  
  /* 🏚️ Textura DESGASTADA (Old Loft) */
  .royal-gallery-wrapper[data-theme="worn"] {
      background-image: 
        url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.02' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E"),
        linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.5));
      background-blend-mode: overlay;
      background-size: 800px 800px;
  }

  .wall-spot {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 600px;
  }

  /* 💡 Foco de luz superior */
  .ceiling-light {
      position: absolute;
      top: -30vh;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(220, 177, 74, 0.15) 0%, transparent 70%);
      filter: blur(40px);
      pointer-events: none;
  }

  .ceiling-light::after {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      width: 2px;
      height: 100vh;
      background: linear-gradient(to bottom, rgba(220, 177, 74, 0.2), transparent);
      transform: translateX(-50%);
  }

  .artwork-frame {
    position: relative;
    padding: 1.5rem;
    background: #000;
    box-shadow: 
        0 50px 100px rgba(0,0,0,0.9),
        0 10px 20px rgba(0,0,0,0.5),
        inset 0 0 0 1px rgba(255,255,255,0.05);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    min-width: 300px;
    min-height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.02);
  }

  .art-link { display: block; cursor: pointer; overflow: hidden; }

  .art-image {
    max-height: 45vh;
    width: auto;
    display: block;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .art-link:hover .art-image { transform: scale(1.05); }

  /* 🛒 Botón Coleccionar */
  .action-area {
      margin-top: 2rem;
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.6s ease;
  }

  .wall-spot:hover .action-area {
      opacity: 1;
      transform: translateY(0);
  }

  .btn-collect {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
      padding: 0.8rem 2rem;
      background: var(--lab-gold);
      color: black;
      text-decoration: none;
      font-size: 0.65rem;
      font-weight: 900;
      letter-spacing: 2px;
      transition: all 0.3s;
  }

  .btn-collect svg { width: 14px; height: 14px; }
  .btn-collect:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(220, 177, 74, 0.3); }

  .artwork-label {
      margin-top: 3rem;
      text-align: center;
      color: #fff;
  }

  .index {
      font-size: 0.6rem;
      color: var(--lab-gold);
      letter-spacing: 5px;
      display: block;
      margin-bottom: 0.5rem;
  }

  .artwork-label h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      margin-bottom: 0.5rem;
      font-weight: 300;
  }

  .artwork-label p {
      font-size: 0.6rem;
      color: rgba(255,255,255,0.3);
      letter-spacing: 3px;
      text-transform: uppercase;
  }

  .scroll-guide {
      position: fixed;
      bottom: 2rem;
      left: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      color: rgba(255,255,255,0.2);
      font-size: 0.6rem;
      letter-spacing: 4px;
      z-index: 10;
  }

  /* 🎨 Estilo Theme Selector */
  .theme-selector {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 100;
      display: flex;
      gap: 1rem;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(20px);
      padding: 0.8rem;
      border-radius: 40px;
      border: 1px solid rgba(255,255,255,0.1);
  }

  .theme-btn {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 2px solid transparent;
      padding: 2px;
      background: none;
      cursor: pointer;
      transition: all 0.3s;
  }

  .theme-btn span {
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 50%;
  }

  .theme-btn.active {
      border-color: var(--lab-gold);
      transform: scale(1.2);
  }

  .theme-btn:hover { transform: scale(1.1); }

  .guide-line {
      width: 1px;
      height: 50px;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.2));
  }

  @media (max-width: 768px) {
      .wall-spot { min-width: 300px; }
      .art-image { max-height: 40vh; }
  }
</style>
