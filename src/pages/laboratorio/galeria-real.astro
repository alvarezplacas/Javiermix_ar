---
// d:\web_javiermix\JAVIERMIX-AR-0504\src\pages\laboratorio\galeria-real.astro
import Layout from '@layouts/Layout.astro';
import { getCatalogoFiles } from '@conexion/directus';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

const artworksRaw = await getCatalogoFiles();
const artworks = artworksRaw
    .filter(file => !file.filename_download.toLowerCase().includes('_2'))
    .slice(0, 15)
    .map((file, index) => ({
        id: file.id,
        title: file.title || `Masterpiece ${index + 1}`,
        img: getOptimizedImageURL(file.id, { width: 1200, format: 'webp', quality: 90 }),
        width: 500 + (Math.random() * 150), 
    }));
---

<Layout title="Royal Gallery | Laboratorio JMX">
    <main class="royal-gallery-wrapper is-atmos-gallery" id="gallery-container">
        <div class="atmos-overlay"></div>

        <header class="gallery-ui">
            <div class="ui-top">
                <a href="/laboratorio" class="exit-link">SALIR DE LA EXHIBICIÓN</a>
                <div class="museum-logo">JMX ROYAL MUSEUM</div>
            </div>

            <div class="ui-bottom">
                <div class="playback-controls">
                    <button id="play-btn" class="control-btn" title="Auto-Tour">
                        <span class="icon">▶</span>
                        PLAY TOUR
                    </button>
                    <div class="sound-toggle" id="sound-btn">
                        <span class="icon">🔇</span>
                        AUDIO OFF
                    </div>
                </div>

                <div class="atmos-controls">
                    <button class="atmos-btn active" data-atmos="gallery" data-label="Mármol Carrara">🏛️</button>
                    <button class="atmos-btn" data-atmos="night" data-label="Urban Brick">🧱</button>
                    <button class="atmos-btn" data-atmos="velvet" data-label="Velvet Red">🍷</button>
                    <button class="atmos-btn" data-atmos="blue" data-label="Velvet Blue">🌌</button>
                    <button class="atmos-btn" data-atmos="concrete" data-label="Hormigón Visto">🩶</button>
                    <button class="atmos-btn" data-atmos="gold" data-label="Golden Leaf">📀</button>
                </div>
            </div>
        </header>

        <div class="horizontal-wall" id="wall">
            {artworks.map((art, index) => (
                <div class="artwork-station" style={`--station-index: ${index}`}>
                    <div class="frame-container" data-tilt>
                        <div class="museum-spotlight"></div>
                        <img 
                            src={art.img} 
                            alt={art.title} 
                            class="main-artwork" 
                            onerror="this.src='/img/placeholder.jpg'; this.classList.add('error');"
                        />
                        <div class="frame-shadow"></div>
                    </div>
                    <div class="artwork-caption">
                        <span class="serial">INV-2026-{index + 100}</span>
                        <h2>{art.title}</h2>
                        <p>Impresión Giclée · Papel Hahnemühle Photo Rag.</p>
                        <button class="buy-btn" data-id={art.id}>COLECCIONAR</button>
                    </div>
                </div>
            ))}
        </div>

        <div class="scroll-progress">
            <div class="bar" id="progress-bar"></div>
        </div>
    </main>
</Layout>

<style>
    @import "../../styles/atmospheres.css";

    .royal-gallery-wrapper {
        height: 100vh;
        width: 100vw;
        overflow-x: auto;
        overflow-y: hidden;
        background: #f5f5f5;
        color: #000;
        position: relative;
        transition: background 1.5s cubic-bezier(0.4, 0, 0.2, 1);
        scrollbar-width: none;
    }
    .royal-gallery-wrapper::-webkit-scrollbar { display: none; }

    .gallery-ui {
        position: fixed;
        inset: 0;
        z-index: 100;
        pointer-events: none;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ui-top, .ui-bottom { display: flex; justify-content: space-between; align-items: center; pointer-events: auto; }

    .playback-controls { display: flex; align-items: center; gap: 2rem; }
    .control-btn {
        background: rgba(0,0,0,0.1);
        border: 1px solid rgba(0,0,0,0.1);
        color: inherit;
        padding: 0.6rem 1.2rem;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 2px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        transition: 0.3s;
    }
    .control-btn.active { background: var(--color-accent, #dcb14a); color: #000; border-color: transparent; }

    .exit-link { font-size: 0.7rem; font-weight: 900; letter-spacing: 3px; color: inherit; text-decoration: none; opacity: 0.5; transition: 0.3s; }
    .exit-link:hover { opacity: 1; letter-spacing: 5px; }

    .museum-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; letter-spacing: 5px; font-weight: 600; }

    .sound-toggle { cursor: pointer; font-size: 0.7rem; font-weight: 900; letter-spacing: 2px; display: flex; align-items: center; gap: 0.8rem; opacity: 0.6; transition: 0.3s; }
    .sound-toggle:hover { opacity: 1; }

    .horizontal-wall {
        height: 100%;
        display: flex;
        align-items: center;
        padding: 0 30vw;
        gap: 20vw;
        will-change: transform;
    }

    .artwork-station {
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
        text-align: center;
        transform: translateY(5vh); /* Bajar un poco las obras */
    }

    .frame-container {
        position: relative;
        padding: 1.5rem;
        background: #fff;
        box-shadow: 0 30px 80px rgba(0,0,0,0.08);
        border: 1px solid rgba(0,0,0,0.05);
        transform-style: preserve-3d;
        transition: all 0.5s ease;
    }

    .main-artwork {
        max-height: 48vh; /* Tamaño reducido */
        width: auto;
        display: block;
        position: relative;
        z-index: 2;
    }
    .main-artwork.error { opacity: 0.3; filter: grayscale(1); }

    .museum-spotlight {
        position: absolute;
        top: -150px; left: 50%;
        transform: translateX(-50%);
        width: 300px; height: 400px;
        background: radial-gradient(circle at top, rgba(255,255,255,0.6), transparent 80%);
        opacity: 0.3;
        pointer-events: none;
    }

    .artwork-caption {
        max-width: 400px;
        opacity: 0;
        transform: translateY(20px);
        transition: 1s ease;
    }
    .artwork-station:hover .artwork-caption { opacity: 1; transform: translateY(0); }

    .artwork-caption h2 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; margin: 0.5rem 0; font-weight: 400; }
    .artwork-caption p { font-size: 0.85rem; color: rgba(0,0,0,0.5); font-weight: 300; }
    .serial { font-size: 0.6rem; letter-spacing: 3px; font-weight: 900; color: var(--color-accent, #dcb14a); }

    .buy-btn {
        margin-top: 1.5rem;
        padding: 0.8rem 2rem;
        background: #000;
        color: #fff;
        border: none;
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 3px;
        cursor: pointer;
        transition: 0.3s;
    }
    .buy-btn:hover { background: var(--color-accent, #dcb14a); color: #000; transform: scale(1.05); }

    .scroll-progress {
        position: fixed;
        bottom: 0; left: 0; width: 100%; height: 3px;
        background: rgba(0,0,0,0.03);
    }
    .scroll-progress .bar { height: 100%; width: 0%; background: var(--color-accent, #dcb14a); transition: width 0.1s linear; }

    /* Adaptaciones para atmósferas */
    .is-atmos-night, .is-atmos-velvet, .is-atmos-blue, .is-atmos-concrete, .is-atmos-gold { color: #fff; }
    .is-atmos-night .frame-container, .is-atmos-velvet .frame-container, .is-atmos-blue .frame-container, .is-atmos-concrete .frame-container, .is-atmos-gold .frame-container { 
        background: #080808; border-color: rgba(255,255,255,0.05); box-shadow: 0 40px 100px rgba(0,0,0,0.8); 
    }
    .is-atmos-night .buy-btn, .is-atmos-velvet .buy-btn, .is-atmos-blue .buy-btn, .is-atmos-concrete .buy-btn, .is-atmos-gold .buy-btn { background: #fff; color: #000; }
    .is-atmos-night .artwork-caption p, .is-atmos-velvet .artwork-caption p, .is-atmos-blue .artwork-caption p, .is-atmos-concrete .artwork-caption p, .is-atmos-gold .artwork-caption p { color: rgba(255,255,255,0.4); }
    .is-atmos-night .control-btn, .is-atmos-velvet .control-btn, .is-atmos-blue .control-btn, .is-atmos-concrete .control-btn, .is-atmos-gold .control-btn { border-color: rgba(255,255,255,0.1); color: #fff; background: rgba(255,255,255,0.05); }

</style>

<script>
    import { soundManager } from '../../utils/SoundManager';

    document.addEventListener('astro:page-load', () => {
        const wall = document.getElementById('wall');
        const gallery = document.getElementById('gallery-container');
        const progressBar = document.getElementById('progress-bar');
        const soundBtn = document.getElementById('sound-btn');
        const playBtn = document.getElementById('play-btn');
        let soundEnabled = false;
        let autoPlayInterval: any = null;

        if (!wall || !gallery) return;

        // 🔊 Inicializar Sonido
        soundManager.init();
        soundBtn?.addEventListener('click', () => {
            soundEnabled = !soundEnabled;
            if (soundEnabled) {
                soundManager.enable();
                soundBtn.innerHTML = '<span class="icon">🔊</span> AUDIO ON';
                soundBtn.classList.add('active');
                // Intentar reproducir un loop ambiente si el usuario lo activa
                soundManager.playMusic('https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3');
            } else {
                soundManager.disable();
                soundBtn.innerHTML = '<span class="icon">🔇</span> AUDIO OFF';
                soundBtn.classList.remove('active');
            }
        });

        // 🚀 Auto-Tour (Play Button)
        playBtn?.addEventListener('click', () => {
            if (autoPlayInterval) {
                clearInterval(autoPlayInterval);
                autoPlayInterval = null;
                playBtn.innerHTML = '<span class="icon">▶</span> PLAY TOUR';
                playBtn.classList.remove('active');
            } else {
                playBtn.classList.add('active');
                playBtn.innerHTML = '<span class="icon">⏸</span> STOP TOUR';
                autoPlayInterval = setInterval(() => {
                    gallery.scrollLeft += 1;
                    updateProgress();
                    if (gallery.scrollLeft >= gallery.scrollWidth - window.innerWidth) {
                        gallery.scrollLeft = 0;
                    }
                }, 20); // Velocidad lenta y fluida
            }
        });

        const updateProgress = () => {
            const scrollPercent = (gallery.scrollLeft / (gallery.scrollWidth - window.innerWidth)) * 100;
            if (progressBar) progressBar.style.width = `${scrollPercent}%`;
        };

        gallery.addEventListener('scroll', updateProgress);

        // 🔘 Selector de Atmósferas
        const atmosBtns = document.querySelectorAll('.atmos-btn');
        atmosBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const atmos = btn.getAttribute('data-atmos');
                gallery.className = 'royal-gallery-wrapper';
                gallery.classList.add(`is-atmos-${atmos}`);
                atmosBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                if (soundEnabled) soundManager.play('transition', 0.2);
            });
        });

        // 🛒 Botón de Colección
        const buyBtns = document.querySelectorAll('.buy-btn');
        buyBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const id = btn.getAttribute('data-id');
                alert(`Iniciando Checkout Express para obra: ${id}`);
                if (soundEnabled) soundManager.play('hover', 0.3);
            });
        });
    });
</script>
