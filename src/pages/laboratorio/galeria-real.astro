---
// d:\web_javiermix\JAVIERMIX-AR-0504\src\pages\laboratorio\galeria-real.astro
import Layout from '@layouts/Layout.astro';
import { getCatalogoFiles } from '@conexion/directus';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

const artworksRaw = await getCatalogoFiles();
const artworks = artworksRaw
    .filter(file => !file.filename_download.toLowerCase().includes('_2'))
    .slice(0, 12)
    .map((file, index) => ({
        id: file.id,
        title: file.title || `Masterpiece ${index + 1}`,
        img: getOptimizedImageURL(file.id, { width: 1000, format: 'avif', quality: 90 }),
        width: 600 + (Math.random() * 200), // Anchos variables para realismo
    }));
---

<Layout title="Royal Gallery | Laboratorio JMX">
    <main class="royal-gallery-wrapper is-atmos-gallery" id="gallery-container">
        <!-- Capa de Iluminación y Filtros (De atmospheres.css) -->
        <div class="atmos-overlay"></div>

        <header class="gallery-ui">
            <div class="ui-top">
                <a href="/laboratorio" class="exit-link">SALIR DE LA EXHIBICIÓN</a>
                <div class="museum-logo">JMX ROYAL MUSEUM</div>
            </div>

            <div class="ui-bottom">
                <div class="atmos-controls">
                    <button class="atmos-btn active" data-atmos="gallery" data-label="Mármol Carrara">🏛️</button>
                    <button class="atmos-btn" data-atmos="night" data-label="Urban Brick">🧱</button>
                    <button class="atmos-btn" data-atmos="velvet" data-label="Velvet Red">🍷</button>
                </div>
                <div class="sound-toggle" id="sound-btn">
                    <span class="icon">🔇</span>
                    AUDIO OFF
                </div>
            </div>
        </header>

        <div class="horizontal-wall" id="wall">
            {artworks.map((art, index) => (
                <div class="artwork-station" style={`--station-index: ${index}`}>
                    <div class="frame-container" data-tilt>
                        <div class="museum-spotlight"></div>
                        <img src={art.img} alt={art.title} class="main-artwork" />
                        <div class="frame-shadow"></div>
                    </div>
                    <div class="artwork-caption">
                        <span class="serial">INV-2026-{index + 100}</span>
                        <h2>{art.title}</h2>
                        <p>Impresión Giclée sobre Papel Hahnemühle Photo Rag.</p>
                        <button class="buy-btn" data-id={art.id}>COLECCIONAR</button>
                    </div>
                </div>
            ))}
        </div>

        <!-- Barra de progreso sutil -->
        <div class="scroll-progress">
            <div class="bar" id="progress-bar"></div>
        </div>
    </main>
</Layout>

<style>
    @import "../../styles/atmospheres.css";

    .royal-gallery-wrapper {
        height: 100vh;
        width: 100vw;
        overflow: hidden;
        background: #f5f5f5; /* Mármol base */
        color: #000;
        position: relative;
        transition: background 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Textura de Ladrillo (Override temporal para el modo Night) */
    .is-atmos-night {
        background: #1a1a1a !important;
        background-image: url("data:image/svg+xml,%3Csvg width='42' height='44' viewBox='0 0 42 44' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23252525' fill-opacity='0.4'%3E%3Cpath d='M0 0h42v44H0V0zm1 1h40v42H1V1zM0 22h42v2H0v-2zm21-22h2v44h-2V0z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") !important;
    }

    .gallery-ui {
        position: fixed;
        inset: 0;
        z-index: 100;
        pointer-events: none;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .ui-top, .ui-bottom { display: flex; justify-content: space-between; align-items: center; pointer-events: auto; }

    .exit-link { font-size: 0.7rem; font-weight: 900; letter-spacing: 3px; color: inherit; text-decoration: none; opacity: 0.5; transition: 0.3s; }
    .exit-link:hover { opacity: 1; letter-spacing: 5px; }

    .museum-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; letter-spacing: 5px; font-weight: 600; }

    .sound-toggle { cursor: pointer; font-size: 0.7rem; font-weight: 900; letter-spacing: 2px; display: flex; align-items: center; gap: 0.8rem; opacity: 0.6; transition: 0.3s; }
    .sound-toggle:hover { opacity: 1; }

    .horizontal-wall {
        height: 100%;
        display: flex;
        align-items: center;
        padding: 0 20vw;
        gap: 25vw;
        will-change: transform;
    }

    .artwork-station {
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
        text-align: center;
    }

    .frame-container {
        position: relative;
        padding: 2rem;
        background: #fff;
        box-shadow: 0 40px 100px rgba(0,0,0,0.1);
        border: 1px solid rgba(0,0,0,0.05);
        transform-style: preserve-3d;
    }

    .main-artwork {
        max-height: 60vh;
        width: auto;
        display: block;
        position: relative;
        z-index: 2;
    }

    .museum-spotlight {
        position: absolute;
        top: -100px; left: 50%;
        transform: translateX(-50%);
        width: 300px; height: 300px;
        background: radial-gradient(circle at top, rgba(255,255,255,0.8), transparent 70%);
        opacity: 0.5;
        pointer-events: none;
    }

    .artwork-caption {
        max-width: 400px;
        animation: fadeIn 1s ease forwards;
        opacity: 0;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .artwork-caption h2 { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; margin: 0.5rem 0; font-weight: 400; }
    .artwork-caption p { font-size: 0.9rem; color: rgba(0,0,0,0.5); font-weight: 300; }
    .serial { font-size: 0.6rem; letter-spacing: 3px; font-weight: 900; color: var(--color-accent, #dcb14a); }

    .buy-btn {
        margin-top: 2rem;
        padding: 1rem 2.5rem;
        background: #000;
        color: #fff;
        border: none;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 3px;
        cursor: pointer;
        transition: 0.3s;
    }
    .buy-btn:hover { background: var(--color-accent, #dcb14a); color: #000; transform: scale(1.05); }

    .scroll-progress {
        position: fixed;
        bottom: 0; left: 0; width: 100%; height: 4px;
        background: rgba(0,0,0,0.05);
    }
    .scroll-progress .bar { height: 100%; width: 0%; background: var(--color-accent, #dcb14a); transition: width 0.1s linear; }

    /* Adaptaciones para atmósferas */
    .is-atmos-night, .is-atmos-velvet { color: #fff; }
    .is-atmos-night .frame-container, .is-atmos-velvet .frame-container { background: #080808; border-color: rgba(255,255,255,0.1); box-shadow: 0 40px 100px rgba(0,0,0,0.8); }
    .is-atmos-night .buy-btn, .is-atmos-velvet .buy-btn { background: #fff; color: #000; }
    .is-atmos-night .artwork-caption p, .is-atmos-velvet .artwork-caption p { color: rgba(255,255,255,0.4); }

</style>

<script>
    import { soundManager } from '../../utils/SoundManager';

    document.addEventListener('astro:page-load', () => {
        const wall = document.getElementById('wall');
        const gallery = document.getElementById('gallery-container');
        const progressBar = document.getElementById('progress-bar');
        const soundBtn = document.getElementById('sound-btn');
        let soundEnabled = false;

        if (!wall || !gallery) return;

        // 🔊 Inicializar Sonido
        soundManager.init();
        soundBtn?.addEventListener('click', () => {
            soundEnabled = !soundEnabled;
            if (soundEnabled) {
                soundManager.enable();
                soundBtn.innerHTML = '<span class="icon">🔊</span> AUDIO ON';
                soundBtn.classList.add('active');
            } else {
                soundManager.disable();
                soundBtn.innerHTML = '<span class="icon">🔇</span> AUDIO OFF';
                soundBtn.classList.remove('active');
            }
        });

        // 🚀 Navegación Horizontal Cinematográfica
        window.addEventListener('wheel', (e) => {
            e.preventDefault();
            const delta = e.deltaY;
            gallery.scrollLeft += delta;
            
            // Actualizar pared
            const scrollPercent = (gallery.scrollLeft / (gallery.scrollWidth - window.innerWidth)) * 100;
            if (progressBar) progressBar.style.width = `${scrollPercent}%`;

            // Sonido de desplazamiento sutil
            if (soundEnabled && Math.abs(delta) > 10) {
                // soundManager.play('transition', 0.05);
            }
        }, { passive: false });

        // 🔘 Selector de Atmósferas
        const atmosBtns = document.querySelectorAll('.atmos-btn');
        atmosBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const atmos = btn.getAttribute('data-atmos');
                
                // Limpiar clases
                gallery.className = 'royal-gallery-wrapper';
                gallery.classList.add(`is-atmos-${atmos}`);
                
                // Actualizar botones
                atmosBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                // Sonido de cambio
                if (soundEnabled) soundManager.play('transition', 0.2);
            });
        });

        // 💎 Interacción con Obras
        const station = document.querySelectorAll('.artwork-station');
        station.forEach(s => {
            s.addEventListener('mouseenter', () => {
                if (soundEnabled) soundManager.play('hover', 0.1);
            });
        });

        // 🛒 Botón de Colección (Express Checkout Placeholder)
        const buyBtns = document.querySelectorAll('.buy-btn');
        buyBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const id = btn.getAttribute('data-id');
                alert(`Iniciando Checkout Express para obra: ${id}\n(Integración con Mercado Pago V8 activa)`);
                if (soundEnabled) soundManager.play('hover', 0.3);
            });
        });
    });
</script>
