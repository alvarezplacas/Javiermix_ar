---
import Layout from '../../layouts/Layout.astro';
import { getHurlinghamFiles, getAssetUrl } from '../../conexion/directus';

const photos = await getHurlinghamFiles();

const uniqueSeries = [...new Set(photos.map((f: any) => f.serie_name))].filter(Boolean);

// Lógica de pares _2
const mainPhotos = photos.filter((p: any) => !p.filename_download.toLowerCase().includes('_2'));
const hoverPhotos = photos.filter((p: any) => p.filename_download.toLowerCase().includes('_2'));

const galleryItems = mainPhotos.map((file: any) => {
    const baseName = file.filename_download.split('.')[0];
    const hoverFile = hoverPhotos.find((h: any) => 
        h.filename_download.toLowerCase().includes(baseName.toLowerCase() + '_2') ||
        h.filename_download.toLowerCase().includes(baseName.toLowerCase() + ' _2')
    );

    return {
        id: file.id,
        title: file.title || file.filename_download,
        serie: file.serie_name,
        src: getAssetUrl(file.id, { width: 1600, format: 'webp', quality: 90 }),
        thumb: getAssetUrl(file.id, { width: 600, format: 'webp', quality: 70 }),
        hoverThumb: hoverFile ? getAssetUrl(hoverFile.id, { width: 1600, format: 'webp', quality: 90 }) : null,
        metadata: {
            type: file.type,
            size: (file.filesize / 1024 / 1024).toFixed(2) + ' MB',
            dim: `${file.width} x ${file.height}px`,
            date: file.uploaded_on ? new Date(file.uploaded_on).toLocaleDateString('es-AR') : ''
        }
    };
});
---

<Layout title="Estudio Hurlingham | Laboratorio JMX">
    <main class="studio-wrapper">
        <!-- Navegación -->
        <nav class="studio-nav">
            <a href="/laboratorio" class="back-link">← VOLVER AL LABORATORIO</a>
            <div class="studio-badge">SESIÓN: HURLINGHAM TALLERES</div>
        </nav>

        <header class="studio-header">
            <h1>Talleres Fotográficos</h1>
            
            <div class="studio-controls">
                <div class="filter-group">
                    <span class="label">Filtrar por Sesión:</span>
                    <select id="session-filter" class="studio-select">
                        <option value="all">Todas las Sesiones</option>
                        {uniqueSeries.map(s => (
                            <option value={s}>{s}</option>
                        ))}
                    </select>
                </div>
                <button id="play-tour" class="play-btn">
                    <span class="icon">▶</span> REPRODUCIR (5s)
                </button>
            </div>

            <p>Exploración técnica y archivo visual de las capturas realizadas en los talleres del Municipio de Hurlingham.</p>
        </header>

        {galleryItems.length === 0 ? (
            <div class="empty-state">
                <p>No se encontraron capturas en la carpeta "Estudio Hurlingham".</p>
                <p class="hint">Asegúrate de haber creado la carpeta en Directus y subido las imágenes.</p>
            </div>
        ) : (
            <div class="contact-sheet">
                {galleryItems.map((item, index) => (
                    <div class="photo-cell" data-index={index}>
                        <div class="image-box">
                            <img src={item.thumb} alt={item.title} loading="lazy" class="main-img" />
                            <div class="overlay">
                                <button class="view-btn" 
                                     data-src={item.src} 
                                     data-hover={item.hoverThumb || ''} 
                                     data-title={item.title} 
                                     data-date={item.metadata.date}
                                >EXPANDIR</button>
                            </div>
                        </div>
                        <div class="photo-info">
                            <span class="file-serie">{item.serie}</span>
                            <span class="file-name">{item.title}</span>
                            <span class="file-meta">{item.metadata.dim} | {item.metadata.size}</span>
                        </div>
                    </div>
                ))}
            </div>
        )}

        <!-- Visor de Alta Fidelidad -->
        <div id="viewer" class="studio-viewer">
            <div class="viewer-nav">
                <div></div> <!-- Espacio para mantener el botón de cierre a la derecha -->
                <button id="close-viewer" class="close-btn">×</button>
            </div>
            <div class="viewer-content">
                <div class="f11-hint">Presiona <b>F11</b> para pantalla completa.</div>
                <div class="slider-stage" id="comparison-stage">
                    <div class="slider-curtain">
                        <div class="curtain-line">
                            <div class="curtain-handle">
                                <div class="handle-arrows">‹›</div>
                            </div>
                        </div>
                    </div>
                    <div class="slider-labels">
                        <span class="label-original">ARCHIVO ORIGINAL</span>
                        <span class="label-restored">RESTAURACIÓN DIGITAL</span>
                    </div>
                    <div id="slide-current" class="slide-item active">
                        <div class="comparison-wrapper">
                            <img src="" alt="" class="v-main" />
                            <div class="curtain-wrapper">
                                <img src="" alt="" class="v-hover" />
                            </div>
                        </div>
                    </div>
                    <div id="slide-next" class="slide-item">
                        <div class="comparison-wrapper">
                            <img src="" alt="" class="v-main" />
                            <div class="curtain-wrapper">
                                <img src="" alt="" class="v-hover" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="viewer-meta-box">
                    <span id="viewer-title"></span>
                    <span id="viewer-date"></span>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
    :root {
        --studio-bg: #0a0a0a;
        --studio-accent: #dcb14a;
        --studio-text: rgba(255,255,255,0.7);
    }

    .studio-wrapper {
        min-height: 100vh;
        background: var(--studio-bg);
        color: #fff;
        padding: 8rem 4rem 4rem;
        font-family: 'Inter', system-ui, sans-serif;
    }

    .studio-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 2rem 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 100;
        background: linear-gradient(to bottom, var(--studio-bg) 0%, transparent 100%);
    }

    .back-link {
        color: var(--studio-text);
        text-decoration: none;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        transition: 0.3s;
    }
    .back-link:hover { color: #fff; }

    .studio-badge {
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 2px;
        color: var(--studio-accent);
        border: 1px solid var(--studio-accent);
        padding: 0.4rem 1rem;
    }

    .studio-header {
        max-width: 800px;
        margin-bottom: 5rem;
    }

    h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
    }

    p {
        color: var(--studio-text);
        line-height: 1.6;
        font-size: 1rem;
    }

    /* 🎞️ Contact Sheet Grid */
    .contact-sheet {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 3rem;
    }

    .photo-cell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: 0.4s;
    }

    .image-box {
        position: relative;
        aspect-ratio: 3/4;
        background: #111;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .image-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .photo-cell:hover .main-img { 
        transform: scale(1.05); 
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.4s;
        backdrop-filter: blur(5px);
        z-index: 10;
    }

    .photo-cell:hover .overlay { 
        opacity: 1; 
    }

    .slider-stage {
        position: relative;
        width: 100%;
        height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 1500px;
        overflow: hidden;
    }
    .comparison-wrapper {
        position: relative;
        display: grid;
        place-items: center;
        max-width: 90vw;
        max-height: 82vh;
        box-shadow: 0 40px 120px rgba(0,0,0,0.9);
        border: 1px solid rgba(255,255,255,0.05);
        --curtain-pos: 50%;
    }

    .comparison-wrapper > * {
        grid-area: 1 / 1;
        width: 100%;
        height: 100%;
    }

    .v-main {
        width: auto !important;
        height: auto !important;
        max-width: 90vw;
        max-height: 82vh;
        object-fit: contain;
    }

    .curtain-wrapper {
        width: var(--curtain-pos);
        height: 100%;
        overflow: hidden;
        z-index: 5;
        justify-self: start;
        pointer-events: none;
        /* Sombra de profundidad para efecto 3D */
        border-right: 1px solid rgba(255,255,255,0.3);
        box-shadow: 15px 0 40px rgba(0,0,0,0.6);
    }

    .v-hover {
        width: auto !important;
        height: auto !important;
        max-width: none;
        max-height: 82vh;
        object-fit: contain;
    }

    /* 🎭 Curtain UI */
    .slider-curtain {
        position: absolute;
        inset: 0;
        z-index: 20;
        pointer-events: none;
        display: none;
    }

    .slider-stage.has-comparison .slider-curtain { 
        display: block; 
        pointer-events: auto; 
    }

    .slider-stage.has-comparison {
        cursor: none !important;
    }

    .curtain-handle {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 48px;
        height: 48px;
        background: #fff;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #000;
        box-shadow: 0 0 40px rgba(0,0,0,0.5), 0 10px 30px rgba(0,0,0,0.3);
        cursor: grab;
        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        pointer-events: auto;
    }

    .curtain-handle:active {
        cursor: grabbing;
        transform: translate(-50%, -50%) scale(0.9);
    }

    .handle-arrows {
        display: flex;
        gap: 4px;
        font-size: 1rem;
        font-weight: 900;
        letter-spacing: -2px;
    }

    .slider-labels {
        position: absolute;
        top: 2rem;
        left: 2rem;
        right: 2rem;
        display: flex;
        justify-content: space-between;
        z-index: 25;
        pointer-events: none;
        opacity: 0;
        transition: 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .slider-stage.has-comparison:hover .slider-labels {
        opacity: 1;
    }

    .label-original, .label-restored {
        font-family: 'Inter', sans-serif;
        font-size: 0.5rem;
        letter-spacing: 2px;
        font-weight: 800;
        color: #000;
        background: #fff;
        padding: 0.5rem 1.2rem;
        border-radius: 100px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        text-transform: uppercase;
    }

    .view-btn {
        background: transparent;
        border: 1px solid #fff;
        color: #fff;
        padding: 0.8rem 1.5rem;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        cursor: pointer;
        transition: 0.3s;
    }
    .view-btn:hover { background: #fff; color: #000; }

    .photo-info {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .file-serie {
        font-size: 0.5rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--studio-accent);
        letter-spacing: 1px;
    }

    .file-name {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: #fff;
    }

    .file-meta {
        font-size: 0.6rem;
        font-family: monospace;
        color: var(--studio-text);
    }

    .empty-state {
        padding: 5rem;
        border: 1px dashed rgba(255,255,255,0.1);
        text-align: center;
        color: var(--studio-text);
    }

    /* 🔍 Studio Viewer */
    .studio-viewer {
        position: fixed;
        inset: 0;
        background: #000;
        z-index: 1000;
        display: none;
        justify-content: center;
        align-items: center;
        padding: 4rem;
        opacity: 0;
        transition: 0.5s;
    }

    .studio-viewer.active {
        display: flex;
        opacity: 1;
    }

    .viewer-content {
        max-width: 90%;
        max-height: 90%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .viewer-content img {
        max-width: 100%;
        max-height: 80vh;
        object-fit: contain;
        box-shadow: 0 0 50px rgba(0,0,0,0.5);
    }

    #viewer-title {
        font-family: 'Inter', sans-serif;
        font-size: 0.7rem;
        color: var(--studio-accent);
        font-weight: 700;
        letter-spacing: 1px;
        margin: 0;
    }

    #viewer-date {
        font-size: 0.55rem;
        color: rgba(255,255,255,0.4);
        font-family: monospace;
    }

    .viewer-meta-box {
        position: absolute;
        bottom: 2rem;
        right: 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.2rem;
        text-align: right;
        pointer-events: none;
    }

    .studio-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 2rem 0 3rem;
        padding: 1.5rem 0;
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        flex-wrap: wrap;
        gap: 2rem;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .filter-group .label {
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--studio-text);
        text-transform: uppercase;
    }

    .studio-select {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 0.8rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        min-width: 250px;
        outline: none;
        transition: 0.3s;
        font-family: inherit;
    }

    .studio-select:hover {
        border-color: var(--studio-accent);
        background: rgba(255,255,255,0.05);
    }

    .studio-select option {
        background: #111;
        color: #fff;
        padding: 10px;
    }

    .play-btn {
        background: transparent;
        border: 1px solid var(--studio-accent);
        color: var(--studio-accent);
        padding: 0.8rem 1.5rem;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 2px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        transition: 0.3s;
    }

    .play-btn.active {
        background: var(--studio-accent);
        color: #000;
    }

    .play-btn:hover {
        box-shadow: 0 0 20px rgba(220, 177, 74, 0.3);
    }

    .viewer-nav {
        position: absolute;
        top: 2rem;
        left: 2rem;
        right: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1001;
    }

    .f11-hint {
        position: fixed;
        bottom: 1.5rem;
        left: 2rem;
        font-size: 0.55rem;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.25);
        text-transform: uppercase;
        z-index: 1000;
        pointer-events: none;
    }

    .f11-hint b { color: var(--studio-accent); }

    .viewer-content {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        position: relative;
    }

    .slider-stage {
        position: relative;
        width: 100%;
        height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 1200px;
    }

    .slide-item {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        visibility: hidden;
        transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), 
                    filter 1.2s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.8s ease;
        will-change: transform, opacity, filter;
    }

    .slide-item.active {
        opacity: 1;
        visibility: visible;
        transform: translateX(0) scale(1);
        filter: blur(0) brightness(1);
        z-index: 2;
    }

    /* Estados de transición */
    .slide-item.exit-left {
        opacity: 0;
        transform: translateX(-100vw) scale(0.85) rotateY(15deg);
        filter: blur(15px) brightness(0.4);
    }

    .slide-item.enter-right {
        opacity: 0;
        transform: translateX(100vw) scale(1.15) rotateY(-15deg);
        filter: blur(15px) brightness(0.4);
    }
    .viewer-content.tour-active .slide-item {
        transition-duration: 1.6s;
    }

    .viewer-meta-box {
        position: fixed;
        bottom: 1.5rem;
        right: 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.2rem;
        text-align: right;
        pointer-events: none;
        z-index: 1000;
        opacity: 0.4;
    }

    #viewer-title {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: var(--studio-accent);
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    #viewer-date {
        font-size: 0.6rem;
        color: rgba(255,255,255,0.4);
        font-family: monospace;
    }

    .close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 3rem;
        cursor: pointer;
        line-height: 1;
        transition: 0.3s;
    }

    .close-btn:hover {
        transform: rotate(90deg);
        color: var(--studio-accent);
    }

    @media (max-width: 900px) {
        .studio-controls { flex-direction: column; align-items: flex-start; }
        .play-btn { width: 100%; justify-content: center; }
    }

    @media (max-width: 768px) {
        .studio-wrapper { padding: 6rem 2rem 2rem; }
        .contact-sheet { grid-template-columns: 1fr; }
        h1 { font-size: 2.5rem; }
    }
</style>

<script>
    const viewer = document.getElementById('viewer');
    const closeBtn = document.getElementById('close-viewer');
    const viewButtons = document.querySelectorAll('.view-btn');
    const slideCurrent = document.getElementById('slide-current');
    const slideNext = document.getElementById('slide-next');
    const viewerTitle = document.getElementById('viewer-title');
    const viewerDate = document.getElementById('viewer-date');
    const viewerContent = document.querySelector('.viewer-content');
    
    let isTransitioning = false;

    function updateViewer(src: string, hoverSrc: string, title: string, date: string) {
        if (isTransitioning) return;
        isTransitioning = true;

        const current = document.getElementById('slide-current');
        const next = document.getElementById('slide-next');
        const stage = document.getElementById('comparison-stage');

        if (!current || !next) {
            isTransitioning = false;
            return;
        }

        const nextMain = next.querySelector('.v-main') as HTMLImageElement;
        const nextHover = next.querySelector('.v-hover') as HTMLImageElement;

        if (!nextMain) {
            isTransitioning = false;
            return;
        }

        // 1. Preparar el siguiente slide
        nextMain.src = src;

        if (hoverSrc && nextHover) {
            nextHover.src = hoverSrc;
            nextHover.style.display = 'block';
            stage?.classList.add('has-comparison');
            resetCurtain();
        } else if (nextHover) {
            nextHover.style.display = 'none';
            stage?.classList.remove('has-comparison');
        }

        next.className = 'slide-item enter-right';
        void next.offsetWidth;

        // 2. Ejecutar la coreografía
        current.classList.add('exit-left');
        current.classList.remove('active');

        next.classList.add('active');
        next.classList.remove('enter-right');

        if (viewerTitle) viewerTitle.textContent = title;
        if (viewerDate) viewerDate.textContent = date;

        // 3. Swap de identidades tras la animación
        setTimeout(() => {
            current.className = 'slide-item';
            const tempId = current.id;
            current.id = next.id;
            next.id = tempId;
            isTransitioning = false;
        }, 1200);
    }

    viewButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const src = btn.getAttribute('data-src') || '';
            const hover = btn.getAttribute('data-hover') || '';
            const title = btn.getAttribute('data-title') || '';
            const date = btn.getAttribute('data-date') || '';
            
            updateViewer(src, hover, title, date);
            viewer?.classList.add('active');
            document.body.style.overflow = 'hidden';
        });
    });

    closeBtn?.addEventListener('click', () => {
        stopTour();
        viewer?.classList.remove('active');
        document.body.style.overflow = 'auto';
    });

    // --- Lógica de Filtrado (Menú Desplegable) ---
    const sessionFilter = document.getElementById('session-filter') as HTMLSelectElement;
    const photoCells = document.querySelectorAll('.photo-cell');

    sessionFilter?.addEventListener('change', () => {
        const filter = sessionFilter.value;

        photoCells.forEach(cell => {
            const serie = (cell as HTMLElement).querySelector('.file-serie')?.textContent;
            if (filter === 'all' || serie === filter) {
                (cell as HTMLElement).style.display = 'flex';
            } else {
                (cell as HTMLElement).style.display = 'none';
            }
        });
        
        if (tourInterval) { stopTour(); startTour(); }
    });

    // --- Lógica de Tour (Slideshow) ---
    const playTourBtn = document.getElementById('play-tour');
    let tourInterval: any = null;
    let currentTourIndex = 0;

    function startTour() {
        const visiblePhotos = Array.from(photoCells).filter(p => (p as HTMLElement).style.display !== 'none');
        if (visiblePhotos.length === 0) return;

        playTourBtn?.classList.add('active');
        playTourBtn!.innerHTML = '<span class="icon">⏹</span> DETENER TOUR';
        viewerContent?.classList.add('tour-active');
        
        // Abrir el visor con la primera
        const firstBtn = visiblePhotos[0].querySelector('.view-btn') as HTMLElement;
        firstBtn?.click();

        tourInterval = setInterval(() => {
            currentTourIndex = (currentTourIndex + 1) % visiblePhotos.length;
            const photo = visiblePhotos[currentTourIndex];
            const viewBtn = photo.querySelector('.view-btn') as HTMLElement;
            
            const src = viewBtn.getAttribute('data-src') || '';
            const hover = viewBtn.getAttribute('data-hover') || '';
            const title = viewBtn.getAttribute('data-title') || '';
            const date = viewBtn.getAttribute('data-date') || '';
            
            updateViewer(src, hover, title, date);
        }, 5000);
    }

    function stopTour() {
        if (tourInterval) clearInterval(tourInterval);
        tourInterval = null;
        playTourBtn?.classList.remove('active');
        playTourBtn!.innerHTML = '<span class="icon">▶</span> REPRODUCIR (5s)';
        viewerContent?.classList.remove('tour-active');
        viewer?.classList.remove('active');
        document.body.style.overflow = 'auto';
    }

    playTourBtn?.addEventListener('click', () => {
        if (tourInterval) stopTour();
        else {
            currentTourIndex = 0;
            startTour();
        }
    });

    // Cerrar con Escape
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            if (tourInterval) stopTour();
            else {
                viewer?.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }
    });
    // --- Lógica del Slider de Comparación ---
    const comparisonStage = document.getElementById('comparison-stage');
    const curtainLine = document.querySelector('.curtain-line') as HTMLElement;
    
    let isDragging = false;

    const startDragging = (e: MouseEvent | TouchEvent) => {
        isDragging = true;
        comparisonStage?.classList.add('is-dragging');
        handleMove(e instanceof MouseEvent ? e.clientX : e.touches[0].clientX);
    };

    const stopDragging = () => {
        isDragging = false;
        comparisonStage?.classList.remove('is-dragging');
    };

    const handleMove = (clientX: number) => {
        if (!isDragging) return;
        
        const activeWrapper = comparisonStage?.querySelector('.slide-item.active .comparison-wrapper') as HTMLElement;
        const mainImg = activeWrapper?.querySelector('.v-main') as HTMLElement;
        if (!activeWrapper || !mainImg) return;

        const rect = mainImg.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) * 100;
        const boundedX = Math.max(0, Math.min(100, x));

        activeWrapper.style.setProperty('--curtain-pos', `${boundedX}%`);
        
        if (curtainLine) {
            curtainLine.style.left = `${rect.left + (rect.width * boundedX / 100)}px`;
            curtainLine.style.opacity = '1';
        }

        const hoverImg = activeWrapper.querySelector('.v-hover') as HTMLElement;
        if (hoverImg) {
            hoverImg.style.width = `${rect.width}px`;
        }
    };

    comparisonStage?.addEventListener('mousedown', (e) => startDragging(e));
    window.addEventListener('mouseup', stopDragging);
    window.addEventListener('mousemove', (e) => handleMove(e.clientX));

    // Soporte Touch
    comparisonStage?.addEventListener('touchstart', (e) => startDragging(e));
    window.addEventListener('touchend', stopDragging);
    window.addEventListener('touchmove', (e) => handleMove(e.touches[0].clientX));

    function resetCurtain() {
        setTimeout(() => {
            const activeWrapper = comparisonStage?.querySelector('.slide-item.active .comparison-wrapper') as HTMLElement;
            const mainImg = activeWrapper?.querySelector('.v-main') as HTMLElement;
            if (!activeWrapper || !mainImg) return;

            const rect = mainImg.getBoundingClientRect();
            const initialX = 50;

            if (curtainLine) {
                curtainLine.style.left = `${rect.left + (rect.width * initialX / 100)}px`;
                curtainLine.style.opacity = '1';
            }
            
            activeWrapper.style.setProperty('--curtain-pos', `${initialX}%`);
            const hoverImg = activeWrapper.querySelector('.v-hover') as HTMLElement;
            if (hoverImg) {
                hoverImg.style.width = `${rect.width}px`;
            }
        }, 200);
    }
</script>
