---
import Layout from '../../layouts/Layout.astro';
import { getHurlinghamFiles, getAssetUrl } from '../../conexion/directus';

const photos = await getHurlinghamFiles();

const uniqueSeries = [...new Set(photos.map((f: any) => f.serie_name))].filter(Boolean);

// Formateo de datos para la galería
const galleryItems = photos.map((file: any) => ({
    id: file.id,
    title: file.title || file.filename_download,
    serie: file.serie_name,
    src: getAssetUrl(file.id, { width: 1600, format: 'webp', quality: 90 }),
    thumb: getAssetUrl(file.id, { width: 600, format: 'webp', quality: 70 }),
    metadata: {
        type: file.type,
        size: (file.filesize / 1024 / 1024).toFixed(2) + ' MB',
        dim: `${file.width} x ${file.height}px`,
        date: file.uploaded_on ? new Date(file.uploaded_on).toLocaleDateString('es-AR') : ''
    }
}));
---

<Layout title="Estudio Hurlingham | Laboratorio JMX">
    <main class="studio-wrapper">
        <!-- Navegación -->
        <nav class="studio-nav">
            <a href="/laboratorio" class="back-link">← VOLVER AL LABORATORIO</a>
            <div class="studio-badge">SESIÓN: HURLINGHAM TALLERES</div>
        </nav>

        <header class="studio-header">
            <h1>Talleres Fotográficos</h1>
            
            <div class="studio-controls">
                <div class="filter-group">
                    <span class="label">Filtrar por Sesión:</span>
                    <select id="session-filter" class="studio-select">
                        <option value="all">Todas las Sesiones</option>
                        {uniqueSeries.map(s => (
                            <option value={s}>{s}</option>
                        ))}
                    </select>
                </div>
                <button id="play-tour" class="play-btn">
                    <span class="icon">▶</span> REPRODUCIR (5s)
                </button>
            </div>

            <p>Exploración técnica y archivo visual de las capturas realizadas en los talleres del Municipio de Hurlingham.</p>
        </header>

        {galleryItems.length === 0 ? (
            <div class="empty-state">
                <p>No se encontraron capturas en la carpeta "Estudio Hurlingham".</p>
                <p class="hint">Asegúrate de haber creado la carpeta en Directus y subido las imágenes.</p>
            </div>
        ) : (
            <div class="contact-sheet">
                {galleryItems.map((item, index) => (
                    <div class="photo-cell" data-index={index}>
                        <div class="image-box">
                            <img src={item.thumb} alt={item.title} loading="lazy" />
                            <div class="overlay">
                                <button class="view-btn" data-src={item.src} data-title={item.title} data-date={item.metadata.date}>EXPANDIR</button>
                            </div>
                        </div>
                        <div class="photo-info">
                            <span class="file-serie">{item.serie}</span>
                            <span class="file-name">{item.title}</span>
                            <span class="file-meta">{item.metadata.dim} | {item.metadata.size}</span>
                        </div>
                    </div>
                ))}
            </div>
        )}

        <!-- Visor de Alta Fidelidad -->
        <div id="viewer" class="studio-viewer">
            <div class="viewer-nav">
                <span class="f11-hint">Sugerencia: Presiona <b>F11</b> para pantalla completa</span>
                <button id="close-viewer" class="close-btn">×</button>
            </div>
            <div class="viewer-content">
                <div class="slide-container">
                    <img id="viewer-img" src="" alt="" />
                </div>
                <div class="viewer-meta-box">
                    <span id="viewer-title"></span>
                    <span id="viewer-date"></span>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
    :root {
        --studio-bg: #0a0a0a;
        --studio-accent: #dcb14a;
        --studio-text: rgba(255,255,255,0.7);
    }

    .studio-wrapper {
        min-height: 100vh;
        background: var(--studio-bg);
        color: #fff;
        padding: 8rem 4rem 4rem;
        font-family: 'Inter', system-ui, sans-serif;
    }

    .studio-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 2rem 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 100;
        background: linear-gradient(to bottom, var(--studio-bg) 0%, transparent 100%);
    }

    .back-link {
        color: var(--studio-text);
        text-decoration: none;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        transition: 0.3s;
    }
    .back-link:hover { color: #fff; }

    .studio-badge {
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 2px;
        color: var(--studio-accent);
        border: 1px solid var(--studio-accent);
        padding: 0.4rem 1rem;
    }

    .studio-header {
        max-width: 800px;
        margin-bottom: 5rem;
    }

    h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
    }

    p {
        color: var(--studio-text);
        line-height: 1.6;
        font-size: 1rem;
    }

    /* 🎞️ Contact Sheet Grid */
    .contact-sheet {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 3rem;
    }

    .photo-cell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: 0.4s;
    }

    .image-box {
        position: relative;
        aspect-ratio: 3/4;
        background: #111;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .image-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .photo-cell:hover img { transform: scale(1.05); }

    .overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.4s;
        backdrop-filter: blur(5px);
    }

    .photo-cell:hover .overlay { opacity: 1; }

    .view-btn {
        background: transparent;
        border: 1px solid #fff;
        color: #fff;
        padding: 0.8rem 1.5rem;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        cursor: pointer;
        transition: 0.3s;
    }
    .view-btn:hover { background: #fff; color: #000; }

    .photo-info {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .file-serie {
        font-size: 0.5rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--studio-accent);
        letter-spacing: 1px;
    }

    .file-name {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: #fff;
    }

    .file-meta {
        font-size: 0.6rem;
        font-family: monospace;
        color: var(--studio-text);
    }

    .empty-state {
        padding: 5rem;
        border: 1px dashed rgba(255,255,255,0.1);
        text-align: center;
        color: var(--studio-text);
    }

    /* 🔍 Studio Viewer */
    .studio-viewer {
        position: fixed;
        inset: 0;
        background: #000;
        z-index: 1000;
        display: none;
        justify-content: center;
        align-items: center;
        padding: 4rem;
        opacity: 0;
        transition: 0.5s;
    }

    .studio-viewer.active {
        display: flex;
        opacity: 1;
    }

    .viewer-content {
        max-width: 90%;
        max-height: 90%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .viewer-content img {
        max-width: 100%;
        max-height: 80vh;
        object-fit: contain;
        box-shadow: 0 0 50px rgba(0,0,0,0.5);
    }

    #viewer-title {
        font-family: 'Inter', sans-serif;
        font-size: 0.7rem;
        color: var(--studio-accent);
        font-weight: 700;
        letter-spacing: 1px;
        margin: 0;
    }

    #viewer-date {
        font-size: 0.55rem;
        color: rgba(255,255,255,0.4);
        font-family: monospace;
    }

    .viewer-meta-box {
        position: absolute;
        bottom: 2rem;
        right: 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.2rem;
        text-align: right;
        pointer-events: none;
    }

    .studio-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 2rem 0 3rem;
        padding: 1.5rem 0;
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        flex-wrap: wrap;
        gap: 2rem;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .filter-group .label {
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--studio-text);
        text-transform: uppercase;
    }

    .studio-select {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 0.8rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        min-width: 250px;
        outline: none;
        transition: 0.3s;
        font-family: inherit;
    }

    .studio-select:hover {
        border-color: var(--studio-accent);
        background: rgba(255,255,255,0.05);
    }

    .studio-select option {
        background: #111;
        color: #fff;
        padding: 10px;
    }

    .play-btn {
        background: transparent;
        border: 1px solid var(--studio-accent);
        color: var(--studio-accent);
        padding: 0.8rem 1.5rem;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 2px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        transition: 0.3s;
    }

    .play-btn.active {
        background: var(--studio-accent);
        color: #000;
    }

    .play-btn:hover {
        box-shadow: 0 0 20px rgba(220, 177, 74, 0.3);
    }

    .viewer-nav {
        position: absolute;
        top: 2rem;
        left: 2rem;
        right: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1001;
    }

    .f11-hint {
        font-size: 0.65rem;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
    }

    .f11-hint b { color: var(--studio-accent); }

    .slide-container {
        position: relative;
        overflow: hidden;
        width: 100%;
        display: flex;
        justify-content: center;
    }

    #viewer-img {
        max-width: 100%;
        max-height: 85vh;
        object-fit: contain;
        box-shadow: 0 0 50px rgba(0,0,0,0.5);
    }

    /* Animación de entrada horizontal */
    .slide-in {
        animation: slideFromRight 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes slideFromRight {
        from { transform: translateX(100px); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }

    .close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 3rem;
        cursor: pointer;
        line-height: 1;
    }

    @media (max-width: 900px) {
        .studio-controls { flex-direction: column; align-items: flex-start; }
        .play-btn { width: 100%; justify-content: center; }
    }

    @media (max-width: 768px) {
        .studio-wrapper { padding: 6rem 2rem 2rem; }
        .contact-sheet { grid-template-columns: 1fr; }
        h1 { font-size: 2.5rem; }
    }
</style>

<script>
    const viewer = document.getElementById('viewer');
    const viewerImg = document.getElementById('viewer-img') as HTMLImageElement;
    const viewerTitle = document.getElementById('viewer-title');
    const closeBtn = document.getElementById('close-viewer');
    const viewButtons = document.querySelectorAll('.view-btn');

    viewButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const src = btn.getAttribute('data-src');
            const title = btn.getAttribute('data-title');
            
            // Buscar metadata en el array local si es posible, o usar dataset
            // Para simplicidad, buscaremos el elemento padre para obtener la fecha si la guardamos ahí
            // O mejor: guardamos la fecha en un data-attribute del botón
            const date = btn.getAttribute('data-date');
            
            if (viewerImg && src) {
                viewerImg.src = src;
                if (viewerTitle) viewerTitle.textContent = title;
                const viewerDate = document.getElementById('viewer-date');
                if (viewerDate) viewerDate.textContent = date || '';

                viewer?.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        });
    });

    closeBtn?.addEventListener('click', () => {
        viewer?.classList.remove('active');
        document.body.style.overflow = 'auto';
    });

    // --- Lógica de Filtrado (Menú Desplegable) ---
    const sessionFilter = document.getElementById('session-filter') as HTMLSelectElement;
    const photoCells = document.querySelectorAll('.photo-cell');

    sessionFilter?.addEventListener('change', () => {
        const filter = sessionFilter.value;

        photoCells.forEach(cell => {
            const serie = (cell as HTMLElement).querySelector('.file-serie')?.textContent;
            if (filter === 'all' || serie === filter) {
                (cell as HTMLElement).style.display = 'flex';
            } else {
                (cell as HTMLElement).style.display = 'none';
            }
        });
        
        if (tourInterval) { stopTour(); startTour(); }
    });

    // --- Lógica de Tour (Slideshow) ---
    const playTourBtn = document.getElementById('play-tour');
    let tourInterval: any = null;
    let currentTourIndex = 0;

    function startTour() {
        const visiblePhotos = Array.from(photoCells).filter(p => (p as HTMLElement).style.display !== 'none');
        if (visiblePhotos.length === 0) return;

        playTourBtn?.classList.add('active');
        playTourBtn!.innerHTML = '<span class="icon">⏹</span> DETENER TOUR';

        tourInterval = setInterval(() => {
            const photo = visiblePhotos[currentTourIndex];
            const viewBtn = photo.querySelector('.view-btn') as HTMLElement;
            
            // Efecto de slide-out antes de cargar la siguiente
            viewerImg?.classList.remove('slide-in');
            void viewerImg?.offsetWidth; // Trigger reflow
            
            viewBtn?.click();
            viewerImg?.classList.add('slide-in');

            currentTourIndex = (currentTourIndex + 1) % visiblePhotos.length;
        }, 5000);
    }

    function stopTour() {
        if (tourInterval) clearInterval(tourInterval);
        tourInterval = null;
        playTourBtn?.classList.remove('active');
        playTourBtn!.innerHTML = '<span class="icon">▶</span> REPRODUCIR (5s)';
        viewer?.classList.remove('active');
        document.body.style.overflow = 'auto';
    }

    playTourBtn?.addEventListener('click', () => {
        if (tourInterval) stopTour();
        else {
            currentTourIndex = 0;
            startTour();
        }
    });

    // Cerrar con Escape
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            if (tourInterval) stopTour();
            else {
                viewer?.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }
    });
</script>
