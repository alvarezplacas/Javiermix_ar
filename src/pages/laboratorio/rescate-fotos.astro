---
import Layout from '../../layouts/Layout.astro';
import { getRescateFiles, getAssetUrl } from '../../conexion/directus';

const photos = await getRescateFiles();

const uniqueSeries = [...new Set(photos.map((f: any) => f.serie_name))].filter(Boolean);

// Lógica de pares _2
const mainPhotos = photos.filter((p: any) => !p.filename_download.toLowerCase().includes('_2'));
const hoverPhotos = photos.filter((p: any) => p.filename_download.toLowerCase().includes('_2'));

const galleryItems = mainPhotos.map((file: any) => {
    const baseName = file.filename_download.split('.')[0];
    // Buscador más flexible de la versión restaurada
    const hoverFile = hoverPhotos.find((h: any) => 
        h.filename_download.toLowerCase().includes(baseName.toLowerCase() + '_2') ||
        h.filename_download.toLowerCase().includes(baseName.toLowerCase() + ' _2')
    );

    return {
        id: file.id,
        title: file.title || file.filename_download,
        serie: file.serie_name,
        src: getAssetUrl(file.id, { width: 1600, format: 'webp', quality: 90 }),
        thumb: getAssetUrl(file.id, { width: 600, format: 'webp', quality: 70 }),
        hoverThumb: hoverFile ? getAssetUrl(hoverFile.id, { width: 1600, format: 'webp', quality: 90 }) : null,
        metadata: {
            type: file.type,
            size: (file.filesize / 1024 / 1024).toFixed(2) + ' MB',
            dim: `${file.width} x ${file.height}px`,
            date: file.uploaded_on ? new Date(file.uploaded_on).toLocaleDateString('es-AR') : ''
        }
    };
});
---

<Layout title="Rescate de Fotos Antiguas | Laboratorio JMX">
    <main class="studio-wrapper">
        <div class="grain-overlay"></div>
        
        <!-- Navegación -->
        <nav class="studio-nav">
            <a href="/laboratorio" class="back-link">← VOLVER AL LABORATORIO</a>
            <div class="studio-badge">PROTOCOLO: RESCATE HISTÓRICO</div>
        </nav>

        <header class="studio-header">
            <div class="pre-title">ARCHIVOS RECUPERADOS</div>
            <h1>Restauración & Memoria</h1>
            
            <div class="filter-navigation">
                <select id="session-filter" class="tag-selector">
                    <option value="all">TODOS LOS ARCHIVOS</option>
                    {uniqueSeries.map(s => (
                        <option value={s}>{s.toUpperCase()}</option>
                    ))}
                </select>
            </div>
        </header>

        {galleryItems.length === 0 ? (
            <div class="empty-state">
                <p>No se encontraron capturas en la carpeta "Rescate de Fotos".</p>
                <p class="hint">Asegúrate de haber creado la carpeta en Directus y subido las imágenes.</p>
            </div>
        ) : (
            <div class="contact-sheet">
                {galleryItems.map((item, index) => (
                    <div class="photo-cell" data-index={index} data-serie={item.serie}>
                        <div class="image-box" onclick="openStudioViewer(this)" 
                            style="cursor: pointer;"
                            data-src={item.src} 
                            data-hover={item.hoverThumb} 
                            data-title={item.title} 
                            data-date={item.metadata.date}
                        >
                            <img src={item.thumb} alt={item.title} loading="lazy" class="old-photo-effect main-img" />
                        </div>
                        <div class="photo-info">
                            <span class="file-name">{item.title}</span>
                            <span class="file-meta">{item.metadata.date ? new Date(item.metadata.date).getFullYear() : ''}</span>
                        </div>
                    </div>
                ))}
            </div>
        )}

        <!-- Visor de Alta Fidelidad -->
        <div id="viewer" class="studio-viewer">
            <div class="viewer-nav">
                <div class="branding-label">INTERVENCIÓN DE FOTOGRAFÍAS ANTIGUAS</div>
                <button id="close-viewer" class="close-btn">×</button>
            </div>
            <div class="viewer-content">
                <div class="f11-hint">Presiona <b>F11</b> para pantalla completa.</div>
                <div class="slider-stage" id="comparison-stage">
                    <div id="lava-container" style="position:absolute; inset:0; pointer-events:none; z-index:15;"></div>

                    <div id="slide-current" class="slide-item active">
                        <div class="comparison-wrapper">
                            <!-- Fondo (Restaurado) -->
                            <img src="" alt="" class="v-hover" draggable="false" />
                            <!-- Frente (Original) -->
                            <img src="" alt="" class="v-main" draggable="false" />
                            <div class="curtain-line" id="lava-line"></div>
                        </div>
                    </div>
                    <div id="slide-next" class="slide-item">
                        <div class="comparison-wrapper">
                            <img src="" alt="" class="v-hover" draggable="false" />
                            <img src="" alt="" class="v-main" draggable="false" />
                            <div class="curtain-line"></div>
                        </div>
                    </div>
                </div>
                <div class="viewer-meta-box">
                    <span id="viewer-title"></span>
                    <span id="viewer-date"></span>
                </div>
    </main>
</Layout>

<style>
    :root {
        --studio-bg: #050505;
        --studio-accent: #dcb14a;
        --studio-text: rgba(255,255,255,0.5);
        --sepia-tone: #3e2723;
    }

    .studio-wrapper {
        min-height: 100vh;
        background: var(--studio-bg);
        color: #fff;
        padding: 8rem 4rem 4rem;
        font-family: 'Inter', system-ui, sans-serif;
        position: relative;
    }

    .grain-overlay {
        position: fixed;
        inset: 0;
        background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');
        opacity: 0.05;
        pointer-events: none;
        z-index: 5;
        mix-blend-mode: overlay;
    }

    .studio-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 2rem 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 100;
        background: linear-gradient(to bottom, var(--studio-bg) 0%, transparent 100%);
    }

    .back-link {
        color: var(--studio-text);
        text-decoration: none;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        transition: 0.3s;
    }
    .back-link:hover { color: #fff; }

    .studio-badge {
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 2px;
        color: var(--studio-accent);
        border: 1px solid var(--studio-accent);
        padding: 0.4rem 1rem;
        background: rgba(220, 177, 74, 0.05);
    }

    .studio-header {
        max-width: 850px;
        margin-bottom: 5rem;
    }

    .pre-title {
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--studio-accent);
        margin-bottom: 1rem;
        font-weight: 800;
        opacity: 0.8;
    }

    h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 4rem;
        margin-bottom: 0.5rem;
        letter-spacing: -1px;
        line-height: 1;
    }

    .filter-navigation {
        margin-top: 1rem;
    }

    .tag-selector {
        background: transparent;
        border: none;
        border-left: 2px solid var(--studio-accent);
        color: var(--studio-accent);
        font-size: 0.65rem;
        font-weight: 900;
        letter-spacing: 3px;
        padding: 0.5rem 1rem;
        cursor: pointer;
        outline: none;
        appearance: none;
        text-transform: uppercase;
        transition: 0.3s;
    }
    .tag-selector:hover {
        background: rgba(220, 177, 74, 0.05);
    }

    p {
        color: var(--studio-text);
        line-height: 1.7;
        font-size: 1.05rem;
        max-width: 700px;
    }

    /* 🎞️ Tetris / Masonry Sheet */
    .contact-sheet {
        column-count: 3;
        column-gap: 2rem;
        width: 100%;
    }

    @media (max-width: 1200px) { .contact-sheet { column-count: 2; } }
    @media (max-width: 768px) { .contact-sheet { column-count: 1; } }

    .photo-cell {
        break-inside: avoid;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: 0.4s;
    }

    .image-box {
        position: relative;
        background: #0a0a0a;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.03);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border-radius: 4px;
    }

    .image-box img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .old-photo-effect {
        filter: sepia(0.2) contrast(1.1) brightness(0.9);
    }

    .photo-cell:hover .main-img { 
        transform: scale(1.08); 
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.7);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.5s;
        backdrop-filter: blur(8px);
        z-index: 10;
    }

    .photo-cell:hover .overlay { 
        opacity: 1; 
    }

    .view-btn {
        background: transparent;
        border: 1px solid var(--studio-accent);
        color: var(--studio-accent);
        padding: 1rem 2rem;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 3px;
        cursor: pointer;
        transition: 0.3s;
    }
    .view-btn:hover { background: var(--studio-accent); color: #000; }

    .photo-info {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding: 0 0.5rem;
    }

    .file-serie {
        font-size: 0.55rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--studio-accent);
        letter-spacing: 2px;
        opacity: 0.7;
    }

    .file-name {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: rgba(255,255,255,0.9);
        font-family: 'Cormorant Garamond', serif;
    }

    .file-meta {
        font-size: 0.6rem;
        font-family: monospace;
        color: rgba(255,255,255,0.3);
    }

    .empty-state {
        padding: 8rem 2rem;
        border: 1px dashed rgba(255,255,255,0.05);
        text-align: center;
        color: var(--studio-text);
        background: rgba(255,255,255,0.01);
    }

    /* 🔍 Studio Viewer */
    .studio-viewer {
        position: fixed;
        inset: 0;
        background: #000;
        z-index: 99999;
        display: none;
        justify-content: center;
        align-items: center;
        padding: 0;
        opacity: 0;
        transition: opacity 0.4s ease;
        user-select: none;
    }

    /* Fondo de papel forzado */
    .studio-viewer::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.9) 100%), url('/img/revista/papel.avif');
        background-size: cover;
        background-blend-mode: darken;
        opacity: 1;
        z-index: -1;
    }

    .studio-viewer.active {
        display: flex !important;
        opacity: 1;
    }

    .viewer-nav {
        position: absolute;
        top: 2rem;
        left: 2rem;
        right: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1001;
    }

    .f11-hint {
        position: fixed; /* Fuera del flujo de la imagen */
        bottom: 1.5rem;
        left: 2rem;
        font-size: 0.55rem;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.25);
        text-transform: uppercase;
        z-index: 1000;
        pointer-events: none;
    }

    .f11-hint b { color: var(--studio-accent); }

    .viewer-content {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        position: relative;
    }

    .slider-stage {
        position: relative;
        width: 100%;
        height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 1500px;
        touch-action: none; /* Prevenir scroll/drag nativo */
    }

    .slide-item {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        visibility: hidden;
        transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1), 
                    filter 1.4s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 1s ease;
        will-change: transform, opacity, filter;
    }

    .slide-item.active {
        opacity: 1;
        visibility: visible;
        transform: translateX(0) scale(1);
        filter: blur(0) brightness(1);
        z-index: 2;
    }

    .slide-item.exit-left {
        opacity: 0;
        transform: translateX(-100vw) scale(0.8) rotateY(25deg);
        filter: blur(20px) brightness(0.2);
    }

    .slide-item.enter-right {
        opacity: 0;
        transform: translateX(100vw) scale(1.2) rotateY(-25deg);
        filter: blur(20px) brightness(0.2);
    }

    .comparison-wrapper {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        max-width: 95vw;
        max-height: 90vh;
        overflow: hidden;
        cursor: default;
    }

    .v-hover {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        z-index: 1;
    }

    .v-main {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        z-index: 2;
        clip-path: inset(0 50% 0 0);
    }

    .curtain-line {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 50%;
        width: 14px;
        background: #111; /* Color apagado */
        z-index: 10;
        transform: translateX(-50%);
        pointer-events: none;
        transition: background 0.4s, box-shadow 0.4s, width 0.4s;
        clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
        display: none;
    }

    .slider-stage.has-comparison .curtain-line {
        display: block; /* Solo visible si hay par _2 */
    }

    .slider-stage.is-dragging .curtain-line {
        background: linear-gradient(to bottom, #ff0000, #ff4e00, #dcb14a, #ff4e00, #ff0000);
        background-size: 100% 200%;
        animation: lava-flow 1s infinite linear;
        box-shadow: 0 0 20px #ff0000, 0 0 40px #ff4e00;
        width: 16px;
    }

    @keyframes lava-flow {
        0% { background-position: 0% 0%; }
        100% { background-position: 0% 200%; }
    }

    .branding-label {
        font-size: 0.65rem;
        color: var(--studio-accent);
        letter-spacing: 2px;
        font-weight: 800;
        opacity: 0.8;
        text-transform: uppercase;
    }

    .viewer-meta-box {
        position: fixed; /* Fuera del flujo de la imagen */
        bottom: 1.5rem;
        right: 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.2rem;
        text-align: right;
        pointer-events: none;
        z-index: 1000;
        opacity: 0.4;
    }

    #viewer-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        color: #fff;
        font-weight: 500;
        letter-spacing: 1px;
    }

    #viewer-date {
        font-size: 0.65rem;
        color: var(--studio-accent);
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 3rem;
        cursor: pointer;
        line-height: 1;
        transition: 0.4s;
        opacity: 0.5;
    }

    .close-btn:hover {
        transform: rotate(180deg);
        color: var(--studio-accent);
        opacity: 1;
    }

    .studio-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 3rem 0;
        padding: 1.5rem 0;
        border-top: 1px solid rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.03);
        flex-wrap: wrap;
        gap: 2rem;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .filter-group .label {
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--studio-text);
        text-transform: uppercase;
    }

    .studio-select {
        background: #0a0a0a;
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 0.8rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        min-width: 280px;
        outline: none;
        transition: 0.3s;
        font-family: inherit;
    }

    .studio-select:hover {
        border-color: var(--studio-accent);
    }

    .play-btn {
        background: transparent;
        border: 1px solid var(--studio-accent);
        color: var(--studio-accent);
        padding: 0.8rem 2rem;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 3px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: 0.4s;
    }

    .play-btn.active {
        background: var(--studio-accent);
        color: #000;
    }

    .play-btn:hover {
        background: rgba(220, 177, 74, 0.1);
        box-shadow: 0 0 30px rgba(220, 177, 74, 0.2);
    }

    @media (max-width: 900px) {
        .studio-controls { flex-direction: column; align-items: flex-start; }
        .play-btn { width: 100%; justify-content: center; }
    }

    @media (max-width: 768px) {
        .studio-wrapper { padding: 6rem 2rem 2rem; }
        .contact-sheet { grid-template-columns: 1fr; }
        h1 { font-size: 2.8rem; }
    }
</style>

<script>
    // --- SELECCIÓN DE ELEMENTOS ---
    const viewer = document.getElementById('viewer');
    const viewerTitle = document.getElementById('viewer-title');
    const viewerDate = document.getElementById('viewer-date');
    const closeBtn = document.getElementById('close-viewer');
    const comparisonStage = document.getElementById('comparison-stage');
    const sessionFilter = document.getElementById('session-filter') as HTMLSelectElement;

    // --- ESTADO GLOBAL ---
    let isTransitioning = false;
    let isDragging = false;
    let currentX = 50;

    sessionFilter?.addEventListener('change', () => {
        const filter = sessionFilter.value;
        photoCells.forEach(cell => {
            const serie = (cell as HTMLElement).getAttribute('data-serie');
            if (filter === 'all' || serie === filter) {
                (cell as HTMLElement).style.display = 'flex';
            } else {
                (cell as HTMLElement).style.display = 'none';
            }
        });
    });

    // --- FUNCIÓN GLOBAL DE APERTURA ---
    (window as any).openStudioViewer = function(btn: HTMLElement) {
        const src = btn.getAttribute('data-src') || '';
        const hover = btn.getAttribute('data-hover') || '';
        const title = btn.getAttribute('data-title') || '';
        const date = btn.getAttribute('data-date') || '';
        
        updateViewer(src, hover, title, date);
        
        if (viewer) {
            viewer.style.display = 'flex';
            viewer.classList.add('active');
            document.body.classList.add('viewer-open');
        }
    };

    function updateViewer(src: string, hoverSrc: string, title: string, date: string) {
        if (isTransitioning) return;
        isTransitioning = true;

        const current = document.getElementById('slide-current');
        const next = document.getElementById('slide-next');

        if (!current || !next) {
            isTransitioning = false;
            return;
        }

        const nextMain = next.querySelector('.v-main') as HTMLImageElement;
        const nextHover = next.querySelector('.v-hover') as HTMLImageElement;

        if (!nextMain) {
            isTransitioning = false;
            return;
        }

        nextMain.src = src;

        if (hoverSrc && hoverSrc !== src && nextHover) {
            nextHover.src = hoverSrc;
            nextHover.style.display = 'block';
            comparisonStage?.classList.add('has-comparison');
            
            // Resetear posición
            currentX = 50;
            nextMain.style.clipPath = `inset(0 50% 0 0)`;
            const nextLine = next.querySelector('.curtain-line') as HTMLElement;
            if (nextLine) nextLine.style.left = `50%`;
        } else {
            if (nextHover) nextHover.style.display = 'none';
            comparisonStage?.classList.remove('has-comparison');
            nextMain.style.clipPath = 'none';
        }

        next.className = 'slide-item enter-right';
        void next.offsetWidth;

        current.classList.add('exit-left');
        current.classList.remove('active');
        next.classList.add('active');
        next.classList.remove('enter-right');

        if (viewerTitle) viewerTitle.textContent = title;
        if (viewerDate) viewerDate.textContent = date;

        setTimeout(() => {
            current.className = 'slide-item';
            const tempId = current.id;
            current.id = next.id;
            next.id = tempId;
            isTransitioning = false;
        }, 1400);
    }

    // --- MOTOR DE COMPARACIÓN (LAVA) ---
    function updateComparator(clientX: number) {
        if (!comparisonStage || !comparisonStage.classList.contains('has-comparison')) return;
        const activeItem = comparisonStage.querySelector('.slide-item.active');
        const mainImg = activeItem?.querySelector('.v-main') as HTMLElement;
        const line = activeItem?.querySelector('.curtain-line') as HTMLElement;
        
        if (!mainImg || !line) return;

        const rect = mainImg.getBoundingClientRect();
        let x = ((clientX - rect.left) / rect.width) * 100;
        currentX = Math.max(0, Math.min(100, x));

        mainImg.style.clipPath = `inset(0 ${100 - currentX}% 0 0)`;
        line.style.left = `${currentX}%`;
    }

    const startDragging = (e: PointerEvent) => {
        if (!comparisonStage?.classList.contains('has-comparison')) return;
        isDragging = true;
        comparisonStage.classList.add('is-dragging');
        (e.target as HTMLElement).setPointerCapture(e.pointerId);
        updateComparator(e.clientX);
    };

    const handlePointerMove = (e: PointerEvent) => {
        if (!isDragging) return;
        updateComparator(e.clientX);
    };

    const endDragging = (e: PointerEvent) => {
        isDragging = false;
        comparisonStage?.classList.remove('is-dragging');
        if (e && (e.target as HTMLElement).hasPointerCapture(e.pointerId)) {
            (e.target as HTMLElement).releasePointerCapture(e.pointerId);
        }
    };

    comparisonStage?.addEventListener('pointerdown', startDragging);
    comparisonStage?.addEventListener('pointermove', handlePointerMove);
    comparisonStage?.addEventListener('pointerup', endDragging);
    comparisonStage?.addEventListener('pointercancel', endDragging);
    comparisonStage?.addEventListener('pointerleave', endDragging);

    // --- SISTEMA DE GOTAS DE LAVA ---
    function spawnLavaDrop() {
        if (!isDragging || !lavaContainer || !comparisonStage?.classList.contains('has-comparison')) return;
        
        const activeLine = comparisonStage?.querySelector('.slide-item.active .curtain-line');
        if (!activeLine) return;

        const lineRect = activeLine.getBoundingClientRect();
        const drop = document.createElement('div');
        const size = Math.random() * 5 + 2;
        
        drop.style.position = 'absolute';
        drop.style.left = (lineRect.left + lineRect.width / 2) + 'px';
        drop.style.top = (lineRect.top + Math.random() * lineRect.height) + 'px';
        drop.style.width = size + 'px';
        drop.style.height = size + 'px';
        drop.style.background = Math.random() > 0.5 ? '#ff0000' : '#ff4e00';
        drop.style.borderRadius = '50%';
        drop.style.filter = 'blur(1px)';
        drop.style.boxShadow = '0 0 10px #ff0000';
        drop.style.zIndex = '1000001';
        
        lavaContainer.appendChild(drop);
        
        const anim = drop.animate([
            { transform: `translate(0, 0) scale(1)`, opacity: 1 },
            { transform: `translate(${(Math.random() - 0.5) * 40}px, ${50 + Math.random() * 100}px) scale(0)`, opacity: 0 }
        ], {
            duration: 800 + Math.random() * 600,
            easing: 'cubic-bezier(0.4, 0, 1, 1)'
        });
        
        anim.onfinish = () => drop.remove();
    }
    setInterval(spawnLavaDrop, 60);

    // --- CONTROLES ---
    closeBtn?.addEventListener('click', () => {
        isDragging = false;
        if (viewer) {
            viewer.classList.remove('active');
            viewer.style.display = 'none';
            document.body.classList.remove('viewer-open');
        }
    });

    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && viewer?.classList.contains('active')) closeBtn?.click();
    });
</script>
