---
import Layout from '../../layouts/Layout.astro';
import { getRescateFiles, getAssetUrl } from '../../conexion/directus';

const photos = await getRescateFiles();

const uniqueSeries = [...new Set(photos.map((f: any) => f.serie_name))].filter(Boolean);

// Lógica de pares _2
const mainPhotos = photos.filter((p: any) => !p.filename_download.toLowerCase().includes('_2'));
const hoverPhotos = photos.filter((p: any) => p.filename_download.toLowerCase().includes('_2'));

const galleryItems = mainPhotos.map((file: any) => {
    const baseName = file.filename_download.split('.')[0];
    // Buscador más flexible de la versión restaurada
    const hoverFile = hoverPhotos.find((h: any) => 
        h.filename_download.toLowerCase().includes(baseName.toLowerCase() + '_2') ||
        h.filename_download.toLowerCase().includes(baseName.toLowerCase() + ' _2')
    );

    return {
        id: file.id,
        title: file.title || file.filename_download,
        serie: file.serie_name,
        src: getAssetUrl(file.id, { width: 1600, format: 'webp', quality: 90 }),
        thumb: getAssetUrl(file.id, { width: 600, format: 'webp', quality: 70 }),
        hoverThumb: hoverFile ? getAssetUrl(hoverFile.id, { width: 1600, format: 'webp', quality: 90 }) : null,
        metadata: {
            type: file.type,
            size: (file.filesize / 1024 / 1024).toFixed(2) + ' MB',
            dim: `${file.width} x ${file.height}px`,
            date: file.uploaded_on ? new Date(file.uploaded_on).toLocaleDateString('es-AR') : ''
        }
    };
});
---

<Layout title="Rescate de Fotos Antiguas | Laboratorio JMX">
    <main class="studio-wrapper">
        <div class="grain-overlay"></div>
        
        <!-- Navegación -->
        <nav class="studio-nav">
            <a href="/laboratorio" class="back-link">← VOLVER AL LABORATORIO</a>
            <div class="studio-badge">PROTOCOLO: RESCATE HISTÓRICO</div>
        </nav>

        <header class="studio-header">
            <div class="pre-title">ARCHIVOS RECUPERADOS</div>
            <h1>Restauración & Memoria</h1>
            
            <div class="studio-controls">
                <div class="filter-group">
                    <span class="label">Serie Histórica:</span>
                    <select id="session-filter" class="studio-select">
                        <option value="all">Todo el Archivo</option>
                        {uniqueSeries.map(s => (
                            <option value={s}>{s}</option>
                        ))}
                    </select>
                </div>
                <button id="play-tour" class="play-btn">
                    <span class="icon">▶</span> INICIAR SECUENCIA (5s)
                </button>
            </div>

            <p>Laboratorio de recuperación química y digital. Cada imagen en esta sección ha sido sometida a un proceso de restauración de alta fidelidad para preservar su valor documental y estético.</p>
        </header>

        {galleryItems.length === 0 ? (
            <div class="empty-state">
                <p>No se encontraron capturas en la carpeta "Rescate de Fotos".</p>
                <p class="hint">Asegúrate de haber creado la carpeta en Directus y subido las imágenes.</p>
            </div>
        ) : (
            <div class="contact-sheet">
                {galleryItems.map((item, index) => (
                    <div class="photo-cell" data-index={index}>
                        <div class="image-box">
                            <img src={item.thumb} alt={item.title} loading="lazy" class="old-photo-effect main-img" />
                            <button 
                                class="view-btn" 
                                onclick="openStudioViewer(this)"
                                data-src={item.src} 
                                data-hover={item.hoverSrc} 
                                data-title={item.title} 
                                data-date={item.date}
                            >
                                <span class="icon">🔍</span> ANALIZAR OBRA
                            </button>
                        </div>
                        <div class="photo-info">
                            <span class="file-serie">{item.serie}</span>
                            <span class="file-name">{item.title}</span>
                            <span class="file-meta">{item.metadata.dim} | {item.metadata.size}</span>
                        </div>
                    </div>
                ))}
            </div>
        )}

        <!-- Visor de Alta Fidelidad -->
        <div id="viewer" class="studio-viewer">
            <div class="viewer-nav">
                <div></div> <!-- Espacio para mantener el botón de cierre a la derecha -->
                <button id="close-viewer" class="close-btn">×</button>
            </div>
            <div class="viewer-content">
                <div class="f11-hint">Presiona <b>F11</b> para pantalla completa.</div>
                <div class="slider-stage" id="comparison-stage">
                    <div id="lava-container" style="position:absolute; inset:0; pointer-events:none; z-index:15;"></div>
                    <div class="slider-labels">
                        <span class="label-original">ARCHIVO ORIGINAL</span>
                        <span class="label-restored">RESTAURACIÓN DIGITAL</span>
                    </div>
                    <div id="slide-current" class="slide-item active">
                        <div class="comparison-wrapper">
                            <!-- Fondo (Restaurado) -->
                            <img src="" alt="" class="v-hover" />
                            <!-- Frente (Original) -->
                            <img src="" alt="" class="v-main" />
                            <div class="curtain-line" id="lava-line"></div>
                        </div>
                    </div>
                    <div id="slide-next" class="slide-item">
                        <div class="comparison-wrapper">
                            <img src="" alt="" class="v-hover" />
                            <img src="" alt="" class="v-main" />
                            <div class="curtain-line"></div>
                        </div>
                    </div>
                </div>
                <div class="viewer-meta-box">
                    <span id="viewer-title"></span>
                    <span id="viewer-date"></span>
                </div>
    </main>
</Layout>

<style>
    :root {
        --studio-bg: #050505;
        --studio-accent: #dcb14a;
        --studio-text: rgba(255,255,255,0.5);
        --sepia-tone: #3e2723;
    }

    .studio-wrapper {
        min-height: 100vh;
        background: var(--studio-bg);
        color: #fff;
        padding: 8rem 4rem 4rem;
        font-family: 'Inter', system-ui, sans-serif;
        position: relative;
    }

    .grain-overlay {
        position: fixed;
        inset: 0;
        background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');
        opacity: 0.05;
        pointer-events: none;
        z-index: 5;
        mix-blend-mode: overlay;
    }

    .studio-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 2rem 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 100;
        background: linear-gradient(to bottom, var(--studio-bg) 0%, transparent 100%);
    }

    .back-link {
        color: var(--studio-text);
        text-decoration: none;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        transition: 0.3s;
    }
    .back-link:hover { color: #fff; }

    .studio-badge {
        font-size: 0.6rem;
        font-weight: 900;
        letter-spacing: 2px;
        color: var(--studio-accent);
        border: 1px solid var(--studio-accent);
        padding: 0.4rem 1rem;
        background: rgba(220, 177, 74, 0.05);
    }

    .studio-header {
        max-width: 850px;
        margin-bottom: 5rem;
    }

    .pre-title {
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--studio-accent);
        margin-bottom: 1rem;
        font-weight: 800;
        opacity: 0.8;
    }

    h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 4rem;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
        line-height: 1;
    }

    p {
        color: var(--studio-text);
        line-height: 1.7;
        font-size: 1.05rem;
        max-width: 700px;
    }

    /* 🎞️ Contact Sheet Grid */
    .contact-sheet {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 3rem;
    }

    .photo-cell {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        transition: 0.4s;
    }

    .image-box {
        position: relative;
        aspect-ratio: 4/5;
        background: #0a0a0a;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.03);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .image-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .old-photo-effect {
        filter: sepia(0.2) contrast(1.1) brightness(0.9);
    }

    .photo-cell:hover .main-img { 
        transform: scale(1.08); 
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.7);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.5s;
        backdrop-filter: blur(8px);
        z-index: 10;
    }

    .photo-cell:hover .overlay { 
        opacity: 1; 
    }

    .view-btn {
        background: transparent;
        border: 1px solid var(--studio-accent);
        color: var(--studio-accent);
        padding: 1rem 2rem;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 3px;
        cursor: pointer;
        transition: 0.3s;
    }
    .view-btn:hover { background: var(--studio-accent); color: #000; }

    .photo-info {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding: 0 0.5rem;
    }

    .file-serie {
        font-size: 0.55rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--studio-accent);
        letter-spacing: 2px;
        opacity: 0.7;
    }

    .file-name {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: rgba(255,255,255,0.9);
        font-family: 'Cormorant Garamond', serif;
    }

    .file-meta {
        font-size: 0.6rem;
        font-family: monospace;
        color: rgba(255,255,255,0.3);
    }

    .empty-state {
        padding: 8rem 2rem;
        border: 1px dashed rgba(255,255,255,0.05);
        text-align: center;
        color: var(--studio-text);
        background: rgba(255,255,255,0.01);
    }

    /* 🔍 Studio Viewer */
    .studio-viewer {
        position: fixed;
        inset: 0;
        background: #000;
        z-index: 99999;
        display: none;
        justify-content: center;
        align-items: center;
        padding: 0;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .studio-viewer.active {
        display: flex !important;
        opacity: 1;
    }

    .viewer-nav {
        position: absolute;
        top: 2rem;
        left: 2rem;
        right: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1001;
    }

    .f11-hint {
        position: fixed; /* Fuera del flujo de la imagen */
        bottom: 1.5rem;
        left: 2rem;
        font-size: 0.55rem;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.25);
        text-transform: uppercase;
        z-index: 1000;
        pointer-events: none;
    }

    .f11-hint b { color: var(--studio-accent); }

    .viewer-content {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        position: relative;
    }

    .slider-stage {
        position: relative;
        width: 100%;
        height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 1500px;
    }

    .slide-item {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        visibility: hidden;
        transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1), 
                    filter 1.4s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 1s ease;
        will-change: transform, opacity, filter;
    }

    .slide-item.active {
        opacity: 1;
        visibility: visible;
        transform: translateX(0) scale(1);
        filter: blur(0) brightness(1);
        z-index: 2;
    }

    .slide-item.exit-left {
        opacity: 0;
        transform: translateX(-100vw) scale(0.8) rotateY(25deg);
        filter: blur(20px) brightness(0.2);
    }

    .slide-item.enter-right {
        opacity: 0;
        transform: translateX(100vw) scale(1.2) rotateY(-25deg);
        filter: blur(20px) brightness(0.2);
    }

    .comparison-wrapper {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        max-width: 95vw;
        max-height: 90vh;
        overflow: hidden;
        cursor: default;
    }

    .v-hover {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        z-index: 1;
    }

    .v-main {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        z-index: 2;
        clip-path: inset(0 50% 0 0);
    }

    .curtain-line {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 50%;
        width: 14px;
        background: rgba(255, 255, 255, 0.1);
        z-index: 10;
        transform: translateX(-50%);
        pointer-events: none;
        transition: background 0.4s, box-shadow 0.4s, width 0.4s;
        clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
        display: none; /* Oculto por defecto */
    }

    .slider-stage.has-comparison .curtain-line {
        display: block; /* Solo visible si hay par _2 */
    }

    .slider-stage.is-dragging .curtain-line {
        background: linear-gradient(to bottom, #ff0000, #ff4e00, #dcb14a, #ff4e00, #ff0000);
        background-size: 100% 200%;
        animation: lava-flow 1s infinite linear;
        box-shadow: 0 0 20px #ff0000, 0 0 40px #ff4e00;
        width: 16px;
    }

    @keyframes lava-flow {
        0% { background-position: 0% 0%; }
        100% { background-position: 0% 200%; }
    }

    .slider-labels {
        position: absolute;
        top: 2rem;
        left: 2rem;
        right: 2rem;
        display: flex;
        justify-content: space-between;
        z-index: 25;
        pointer-events: none;
        opacity: 0;
        transition: 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .slider-stage.has-comparison:hover .slider-labels {
        opacity: 1;
    }

    .label-original, .label-restored {
        font-family: 'Inter', sans-serif;
        font-size: 0.5rem;
        letter-spacing: 2px;
        font-weight: 800;
        color: #000;
        background: #fff;
        padding: 0.5rem 1.2rem;
        border-radius: 100px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        text-transform: uppercase;
    }

    .viewer-meta-box {
        position: fixed; /* Fuera del flujo de la imagen */
        bottom: 1.5rem;
        right: 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.2rem;
        text-align: right;
        pointer-events: none;
        z-index: 1000;
        opacity: 0.4;
    }

    #viewer-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        color: #fff;
        font-weight: 500;
        letter-spacing: 1px;
    }

    #viewer-date {
        font-size: 0.65rem;
        color: var(--studio-accent);
        font-family: monospace;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .close-btn {
        background: none;
        border: none;
        color: #fff;
        font-size: 3rem;
        cursor: pointer;
        line-height: 1;
        transition: 0.4s;
        opacity: 0.5;
    }

    .close-btn:hover {
        transform: rotate(180deg);
        color: var(--studio-accent);
        opacity: 1;
    }

    .studio-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 3rem 0;
        padding: 1.5rem 0;
        border-top: 1px solid rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.03);
        flex-wrap: wrap;
        gap: 2rem;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .filter-group .label {
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: var(--studio-text);
        text-transform: uppercase;
    }

    .studio-select {
        background: #0a0a0a;
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        padding: 0.8rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        min-width: 280px;
        outline: none;
        transition: 0.3s;
        font-family: inherit;
    }

    .studio-select:hover {
        border-color: var(--studio-accent);
    }

    .play-btn {
        background: transparent;
        border: 1px solid var(--studio-accent);
        color: var(--studio-accent);
        padding: 0.8rem 2rem;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 3px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: 0.4s;
    }

    .play-btn.active {
        background: var(--studio-accent);
        color: #000;
    }

    .play-btn:hover {
        background: rgba(220, 177, 74, 0.1);
        box-shadow: 0 0 30px rgba(220, 177, 74, 0.2);
    }

    @media (max-width: 900px) {
        .studio-controls { flex-direction: column; align-items: flex-start; }
        .play-btn { width: 100%; justify-content: center; }
    }

    @media (max-width: 768px) {
        .studio-wrapper { padding: 6rem 2rem 2rem; }
        .contact-sheet { grid-template-columns: 1fr; }
        h1 { font-size: 2.8rem; }
    }
</style>

<script>
    let isTransitioning = false;

    // --- FUNCIÓN GLOBAL DE APERTURA (Infalible) ---
    (window as any).openStudioViewer = function(btn: HTMLElement) {
        const src = btn.getAttribute('data-src') || '';
        const hover = btn.getAttribute('data-hover') || '';
        const title = btn.getAttribute('data-title') || '';
        const date = btn.getAttribute('data-date') || '';
        
        console.log("[MASTER] Abriendo:", title);
        updateViewer(src, hover, title, date);
        
        const v = document.getElementById('viewer');
        if (v) {
            v.style.display = 'flex';
            v.style.zIndex = '1000000';
            v.classList.add('active');
            document.body.classList.add('viewer-open');
        } else {
            alert("Error: No se encontró el visor #viewer en el DOM");
        }
    };

    function updateViewer(src: string, hoverSrc: string, title: string, date: string) {
        if (isTransitioning) return;
        isTransitioning = true;

        const current = document.getElementById('slide-current');
        const next = document.getElementById('slide-next');
        const stage = document.getElementById('comparison-stage');

        if (!current || !next) {
            isTransitioning = false;
            return;
        }

        const nextMain = next.querySelector('.v-main') as HTMLImageElement;
        const nextHover = next.querySelector('.v-hover') as HTMLImageElement;

        if (!nextMain) {
            isTransitioning = false;
            return;
        }

        nextMain.src = src;

        if (hoverSrc && hoverSrc !== src && nextHover) {
            nextHover.src = hoverSrc;
            nextHover.style.display = 'block';
            stage?.classList.add('has-comparison');
            // Resetear clip-path y posición de la línea al abrir
            currentX = 50;
            const nextMain = next.querySelector('.v-main') as HTMLElement;
            const nextLine = next.querySelector('.curtain-line') as HTMLElement;
            if (nextMain) nextMain.style.clipPath = `inset(0 50% 0 0)`;
            if (nextLine) nextLine.style.left = `50%`;
        } else {
            if (nextHover) nextHover.style.display = 'none';
            stage?.classList.remove('has-comparison');
            const nextMain = next.querySelector('.v-main') as HTMLElement;
            if (nextMain) nextMain.style.clipPath = 'none';
        }

        next.className = 'slide-item enter-right';
        void next.offsetWidth;

        current.classList.add('exit-left');
        current.classList.remove('active');
        next.classList.add('active');
        next.classList.remove('enter-right');

        if (viewerTitle) viewerTitle.textContent = title;
        if (viewerDate) viewerDate.textContent = date;

        setTimeout(() => {
            current.className = 'slide-item';
            const tempId = current.id;
            current.id = next.id;
            next.id = tempId;
            isTransitioning = false;
        }, 1400);
    }

    let isDragging = false;
    let currentX = 50;

    comparisonStage?.addEventListener('mousedown', (e) => {
        if (!comparisonStage.classList.contains('has-comparison')) return;
        isDragging = true;
        comparisonStage.classList.add('is-dragging');
        updateComparator(e.clientX);
    });

    window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        updateComparator(e.clientX);
    });

    window.addEventListener('mouseup', () => {
        isDragging = false;
        comparisonStage?.classList.remove('is-dragging');
    });

    // Soporte Táctil
    comparisonStage?.addEventListener('touchstart', (e) => {
        if (!comparisonStage.classList.contains('has-comparison')) return;
        isDragging = true;
        comparisonStage.classList.add('is-dragging');
        updateComparator(e.touches[0].clientX);
    });

    window.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        updateComparator(e.touches[0].clientX);
    });

    window.addEventListener('touchend', () => {
        isDragging = false;
        comparisonStage?.classList.remove('is-dragging');
    });

    function updateComparator(clientX: number) {
        if (!comparisonStage) return;
        const activeItem = comparisonStage.querySelector('.slide-item.active');
        const mainImg = activeItem?.querySelector('.v-main') as HTMLElement;
        const hoverImg = activeItem?.querySelector('.v-hover') as HTMLElement;
        const line = activeItem?.querySelector('.curtain-line') as HTMLElement;
        
        if (!mainImg || !line) return;

        const rect = mainImg.getBoundingClientRect();
        let x = ((clientX - rect.left) / rect.width) * 100;
        currentX = Math.max(0, Math.min(100, x));

        mainImg.style.clipPath = `inset(0 ${100 - currentX}% 0 0)`;
        line.style.left = `${currentX}%`;
    }

    // --- SISTEMA DE GOTAS DE LAVA ---
    const lavaContainer = document.getElementById('lava-container');
    
    function spawnLavaDrop() {
        if (!isDragging || !lavaContainer || !comparisonStage?.classList.contains('has-comparison')) return;
        
        const activeLine = comparisonStage?.querySelector('.slide-item.active .curtain-line');
        if (!activeLine) return;

        const lineRect = activeLine.getBoundingClientRect();
        const drop = document.createElement('div');
        const size = Math.random() * 5 + 2;
        
        drop.style.position = 'absolute';
        drop.style.left = (lineRect.left + lineRect.width / 2) + 'px';
        drop.style.top = (lineRect.top + Math.random() * lineRect.height) + 'px';
        drop.style.width = size + 'px';
        drop.style.height = size + 'px';
        drop.style.background = Math.random() > 0.5 ? '#ff0000' : '#ff4e00';
        drop.style.borderRadius = '50%';
        drop.style.filter = 'blur(1px)';
        drop.style.boxShadow = '0 0 10px #ff0000';
        drop.style.zIndex = '1000001';
        
        lavaContainer.appendChild(drop);
        
        const anim = drop.animate([
            { transform: `translate(0, 0) scale(1)`, opacity: 1 },
            { transform: `translate(${(Math.random() - 0.5) * 40}px, ${50 + Math.random() * 100}px) scale(0)`, opacity: 0 }
        ], {
            duration: 800 + Math.random() * 600,
            easing: 'cubic-bezier(0.4, 0, 1, 1)'
        });
        
        anim.onfinish = () => drop.remove();
    }

    setInterval(spawnLavaDrop, 60);

    // --- MOTOR DE APERTURA MAESTRO (Delegación Global) ---
    document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.view-btn');
        if (!btn) return;

        e.preventDefault();
        const src = btn.getAttribute('data-src') || '';
        const hover = btn.getAttribute('data-hover') || '';
        const title = btn.getAttribute('data-title') || '';
        const date = btn.getAttribute('data-date') || '';

        console.log("[JS] Clic detectado en:", title);
        
        updateViewer(src, hover, title, date);
        
        if (viewer) {
            viewer.style.display = 'flex';
            viewer.classList.add('active');
            document.body.classList.add('viewer-open');
            console.log("[JS] Visor activado correctamente.");
        } else {
            console.error("[JS] Error: No se encontró el elemento #viewer");
        }
    });

    closeBtn?.addEventListener('click', () => {
        stopTour();
        if (viewer) {
            viewer.classList.remove('active');
            viewer.style.display = 'none';
            document.body.classList.remove('viewer-open');
        }
    });

    // --- Lógica de Filtrado ---
    const sessionFilter = document.getElementById('session-filter') as HTMLSelectElement;
    const photoCells = document.querySelectorAll('.photo-cell');

    sessionFilter?.addEventListener('change', () => {
        const filter = sessionFilter.value;

        photoCells.forEach(cell => {
            const serie = (cell as HTMLElement).querySelector('.file-serie')?.textContent;
            if (filter === 'all' || serie === filter) {
                (cell as HTMLElement).style.display = 'flex';
            } else {
                (cell as HTMLElement).style.display = 'none';
            }
        });
        
        if (tourInterval) { stopTour(); startTour(); }
    });

    // --- Lógica de Tour ---
    const playTourBtn = document.getElementById('play-tour');
    let tourInterval: any = null;
    let currentTourIndex = 0;

    function startTour() {
        const visiblePhotos = Array.from(photoCells).filter(p => (p as HTMLElement).style.display !== 'none');
        if (visiblePhotos.length === 0) return;

        playTourBtn?.classList.add('active');
        playTourBtn!.innerHTML = '<span class="icon">⏹</span> DETENER SECUENCIA';
        viewerContent?.classList.add('tour-active');
        
        const firstBtn = visiblePhotos[0].querySelector('.view-btn') as HTMLElement;
        firstBtn?.click();

        tourInterval = setInterval(() => {
            currentTourIndex = (currentTourIndex + 1) % visiblePhotos.length;
            const photo = visiblePhotos[currentTourIndex];
            const viewBtn = photo.querySelector('.view-btn') as HTMLElement;
            
            const src = viewBtn.getAttribute('data-src') || '';
            const hover = viewBtn.getAttribute('data-hover') || '';
            const title = viewBtn.getAttribute('data-title') || '';
            const date = viewBtn.getAttribute('data-date') || '';
            
            updateViewer(src, hover, title, date);
        }, 5000);
    }

    function stopTour() {
        if (tourInterval) clearInterval(tourInterval);
        tourInterval = null;
        playTourBtn?.classList.remove('active');
        playTourBtn!.innerHTML = '<span class="icon">▶</span> INICIAR SECUENCIA (5s)';
        viewerContent?.classList.remove('tour-active');
        viewer?.classList.remove('active');
        document.body.style.overflow = 'auto';
    }

    playTourBtn?.addEventListener('click', () => {
        if (tourInterval) stopTour();
        else {
            currentTourIndex = 0;
            startTour();
        }
    });

    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            if (tourInterval) stopTour();
            else {
                viewer?.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }
    });

    // --- Lógica del Slider de Comparación ---
    const comparisonStage = document.getElementById('comparison-stage');
    const curtainLine = document.querySelector('.curtain-line') as HTMLElement;
    let isDragging = false;

    const startDragging = (e: MouseEvent | TouchEvent) => {
        isDragging = true;
        comparisonStage?.classList.add('is-dragging');
        handleMove(e instanceof MouseEvent ? e.clientX : e.touches[0].clientX);
    };

    const stopDragging = () => {
        isDragging = false;
        comparisonStage?.classList.remove('is-dragging');
    };

    const handleMove = (clientX: number) => {
        if (!isDragging) return;
        
        const activeWrapper = comparisonStage?.querySelector('.slide-item.active .comparison-wrapper') as HTMLElement;
        const mainImg = activeWrapper?.querySelector('.v-main') as HTMLElement;
        if (!activeWrapper || !mainImg) return;

        const rect = mainImg.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) * 100;
        const boundedX = Math.max(0, Math.min(100, x));

        activeWrapper.style.setProperty('--curtain-pos', `${boundedX}%`);
        
        if (curtainLine) {
            curtainLine.style.left = `${rect.left + (rect.width * boundedX / 100)}px`;
            curtainLine.style.opacity = '1';
        }

        const hoverImg = activeWrapper.querySelector('.v-hover') as HTMLElement;
        if (hoverImg) {
            hoverImg.style.width = `${rect.width}px`;
        }
    };

    comparisonStage?.addEventListener('mousedown', (e) => startDragging(e));
    window.addEventListener('mouseup', stopDragging);
    window.addEventListener('mousemove', (e) => handleMove(e.clientX));

    // Soporte Touch
    comparisonStage?.addEventListener('touchstart', (e) => startDragging(e));
    window.addEventListener('touchend', stopDragging);
    window.addEventListener('touchmove', (e) => handleMove(e.touches[0].clientX));

    function resetCurtain() {
        setTimeout(() => {
            const activeWrapper = comparisonStage?.querySelector('.slide-item.active .comparison-wrapper') as HTMLElement;
            const mainImg = activeWrapper?.querySelector('.v-main') as HTMLElement;
            if (!activeWrapper || !mainImg) return;

            const rect = mainImg.getBoundingClientRect();
            const initialX = 50;

            if (curtainLine) {
                curtainLine.style.left = `${rect.left + (rect.width * initialX / 100)}px`;
                curtainLine.style.opacity = '1';
            }
            
            activeWrapper.style.setProperty('--curtain-pos', `${initialX}%`);
            const hoverImg = activeWrapper.querySelector('.v-hover') as HTMLElement;
            if (hoverImg) {
                hoverImg.style.width = `${rect.width}px`;
            }
        }, 200);
    }
</script>
