---
// d:\web_javiermix\JAVIERMIX-AR-0504\src\pages\galeria\index.astro
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getSeries, getCatalogoFiles } from '@conexion/directus';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

// 🏺 Datos
const seriesListRaw = await getSeries();
const seriesList = seriesListRaw.map(s => ({
    ...s,
    coverUrl: getOptimizedImageURL(s.coverId, { width: 1000, format: 'avif', quality: 90 })
}));

const artworksRaw = await getCatalogoFiles();
const artworks = artworksRaw.map(file => ({
    id: file.id,
    title: file.title || file.filename_download.split('.')[0],
    serie: file.serie_name || 'Sin Serie',
    thumb: getOptimizedImageURL(file.id, { width: 800, format: 'avif', quality: 85 })
}));
---

<Layout
  title="Galería | Javier Mix"
  description="Buscador de arte fotográfico de Javier Mix."
  url="/galeria"
>
    <Header currentPath="/galeria" />

	<main class="gallery-clean-container">
		<!-- 🔍 HERO BUSCADOR ESTILO GOOGLE -->
		<header class="google-hero">
            <h1 class="gallery-title">Explorar Archivo</h1>
			<div class="search-portal-wrapper">
				<input type="text" id="gallery-search-input" placeholder="Busca por tema, color, textura..." autocomplete="off">
                <button id="btn-toggle-series" class="series-toggle">
                    <span class="dot"></span>
                    SERIES
                </button>
			</div>
		</header>

		<!-- 🏛️ CONTENIDO (Default: Obras Recientes / Resultados) -->
		<div id="content-view" class="viewport">
            <div id="results-info" class="results-meta" style="display: none;">
                <p>Mostrando <span id="mode-label">OBRAS</span>: <span id="res-count">0</span> resultados</p>
            </div>

            <!-- GRILLA MASONRY -->
            <div id="gallery-grid" class="masonry-grid">
                {artworks.slice(0, 15).map((art) => (
                    <a href={`/obra/${art.id}`} class="grid-item" data-tilt>
                        <img src={art.thumb} alt={art.title} loading="lazy" />
                        <div class="item-overlay">
                            <span class="art-title">{art.title}</span>
                            <span class="art-serie">{art.serie}</span>
                        </div>
                    </a>
                ))}
            </div>
		</div>

        <script id="artworks-data" type="application/json" is:inline set:html={JSON.stringify(artworks)} />
        <script id="series-data" type="application/json" is:inline set:html={JSON.stringify(seriesList)} />
	</main>

	<Footer />
</Layout>

<style>
/* 🌑 ESTILO LIMPIO Y FUNCIONAL */
.gallery-clean-container {
    background: #000;
    color: #fff;
    min-height: 100vh;
    padding-bottom: 5rem;
    font-family: 'Inter', sans-serif;
}

/* 🔍 GOOGLE HERO */
.google-hero {
    padding: 12rem 5% 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.gallery-title { font-size: 3rem; font-weight: 200; font-family: var(--font-primary); margin-bottom: 3rem; letter-spacing: -1px; }

.search-portal-wrapper {
    width: 100%;
    max-width: 800px;
    position: relative;
    display: flex;
    align-items: center;
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50px;
    padding: 0.5rem 0.5rem 0.5rem 2rem;
    transition: all 0.3s ease;
}

.search-portal-wrapper:focus-within {
    background: #181818;
    border-color: var(--color-accent);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

#gallery-search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    padding: 1rem 0;
    font-size: 1.1rem;
    outline: none;
}

.series-toggle {
    background: #222;
    border: 1px solid rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.6);
    padding: 0.8rem 1.5rem;
    border-radius: 40px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    transition: all 0.3s;
}

.series-toggle .dot { width: 6px; height: 6px; background: rgba(255,255,255,0.2); border-radius: 50%; transition: 0.3s; }
.series-toggle.active { background: rgba(197, 160, 89, 0.1); border-color: var(--color-accent); color: #fff; }
.series-toggle.active .dot { background: var(--color-accent); box-shadow: 0 0 10px var(--color-accent); }

/* 🖼️ GRID MASONRY (RESPETO AL FORMATO) */
.viewport { max-width: 1800px; margin: 0 auto; padding: 0 5%; }
.results-meta { text-align: center; margin-bottom: 4rem; font-size: 0.8rem; color: rgba(255,255,255,0.4); letter-spacing: 2px; }
#mode-label { color: var(--color-accent); }

.masonry-grid {
    column-count: 3;
    column-gap: 2rem;
}

.grid-item {
    break-inside: avoid;
    margin-bottom: 2rem;
    display: block;
    text-decoration: none;
    position: relative;
    background: #080808;
    transition: transform 0.1s ease-out;
}

.grid-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.4s;
}

.item-overlay {
    padding: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.05);
}

.art-title { font-size: 0.8rem; font-weight: 700; color: #fff; display: block; letter-spacing: 1px; text-transform: uppercase; }
.art-serie { font-size: 0.6rem; color: var(--color-accent); font-weight: 800; display: block; margin-top: 0.4rem; letter-spacing: 1px; }

/* 📱 MOBILE */
@media (max-width: 1024px) { .masonry-grid { column-count: 2; } }
@media (max-width: 768px) { .masonry-grid { column-count: 1; } .gallery-title { font-size: 2.2rem; } .search-portal-wrapper { border-radius: 10px; } }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('gallery-search-input') as HTMLInputElement;
    const btnToggle = document.getElementById('btn-toggle-series');
    const grid = document.getElementById('gallery-grid');
    const resultsInfo = document.getElementById('results-info');
    const resCount = document.getElementById('res-count');
    const modeLabel = document.getElementById('mode-label');

    const artworks = JSON.parse(document.getElementById('artworks-data')?.innerHTML || '[]');
    const series = JSON.parse(document.getElementById('series-data')?.innerHTML || '[]');

    let searchMode = 'WORKS'; // WORKS or SERIES

    // 💡 EFECTO 3D SUTIL
    const applyTilt = () => {
        const items = document.querySelectorAll('.grid-item');
        items.forEach((item: any) => {
            item.addEventListener('mousemove', (e: MouseEvent) => {
                const r = item.getBoundingClientRect();
                const x = e.clientX - r.left; const y = e.clientY - r.top;
                const rx = (y - r.height/2) / 25; const ry = (r.width/2 - x) / 25;
                item.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.02, 1.02, 1.02)`;
                item.style.zIndex = "10";
            });
            item.addEventListener('mouseleave', () => {
                item.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                item.style.zIndex = "1";
            });
        });
    };
    applyTilt();

    // 🔘 TOGGLE MODO
    btnToggle?.addEventListener('click', () => {
        searchMode = (searchMode === 'WORKS') ? 'SERIES' : 'WORKS';
        btnToggle.classList.toggle('active');
        if (modeLabel) modeLabel.textContent = searchMode === 'SERIES' ? 'SERIES' : 'OBRAS';
        triggerSearch();
    });

    const triggerSearch = () => {
        const term = searchInput.value.toLowerCase().trim();
        
        if (term === '' && searchMode === 'WORKS') {
            resultsInfo!.style.display = 'none';
            // Mostrar los iniciales (re-renderizar artworks[0..15])
            renderGrid(artworks.slice(0, 15), 'WORK');
            return;
        }

        resultsInfo!.style.display = 'block';
        const filtered = (searchMode === 'WORKS') 
            ? artworks.filter((a:any) => a.title.toLowerCase().includes(term))
            : series.filter((s:any) => s.name.toLowerCase().includes(term));

        if (resCount) resCount.textContent = filtered.length.toString();
        renderGrid(filtered, searchMode === 'WORKS' ? 'WORK' : 'SERIE');
    };

    const renderGrid = (items: any[], type: 'WORK' | 'SERIE') => {
        grid!.innerHTML = items.map((item: any) => {
            const url = type === 'WORK' ? `/obra/${item.id}` : `/galeria/${item.id}`;
            const img = type === 'WORK' ? item.thumb : item.coverUrl;
            const title = type === 'WORK' ? item.title : item.name;
            const sub = type === 'WORK' ? item.serie : 'COLECCIÓN COMPLETA';
            return `
                <a href="${url}" class="grid-item">
                    <img src="${img}" alt="${title}" loading="lazy" />
                    <div class="item-overlay">
                        <span class="art-title">${title}</span>
                        <span class="art-serie">${sub}</span>
                    </div>
                </a>
            `;
        }).join('');
        applyTilt();
    };

    searchInput?.addEventListener('input', triggerSearch);
  });
</script>
