---
// d:\web_javiermix\JAVIERMIX-AR-0504\src\pages\galeria\index.astro
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getSeries, getCatalogoFiles, DirectusManager } from '@conexion/directus';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

// 🏺 Series for default view
const seriesFromAPI = await getSeries();
const seriesList = seriesFromAPI.map(s => ({
    ...s,
    coverUrl: getOptimizedImageURL(s.coverId, { width: 1000, format: 'avif', quality: 90 })
}));

const featuredSeries = seriesList.slice(0, 3);
const otherSeries = seriesList.slice(3);

// 🔍 Load all artworks for GLOBAL search
const allArtworksRaw = await getCatalogoFiles();
const allArtworks = allArtworksRaw.map(file => ({
    id: file.id,
    title: file.title || file.filename_download.split('.')[0],
    description: file.description || '',
    tags: file.tags || [],
    serie: file.serie_name || 'Sin Serie',
    thumb: getOptimizedImageURL(file.id, { width: 800, format: 'avif', quality: 80 })
}));
---

<Layout
  title="Galería Curada | Javier Mix"
  description="Explore el universo visual de Javier Mix a través de sus series exclusivas."
  url="/galeria"
  image={seriesList[0]?.coverUrl}
>
    
    <Header currentPath="/galeria" />

	<main class="gallery-immersive-master">
        <canvas id="canvas-particles" class="particles-bg"></canvas>
        <div class="glow-overlay"></div>

		<!-- 🔍 BUSCADOR DE PRECISIÓN -->
		<header class="immersive-hero">
            <div class="hero-context">
                <span class="fine-label">FINE ART SEARCH</span>
                <h1 class="portal-title">Explorar <span class="gold-dot">.</span> Archivo</h1>
            </div>
            
			<div class="portal-search-container">
                <div class="search-input-box">
				    <input type="text" id="gallery-search-input" placeholder="Busca atmósfera, color o tema..." autocomplete="off">
                    <div class="search-accent-glow"></div>
                </div>
                <button id="btn-mode-series" class="mode-toggle">
                    <span class="mode-label">SERIES</span>
                    <div class="mode-indicator"></div>
                </button>
			</div>
		</header>

		<!-- 🏛️ VISTA DE SERIES (Modo Default) -->
		<div id="view-series" class="gallery-view active">
            <section class="kinetic-triptych">
                <div class="section-label">
                    <span class="label-text">ÚLTIMAS SERIES</span>
                    <div class="label-line"></div>
                </div>
                
                <div class="triptych-container">
                    {featuredSeries.length > 0 ? featuredSeries.map((serie, index) => (
                        <a href={`/galeria/${serie.id}`} class="kinetic-card" data-tilt>
                            <div class="card-visual">
                                <img src={serie.coverUrl} alt={serie.name} class="visual-img" />
                                <div class="visual-vignette"></div>
                            </div>
                            <div class="card-content">
                                <div class="card-meta">
                                    <span class="m-count">{serie.count} OBRAS</span>
                                    <div class="m-line"></div>
                                </div>
                                <h3 class="card-name">{serie.name}</h3>
                                <span class="explore-link">VER COLECCIÓN</span>
                            </div>
                        </a>
                    )) : (
                        <div class="empty-state-lux">
                            <p>Sincronizando Archivo Maestro...</p>
                            <div class="loader-line"></div>
                        </div>
                    )}
                </div>
            </section>

            {otherSeries.length > 0 && (
                <section class="discovery-ribbon">
                    <div class="ribbon-outer">
                        <div class="ribbon-inner">
                            {[...otherSeries, ...otherSeries].map((serie) => (
                                <a href={`/galeria/${serie.id}`} class="ribbon-item">
                                    <div class="item-frame">
                                        <img src={serie.coverUrl} alt={serie.name} />
                                        <div class="item-overlay">
                                            <span class="it-name">{serie.name}</span>
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                </section>
            )}
		</div>

        <!-- 🕵️ RESULTADOS MASONRY (Respeto al formato) -->
        <div id="view-results" class="gallery-view" style="display: none;">
            <div class="results-layout">
                <header class="results-header">
                    <p class="results-count">FILTRANDO POR <span class="accent" id="search-mode-text">OBRAS</span>: <span id="res-count">0</span> COINCIDENCIAS</p>
                </header>
                
                <!-- 🖼️ MASONRY NATURAL GRID (Sin Recortes) -->
                <div id="results-grid" class="natural-masonry-grid">
                    <!-- Inyección dinámica -->
                </div>
            </div>
        </div>

        <script id="artworks-data" type="application/json" is:inline set:html={JSON.stringify(allArtworks)} />
        <script id="series-data" type="application/json" is:inline set:html={JSON.stringify(seriesList)} />
	</main>

	<Footer />
</Layout>

<style>
/* 🌑 CORE DESIGN */
.gallery-immersive-master { background: #080808; min-height: 100vh; position: relative; overflow-x: hidden; }
.particles-bg { position: fixed; inset: 0; z-index: 1; pointer-events: none; opacity: 0.3; }
.glow-overlay { position: fixed; top: -20%; left: -10%; width: 140%; height: 140%; background: radial-gradient(circle at 50% 50%, rgba(197,160,89,0.03) 0%, transparent 60%); pointer-events: none; z-index: 2; }

/* 🔍 BUSCADOR INTEGRADO */
.immersive-hero { position: relative; z-index: 10; padding: 12rem 2rem 6rem; display: flex; flex-direction: column; align-items: center; }
.hero-context { text-align: center; margin-bottom: 5rem; }
.fine-label { font-size: 0.6rem; letter-spacing: 8px; color: var(--color-accent); font-weight: 800; display: block; margin-bottom: 1.5rem; }
.portal-title { font-size: clamp(3rem, 7vw, 4.5rem); font-family: var(--font-primary); color: #fff; font-weight: 200; }
.gold-dot { color: var(--color-accent); }

.portal-search-container {
    display: flex;
    gap: 1.5rem;
    width: 100%;
    max-width: 900px;
    align-items: stretch;
}

.search-input-box {
    flex: 1;
    position: relative;
}

#gallery-search-input {
    width: 100%;
    padding: 1.8rem 2.5rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 200;
    transition: all 0.5s ease;
}

#gallery-search-input:focus {
    background: rgba(255,255,255,0.04);
    border-color: var(--color-accent);
    outline: none;
}

.mode-toggle {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.4);
    padding: 0 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    transition: all 0.4s ease;
}

.mode-toggle.active {
    border-color: var(--color-accent);
    color: #fff;
    background: rgba(197, 160, 89, 0.05);
}

.mode-label { font-size: 0.65rem; letter-spacing: 3px; font-weight: 800; }
.mode-indicator { width: 4px; height: 4px; border-radius: 50%; background: currentColor; transition: transform 0.4s; }
.mode-toggle.active .mode-indicator { background: var(--color-accent); transform: scale(1.5); box-shadow: 0 0 10px var(--color-accent); }

/* 🏛️ TRÍPTICO */
.kinetic-triptych { max-width: 1700px; margin: 0 auto; padding: 0 4%; position: relative; z-index: 10; }
.section-label { display: flex; align-items: center; gap: 2rem; margin-bottom: 4rem; }
.label-text { font-size: 0.7rem; letter-spacing: 5px; color: rgba(255,255,255,0.3); font-weight: 800; }
.label-line { height: 1px; flex: 1; background: linear-gradient(to right, rgba(255,255,255,0.05), transparent); }

.triptych-container { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
.kinetic-card { position: relative; height: 75vh; background: #000; overflow: hidden; text-decoration: none; }
.visual-img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.7); transition: transform 2s cubic-bezier(0.165, 0.84, 0.44, 1); }
.kinetic-card:hover .visual-img { transform: scale(1.05); filter: brightness(0.9); }
.card-content { position: absolute; inset: 0; padding: 4rem; display: flex; flex-direction: column; justify-content: flex-end; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); }
.card-name { font-size: 2.5rem; font-family: var(--font-primary); color: #fff; font-weight: 200; margin-bottom: 1rem; }
.explore-link { font-size: 0.6rem; letter-spacing: 2px; color: var(--color-accent); font-weight: 800; }

/* 🖼️ NATURAL MASONRY GRID (Sin Recortes) */
.results-layout { max-width: 1800px; margin: 0 auto; padding: 4rem 4% 10rem; }
.results-header { margin-bottom: 5rem; text-align: center; }
.results-count { font-size: 0.7rem; letter-spacing: 4px; color: rgba(255,255,255,0.3); font-weight: 800; text-transform: uppercase; }
.accent { color: var(--color-accent); }

.natural-masonry-grid {
    column-count: 3;
    column-gap: 2rem;
}

.masonry-item {
    break-inside: avoid;
    margin-bottom: 2rem;
    display: block;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    background: #111;
    transition: all 0.5s ease;
}

.masonry-item img {
    width: 100%;
    height: auto; /* IMPORTANTE: Respeta la altura natural */
    display: block;
    filter: brightness(0.8);
    transition: all 0.8s ease;
}

.masonry-item:hover img { filter: brightness(1); transform: scale(1.03); }

.masonry-info {
    padding: 1.5rem;
    background: #000;
}

.m-title { color: #fff; font-size: 0.75rem; letter-spacing: 2px; font-weight: 700; text-transform: uppercase; margin-bottom: 0.3rem; display: block; }
.m-serie { color: var(--color-accent); font-size: 0.55rem; letter-spacing: 1.5px; font-weight: 800; text-transform: uppercase; }

/* 🎡 RIBBON */
.discovery-ribbon { margin-top: 10rem; padding: 4rem 0; overflow: hidden; }
.ribbon-inner { display: flex; gap: 2rem; width: max-content; animation: ribbonScroll 120s linear infinite; }
@keyframes ribbonScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.ribbon-item { width: 350px; height: 250px; display: block; overflow: hidden; position: relative; }
.ribbon-item img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.4); }

/* 📱 RESPONSIVE */
@media (max-width: 1200px) { .natural-masonry-grid { column-count: 2; } }
@media (max-width: 1024px) {
    .triptych-container { grid-template-columns: 1fr; }
    .kinetic-card { height: 50vh; }
    .portal-search-container { flex-direction: column; }
    .mode-toggle { padding: 1.5rem; }
}
@media (max-width: 768px) { .natural-masonry-grid { column-count: 1; } }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // 🌌 PARTICULAS
    const canvas = document.getElementById('canvas-particles') as HTMLCanvasElement;
    const ctx = canvas?.getContext('2d');
    if (canvas && ctx) {
        let p: any[] = [];
        const res = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
        window.addEventListener('resize', res); res();
        for(let i=0;i<50;i++) p.push({x:Math.random()*canvas.width, y:Math.random()*canvas.height, s:Math.random()*1, sx:Math.random()*0.2-0.1, sy:Math.random()*0.2-0.1});
        const draw = () => {
            ctx.clearRect(0,0,canvas.width,canvas.height); ctx.fillStyle="rgba(197,160,89,0.3)";
            p.forEach(i=>{ i.x+=i.sx; i.y+=i.sy; if(i.x>canvas.width)i.x=0; if(i.y>canvas.height)i.y=0; ctx.beginPath(); ctx.arc(i.x,i.y,i.s,0,Math.PI*2); ctx.fill(); });
            requestAnimationFrame(draw);
        };
        draw();
    }

    // 🕵️ MOTOR DE BÚSQUEDA HÍBRIDO
    const searchInput = document.getElementById('gallery-search-input') as HTMLInputElement;
    const btnMode = document.getElementById('btn-mode-series');
    const viewSeries = document.getElementById('view-series');
    const viewResults = document.getElementById('view-results');
    const resultsGrid = document.getElementById('results-grid');
    const resCount = document.getElementById('res-count');
    const modeText = document.getElementById('search-mode-text');

    const artworks = JSON.parse(document.getElementById('artworks-data')?.innerHTML || '[]');
    const series = JSON.parse(document.getElementById('series-data')?.innerHTML || '[]');

    let searchMode = 'WORKS'; // 'WORKS' o 'SERIES'

    btnMode?.addEventListener('click', () => {
        searchMode = (searchMode === 'WORKS') ? 'SERIES' : 'WORKS';
        btnMode.classList.toggle('active');
        if (modeText) modeText.textContent = searchMode === 'SERIES' ? 'SERIES' : 'OBRAS';
        triggerSearch();
    });

    const triggerSearch = () => {
        const term = searchInput.value.toLowerCase().trim();
        if (term === '' && searchMode === 'WORKS') {
            viewSeries!.style.display = 'block';
            viewResults!.style.display = 'none';
            return;
        }

        viewSeries!.style.display = 'none';
        viewResults!.style.display = 'block';

        if (searchMode === 'WORKS') {
            const filtered = artworks.filter((a: any) => 
                a.title.toLowerCase().includes(term) || a.description.toLowerCase().includes(term) || a.tags.some((t:string)=>t.toLowerCase().includes(term))
            );
            renderResults(filtered, 'WORK');
        } else {
            // BUSCAR SOLO SERIES
            const filtered = series.filter((s: any) => s.name.toLowerCase().includes(term));
            renderResults(filtered, 'SERIE');
        }
    };

    const renderResults = (items: any[], type: 'WORK' | 'SERIE') => {
        if (resCount) resCount.textContent = items.length.toString();
        
        resultsGrid!.innerHTML = items.map((item: any) => {
            if (type === 'WORK') {
                return `
                    <a href="/obra/${item.id}" class="masonry-item">
                        <img src="${item.thumb}" alt="${item.title}" loading="lazy" />
                        <div class="masonry-info">
                            <span class="m-title">${item.title}</span>
                            <span class="m-serie">${item.serie}</span>
                        </div>
                    </a>
                `;
            } else {
                return `
                    <a href="/galeria/${item.id}" class="masonry-item">
                        <img src="${item.coverUrl}" alt="${item.name}" loading="lazy" />
                        <div class="masonry-info">
                            <span class="m-title">${item.name}</span>
                            <span class="m-serie">COLECCIÓN COMPLETA</span>
                        </div>
                    </a>
                `;
            }
        }).join('');
    };

    searchInput?.addEventListener('input', triggerSearch);
  });
</script>
