---
// h:\Javiermix_web_v2\frontend\/galeria/\index.astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getSeries, getCatalogoFiles } from '../../conexion/directus';
import { getOptimizedImageURL } from '../../utils/media';

export const prerender = false;

// 🏺 Series for default view
const seriesFromAPI = await getSeries();
const seriesList = seriesFromAPI.map(s => ({
    ...s,
    coverUrl: getOptimizedImageURL(s.coverId, { width: 800, format: 'avif' })
}));

// 🔍 [NEW] Load all artworks metadata for GLOBAL search
const allArtworksRaw = await getCatalogoFiles();
const allArtworks = allArtworksRaw.map(file => ({
    id: file.id,
    title: file.title || file.filename_download.split('.')[0],
    description: file.description || '',
    tags: file.tags || [],
    serie: file.serie_name || 'Sin Serie',
    thumb: getOptimizedImageURL(file.id, { width: 600, format: 'avif', quality: 70 })
}));
---

<Layout
  title="Galería Fine Art | Javier Mix"
  description="Explore las series fotográficas de Javier Mix."
  url="/galeria"
  image={seriesList[0]?.coverUrl}
>
    
    <Header currentPath="/galeria" />

	<main class="gallery-container" style="padding-top: 5rem;">
		<header class="gallery-header">
			<h1 class="gallery-title">Fine Art Portfolio</h1>
			<p class="gallery-subtitle">Selección Exclusiva de Obras Disponibles</p>
		</header>

		<div class="gallery-search-container" id="gallery-search-overlay">
			<div class="search-input-wrapper" style="position: relative;">
				<input type="text" id="gallery-search-input" placeholder="Buscar por color, tema o título..." aria-label="Buscar obras">
			</div>
		</div>

		<div id="view-series" class="gallery-view active">
			<section class="series-snap-container" style="max-width: 1400px; margin: 0 auto; padding: 0 2rem;">
				{seriesList.length === 0 ? (
					<div class="empty-state">No se encontraron colecciones</div>
				) : (
					seriesList.map((serie) => (
						<a href={`/galeria/${serie.id}`} class="series-card fade-in-content">
							<div class="series-card-bg" style={`background-image: url('${serie.coverUrl}');`}></div>
							<div class="series-card-content">
								<h2 class="series-title">{serie.name}</h2>
								<p class="series-count">{serie.count} Obras</p>
								<span class="series-cta">Explorar Serie &rarr;</span>
							</div>
						</a>
					))
				)}
			</section>
		</div>

        <!-- 🕵️ GLOBAL SEARCH RESULTS VIEW -->
        <div id="view-results" class="gallery-view" style="display: none; padding: 0 2rem; max-width: 1600px; margin: 0 auto;">
          <div class="results-info" style="margin-bottom: 3rem; color: var(--color-travertine-mid); font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase;">
             Resultados para: <span id="search-term-display" style="color: var(--color-accent); font-weight: 700;"></span>
          </div>
          <div id="results-grid" class="artworks-results-grid">
             <!-- Renderizado Dinámico -->
          </div>
          <div id="no-results" style="display: none; text-align: center; padding: 8rem 0; color: var(--color-travertine-mid);">
             <i class="fas fa-search" style="font-size: 3rem; opacity: 0.1; margin-bottom: 2rem; display: block;"></i>
             <p style="letter-spacing: 4px; font-size: 1.1rem; font-style: italic;">No encontramos obras con esos términos.</p>
          </div>
        </div>

        <!-- 📦 Inyección de Datos para el Motor de Búsqueda -->
        <script id="artworks-data" type="application/json" is:inline set:html={JSON.stringify(allArtworks)} />
	</main>

	<Footer />
</Layout>

<style>
.gallery-container {
    background-color: var(--color-onyx-deep);
    min-height: 100vh;
}

.gallery-header {
    text-align: center;
    padding: 6rem 1rem 4rem;
}

.gallery-title {
    font-size: var(--text-h1);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    font-family: var(--font-primary);
    color: var(--color-white);
    font-weight: 600;
}

.gallery-subtitle {
    color: var(--color-text-muted);
    font-family: var(--font-secondary);
    font-size: 1.1rem;
    letter-spacing: 1px;
}

.gallery-search-container {
    text-align: center;
    margin: 2rem auto;
    width: 100%;
    max-width: 800px;
    position: relative;
    padding: 0 1rem;
}

#gallery-search-input {
    width: 100%;
    padding: 1.25rem 2rem;
    border-radius: 50px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--color-white);
    font-family: var(--font-secondary);
    font-size: 1rem;
    backdrop-filter: blur(12px);
    transition: var(--transition-premium);
}

#gallery-search-input:focus {
    background: var(--color-onyx-charcoal);
    border-color: var(--color-accent);
    outline: none;
}

.series-snap-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); 
    gap: 3rem;
    padding-bottom: 6rem;
}

.series-card {
    position: relative;
    display: block;
    height: 500px;
    overflow: hidden;
    text-decoration: none;
    transition: var(--transition-premium);
    background-color: var(--color-onyx-charcoal);
}

.series-card-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.series-card:hover .series-card-bg {
    transform: scale(1.1);
}

.series-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 3rem;
    background: linear-gradient(to top, var(--color-onyx-deep) 0%, transparent 100%);
    color: var(--color-white);
    transform: translateY(10px);
    transition: var(--transition-premium);
}

.series-card:hover .series-card-content {
    transform: translateY(0);
}

.series-title {
    font-family: var(--font-primary);
    font-size: 2.8rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-white);
    font-weight: 600;
    line-height: 1;
}

.series-count {
    font-family: var(--font-secondary);
    font-size: 0.8rem;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 600;
}

.series-cta {
    font-family: var(--font-secondary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-white);
    opacity: 0; 
    transform: translateX(-10px);
    transition: var(--transition-premium);
    display: inline-block;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 4px;
}

.series-card:hover .series-cta {
    opacity: 1;
    transform: translateX(0);
}

.artworks-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    animation: fadeIn 0.6s forwards;
}

.artwork-result-card {
    text-decoration: none;
    display: block;
    transition: var(--transition-premium);
    position: relative;
    border-bottom: 1px solid rgba(255,255,255,0.05); /* Sutil línea inferior */
    padding-bottom: 1rem;
}

.artwork-result-card:hover { transform: translateY(-5px); }

.artwork-thumb-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-onyx-charcoal);
    margin-bottom: 1rem;
}

.artwork-thumb { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    transition: transform 0.8s; 
}
.artwork-result-card:hover .artwork-thumb { transform: scale(1.05); }

.artwork-result-info { 
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
}
.artwork-result-title { font-family: var(--font-primary); font-size: 1.6rem; color: var(--color-white); margin: 0; line-height: 1.2; }
.artwork-result-serie { font-size: 0.6rem; color: var(--color-accent); text-transform: uppercase; letter-spacing: 2px; font-weight: 700; opacity: 0.8; }

@media (max-width: 768px) {
    .series-snap-container {
        display: block;
        height: auto;
    }
    .series-card { height: 60vh; margin-bottom: 2rem !important; }
    .artworks-results-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('gallery-search-input') as HTMLInputElement;
    const viewSeries = document.getElementById('view-series');
    const viewResults = document.getElementById('view-results');
    const resultsGrid = document.getElementById('results-grid');
    const noResults = document.getElementById('no-results');
    const termDisplay = document.getElementById('search-term-display');
    
    // Parse index data
    const dataEl = document.getElementById('artworks-data');
    const artworks = dataEl ? JSON.parse(dataEl.innerHTML) : [];
    
    searchInput?.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase().trim();
      
      if (term === '') {
        viewSeries!.style.display = 'block';
        viewResults!.style.display = 'none';
        return;
      }

      // GLOBAL SEARCH LOGIC (Title, Desc, Tags)
      const filtered = artworks.filter((a: any) => {
        const inTitle = a.title.toLowerCase().includes(term);
        const inDesc = a.description.toLowerCase().includes(term);
        const inTags = a.tags.some((t: string) => t.toLowerCase().includes(term));
        return inTitle || inDesc || inTags;
      });

      // Show Results
      viewSeries!.style.display = 'none';
      viewResults!.style.display = 'block';
      termDisplay!.textContent = `"${term}"`;
      
      if (filtered.length === 0) {
        resultsGrid!.innerHTML = '';
        noResults!.style.display = 'block';
      } else {
        noResults!.style.display = 'none';
        resultsGrid!.innerHTML = filtered.map((a: any) => `
            <a href="/obra/${a.id}" class="artwork-result-card">
                <div class="artwork-thumb-container">
                    <img src="${a.thumb}" alt="${a.title}" class="artwork-thumb" loading="lazy" />
                </div>
                <div class="artwork-result-info">
                   <h3 class="artwork-result-title">${a.title}</h3>
                   <span class="artwork-result-serie">${a.serie}</span>
                </div>
            </a>
        `).join('');
      }
    });
  });
</script>
