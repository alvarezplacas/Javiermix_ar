---
// d:\web_javiermix\JAVIERMIX-AR-0504\src\pages\galeria\index.astro
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getSeries, getCatalogoFiles, DirectusManager } from '@conexion/directus';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

// 🏺 Series for default view
const seriesFromAPI = await getSeries();
const seriesList = seriesFromAPI.map(s => ({
    ...s,
    coverUrl: getOptimizedImageURL(s.coverId, { width: 800, format: 'avif' })
}));

// Separación para el nuevo layout
const featuredSeries = seriesList.slice(0, 3);
const otherSeries = seriesList.slice(3);

// 🔍 Load all artworks for GLOBAL search
const allArtworksRaw = await getCatalogoFiles();
const allArtworks = allArtworksRaw.map(file => ({
    id: file.id,
    title: file.title || file.filename_download.split('.')[0],
    description: file.description || '',
    tags: file.tags || [],
    serie: file.serie_name || 'Sin Serie',
    thumb: getOptimizedImageURL(file.id, { width: 600, format: 'avif', quality: 70 })
}));
---

<Layout
  title="Galería Fine Art | Javier Mix"
  description="Explore las series fotográficas de Javier Mix."
  url="/galeria"
  image={seriesList[0]?.coverUrl}
>
    
    <Header currentPath="/galeria" />

	<main class="gallery-master-container">
		<!-- 🔍 HERO BUSCADOR (Estilo Minimalista) -->
		<header class="minimal-search-hero">
            <div class="hero-labels">
                <span class="eyebrow">FINE ART PORTFOLIO</span>
                <h1 class="minimal-title">Javier Mix <span class="gold-dot">.</span> Galería</h1>
            </div>
			<div class="search-box-wrapper">
				<input type="text" id="gallery-search-input" placeholder="Busca atmósfera, color o tema..." aria-label="Buscar obras">
                <i class="fas fa-search search-icon"></i>
			</div>
		</header>

		<!-- 🏛️ VISTA DE SERIES (Default) -->
		<div id="view-series" class="gallery-view active">
			
            <!-- 🎨 SECCIÓN 1: TRÍPTICO DESTACADO -->
            <section class="featured-triptych-section">
                <div class="section-header">
                    <h2 class="section-title">SERIES DESTACADAS</h2>
                    <div class="title-line"></div>
                </div>
                
                <div class="triptych-grid">
                    {featuredSeries.length > 0 ? featuredSeries.map((serie, index) => (
                        <a href={`/galeria/${serie.id}`} class={`triptych-card fade-in-up`} style={`animation-delay: ${index * 0.2}s`}>
                            <div class="card-image-wrapper">
                                <img src={serie.coverUrl} alt={serie.name} class="card-bg" loading="lazy" />
                                <div class="card-overlay"></div>
                            </div>
                            <div class="card-info">
                                <span class="card-count">{serie.count} Obras</span>
                                <h3 class="card-title">{serie.name}</h3>
                                <span class="card-cta">EXPLORAR SERIE</span>
                            </div>
                        </a>
                    )) : (
                        <div class="empty-state">No hay series destacadas disponibles.</div>
                    )}
                </div>
            </section>

            <!-- 🎡 SECCIÓN 2: DISCOVERY CAROUSEL (Infinite Marquee) -->
            {otherSeries.length > 0 && (
                <section class="discovery-marquee-section">
                    <div class="section-header centered">
                        <h2 class="section-title">EXPLORACIÓN CONTINUA</h2>
                    </div>
                    
                    <div class="marquee-container">
                        <div class="marquee-track">
                            {/* Duplicamos el contenido para el efecto infinito */}
                            {[...otherSeries, ...otherSeries, ...otherSeries].map((serie) => (
                                <a href={`/galeria/${serie.id}`} class="marquee-item">
                                    <div class="marquee-img-wrapper">
                                        <img src={serie.coverUrl} alt={serie.name} loading="lazy" />
                                        <div class="marquee-overlay">
                                            <span class="m-title">{serie.name}</span>
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                </section>
            )}
		</div>

        <!-- 🕵️ RESULTADOS DE BÚSQUEDA (Global) -->
        <div id="view-results" class="gallery-view" style="display: none;">
          <div class="results-container">
              <div class="results-info">
                 Resultados para: <span id="search-term-display"></span>
              </div>
              <div id="results-grid" class="v8-artworks-grid">
                 <!-- Renderizado Dinámico -->
              </div>
              <div id="no-results" style="display: none;">
                 <i class="fas fa-search search-empty-icon"></i>
                 <p class="empty-msg">No encontramos obras con esos términos.</p>
              </div>
          </div>
        </div>

        <script id="artworks-data" type="application/json" is:inline set:html={JSON.stringify(allArtworks)} />
	</main>

	<Footer />
</Layout>

<style>
/* 🌑 CONTENEDOR MAESTRO */
.gallery-master-container {
    background-color: var(--color-onyx-deep);
    min-height: 100vh;
    padding-bottom: 8rem;
}

/* 🔍 HERO BUSCADOR */
.minimal-search-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10rem 2rem 6rem;
    text-align: center;
}
.hero-labels { margin-bottom: 3.5rem; }
.eyebrow { font-size: 0.65rem; letter-spacing: 5px; color: var(--color-accent); font-weight: 700; margin-bottom: 1rem; display: block; }
.minimal-title { font-size: clamp(2.5rem, 6vw, 4rem); font-family: var(--font-primary); color: var(--color-white); font-weight: 300; }
.gold-dot { color: var(--color-accent); font-weight: 900; }

.search-box-wrapper {
    width: 100%;
    max-width: 700px;
    position: relative;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}
.search-box-wrapper:focus-within { transform: scale(1.02); }

#gallery-search-input {
    width: 100%;
    padding: 1.5rem 4rem 1.5rem 2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: var(--color-white);
    font-size: 1.1rem;
    font-weight: 200;
    backdrop-filter: blur(20px);
    transition: all 0.4s ease;
}
#gallery-search-input:focus {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--color-accent);
    outline: none;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}
.search-icon { position: absolute; right: 2rem; top: 50%; transform: translateY(-50%); color: var(--color-accent); font-size: 1.2rem; opacity: 0.6; }

/* 🎨 SECCIÓN DESTACADOS (TRÍPTICO) */
.featured-triptych-section { max-width: 1600px; margin: 0 auto; padding: 0 4%; }
.section-header { display: flex; align-items: center; gap: 2rem; margin-bottom: 3.5rem; }
.section-header.centered { justify-content: center; text-align: center; }
.section-title { font-size: 0.75rem; letter-spacing: 4px; color: var(--color-travertine-mid); font-weight: 700; }
.title-line { height: 1px; flex: 1; background: linear-gradient(to right, rgba(255,255,255,0.1), transparent); }

.triptych-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
}

.triptych-card {
    position: relative;
    height: 65vh;
    min-height: 500px;
    overflow: hidden;
    text-decoration: none;
    display: block;
}

.card-image-wrapper { width: 100%; height: 100%; position: relative; }
.card-bg { width: 100%; height: 100%; object-fit: cover; transition: transform 2s cubic-bezier(0.165, 0.84, 0.44, 1); filter: brightness(0.7); }
.card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, var(--color-onyx-deep) 0%, transparent 60%); opacity: 0.8; }

.card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 3rem;
    color: var(--color-white);
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}

.card-count { font-size: 0.6rem; letter-spacing: 3px; color: var(--color-accent); font-weight: 700; display: block; margin-bottom: 1rem; }
.card-title { font-size: 2.2rem; font-family: var(--font-primary); font-weight: 300; margin-bottom: 1.5rem; line-height: 1.1; }
.card-cta { font-size: 0.65rem; letter-spacing: 2px; font-weight: 800; border-bottom: 1px solid var(--color-accent); padding-bottom: 0.3rem; opacity: 0; transition: opacity 0.4s ease; }

.triptych-card:hover .card-bg { transform: scale(1.08); filter: brightness(0.9); }
.triptych-card:hover .card-info { transform: translateY(0); }
.triptych-card:hover .card-cta { opacity: 1; }

/* 🎡 DISCOVERY CAROUSEL (MARQUEE) */
.discovery-marquee-section { margin-top: 10rem; overflow: hidden; padding: 4rem 0; }
.marquee-container { position: relative; width: 100%; margin-top: 2rem; }
.marquee-track {
    display: flex;
    width: max-content;
    gap: 2rem;
    animation: scrollInfinite 60s linear infinite;
}
.marquee-track:hover { animation-play-state: paused; }

@keyframes scrollInfinite {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); }
}

.marquee-item { width: 350px; height: 250px; display: block; text-decoration: none; position: relative; overflow: hidden; }
.marquee-img-wrapper { width: 100%; height: 100%; }
.marquee-img-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; filter: grayscale(0.4); }
.marquee-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; opacity: 1; transition: opacity 0.4s ease; }
.marquee-item:hover img { transform: scale(1.1); filter: grayscale(0); }
.marquee-item:hover .marquee-overlay { background: rgba(0,0,0,0.2); }
.m-title { color: #fff; font-size: 0.7rem; letter-spacing: 4px; font-weight: 700; text-transform: uppercase; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }

/* 🕵️ RESULTADOS BÚSQUEDA */
.results-container { max-width: 1600px; margin: 0 auto; padding: 0 4%; }
.results-info { margin-bottom: 3rem; color: var(--color-travertine-mid); font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; }
#search-term-display { color: var(--color-accent); font-weight: 700; }

.v8-artworks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2.5rem;
    padding-bottom: 5rem;
}

.search-empty-icon { font-size: 3rem; opacity: 0.1; margin-bottom: 2rem; display: block; text-align: center; width: 100%; color: var(--color-white); }
.empty-msg { text-align: center; letter-spacing: 4px; font-size: 1.1rem; font-style: italic; color: var(--color-travertine-mid); }

/* 📱 RESPONSIVE */
@media (max-width: 1024px) {
    .triptych-grid { grid-template-columns: 1fr; gap: 3rem; }
    .triptych-card { height: 50vh; }
    .minimal-search-hero { padding: 8rem 1.5rem 4rem; }
    .featured-triptych-section { padding: 0 6%; }
}
</style>

<script>
  import { getOptimizedImageURL } from '@utils/media';

  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('gallery-search-input') as HTMLInputElement;
    const viewSeries = document.getElementById('view-series');
    const viewResults = document.getElementById('view-results');
    const resultsGrid = document.getElementById('results-grid');
    const noResults = document.getElementById('no-results');
    const termDisplay = document.getElementById('search-term-display');
    
    // Data injection
    const dataEl = document.getElementById('artworks-data');
    const artworks = dataEl ? JSON.parse(dataEl.innerHTML) : [];
    
    searchInput?.addEventListener('input', (e) => {
      const originalValue = (e.target as HTMLInputElement).value;
      const term = originalValue.toLowerCase().trim();
      
      if (term === '') {
        viewSeries!.style.display = 'block';
        viewResults!.style.display = 'none';
        return;
      }

      const filtered = artworks.filter((a: any) => {
        return a.title.toLowerCase().includes(term) || 
               a.description.toLowerCase().includes(term) || 
               a.tags.some((t: string) => t.toLowerCase().includes(term));
      });

      // Show Results
      viewSeries!.style.display = 'none';
      viewResults!.style.display = 'block';
      termDisplay!.textContent = `"${term}"`;
      
      if (filtered.length === 0) {
        resultsGrid!.innerHTML = '';
        noResults!.style.display = 'block';
      } else {
        noResults!.style.display = 'none';
        resultsGrid!.innerHTML = filtered.map((a: any, i: number) => `
            <a href="/obra/${a.id}" class="v8-artwork-card" style="animation-delay: ${i * 0.05}s">
                <div class="v8-artwork-img-container">
                    <img src="${a.thumb}" alt="${a.title}" class="v8-artwork-img" loading="lazy" />
                </div>
                <div class="v8-overlay-info">
                   <h3 class="v8-title">${a.title}</h3>
                   <span class="v8-serie">${a.serie}</span>
                </div>
            </a>
        `).join('');
      }
    });
  });
</script>
