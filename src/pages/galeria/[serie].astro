---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getSerieDetails } from '@conexion/directus';
import { getArtworkLikes } from '@conexion/likes';
import { getOptimizedImageURL } from '@utils/media';

export const prerender = false;

const { serie } = Astro.params; // Folder ID
const { name, items } = await getSerieDetails(serie as string);

// Lógica: JMX_xxxx.ext es principal, JMX_xxxx_2.ext es variante hover
const mainImages = items.filter((f: any) => {
	const low = f.filename_download.toLowerCase();
	return !low.includes('_2.') && !low.includes(' 2.');
});

const artworks = await Promise.all(mainImages.map(async (img: any) => {
	const baseName = img.filename_download.split('.')[0].toLowerCase();
	const hoverVariant = items.find((f: any) => f.filename_download.toLowerCase().startsWith(`${baseName}_2.`));
    const likes = await getArtworkLikes(img.id);
	
	return {
		id: img.id,
		title: img.title || "Obra Javier Mix",
		mainUrl: getOptimizedImageURL(img.id),
		hoverUrl: hoverVariant ? getOptimizedImageURL(hoverVariant.id) : null,
        likes
	};
}));

const serieName = name;
const coverOg = artworks[0]?.mainUrl || undefined;
---

<Layout
  title={`${serieName} | Colección Fine Art`}
  description={`Descubrí la serie "${serieName}" de Javier Mix: ${artworks.length} obras de fotografía Fine Art de autor.`}
  url={`/galeria/${Astro.params.serie}`}
  image={coverOg}
>
	<Header currentPath="/galeria" />

	<div class="immersive-header" data-artworks={JSON.stringify(artworks.map(a => a.mainUrl))}>
		<div class="slideshow-container">
			<div class="slide-layer active" id="slide-1"></div>
			<div class="slide-layer" id="slide-2"></div>
		</div>
		
		<div class="header-overlay-mask"></div>

		<header class="serie-header-content">
			<a href="/galeria" class="back-link">
				<span class="icon">&larr;</span>
				<span class="label">Volver a Colecciones</span>
			</a>
			<h1 class="serie-title">{name}</h1>
			<p class="serie-meta">
				<span class="count">{artworks.length}</span>
				<span class="label">Obras Disponibles</span>
			</p>
		</header>
	</div>

	<article class="serie-content-container">
		<section class="masonry-grid" id="series-masonry">
			{artworks.map((artwork) => (
				<div class="gallery-artwork-card" data-id={artwork.id}>
					<a href={`/obra/${artwork.id}`} class="artwork-link">
						<div class="artwork-figure">
							<img src={artwork.mainUrl} alt={""} class="artwork-img main-img" loading="lazy" />
							{artwork.hoverUrl && (
								<img src={artwork.hoverUrl} alt={""} class="artwork-img hover-img" loading="lazy" />
							)}
						</div>
					</a>
					
					<div class="artwork-info-overlay">
						<div class="interaction-bar">
							<button class="like-btn" data-artwork-id={artwork.id}>
								<svg class="heart-svg" viewBox="0 0 24 24">
									<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
								</svg>
								<span class="likes-count">{artwork.likes}</span>
							</button>
							<a href={`/obra/${artwork.id}`} class="view-obra">VER OBRA</a>
						</div>
					</div>
				</div>
			))}
		</section>
	</article>

	<Footer />
</Layout>

<style>
.immersive-header {
	position: relative;
	width: 100%;
	height: 80vh;
	background-color: #000;
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	text-align: center;
}

.slideshow-container {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	z-index: 1;
}

.slide-layer {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background-size: cover;
	background-position: center;
	opacity: 0;
	transition: opacity 1.5s cubic-bezier(0.4, 0, 0.2, 1);
	filter: brightness(0.4) contrast(1.1);
}

.slide-layer.active {
	opacity: 1;
}

.header-overlay-mask {
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	height: 100%;
	/* Fundido hacia abajo mejorado para quedar detrás de la grilla */
	background: linear-gradient(to bottom, rgba(5, 5, 5, 0.1) 0%, rgba(5, 5, 5, 0.6) 70%, #050505 100%);
	z-index: 2;
}

.serie-header-content {
	position: relative;
	z-index: 10;
}

.back-link {
	display: inline-flex;
	align-items: center;
	gap: 0.75rem;
	margin-bottom: 2rem;
	color: rgba(255, 255, 255, 0.5);
	text-decoration: none;
	transition: all 0.4s ease;
}

.back-link:hover {
	color: var(--color-accent);
}

.serie-title {
	font-family: var(--font-primary);
	font-size: clamp(3rem, 7vw, 6rem);
	font-weight: 300;
	color: #fff;
	text-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.serie-meta {
	font-family: var(--font-secondary);
	font-size: 0.8rem;
	text-transform: uppercase;
	letter-spacing: 4px;
	color: var(--color-accent);
	font-weight: 700;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 1rem;
}

.serie-content-container {
	max-width: 1600px;
	margin: -10vh auto 0; /* Más solapamiento para potenciar el fundido */
	position: relative;
	z-index: 20;
	padding: 0 5% 10rem;
}

.masonry-grid {
	column-count: 3;
	column-gap: 3rem;
}

.gallery-artwork-card {
	break-inside: avoid;
	margin-bottom: 3rem;
	position: relative;
	overflow: hidden;
	display: flex;
	flex-direction: column;
}

.artwork-figure {
	position: relative;
	width: 100%;
}

.artwork-img {
	width: 100%;
	height: auto;
	display: block;
	transition: transform 0.8s ease, opacity 0.6s ease;
}

.artwork-img.hover-img {
	position: absolute;
	top: 0;
	left: 0;
	opacity: 0;
	z-index: 2;
}

.gallery-artwork-card:hover .artwork-img.hover-img {
	opacity: 1;
}

.artwork-info-overlay {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	height: 100%;
	background: rgba(0,0,0,0.3);
	z-index: 5;
	display: flex;
	align-items: center;
	justify-content: center;
	opacity: 0;
	transition: opacity 0.4s ease;
}

.interaction-bar {
	display: flex;
	flex-direction: column;
	align-items: flex-start;
	gap: 1.5rem;
    padding-left: 2rem;
}

.like-btn {
	background: none;
	border: none;
	color: #fff;
	cursor: pointer;
	display: flex;
	align-items: center;
	gap: 0.6rem;
	transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	z-index: 10;
    padding: 8px;
}

.like-btn:hover {
	transform: scale(1.15);
}

.like-btn.liked {
	color: #FF2D55; /* Rojo Premium */
}

.heart-svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    transition: all 0.4s ease;
}

.like-btn.liked .heart-svg {
    fill: #FF2D55;
    stroke: #FF2D55;
    filter: drop-shadow(0 0 5px rgba(255, 45, 85, 0.5));
}

.likes-count {
	font-family: var(--font-secondary);
	font-size: 0.9rem;
	font-weight: 500;
    letter-spacing: 1px;
}

/* Animación de latido al cliquear */
@keyframes heartBeat {
  0% { transform: scale(1); }
  25% { transform: scale(1.3); }
  50% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

.like-btn.animating {
  animation: heartBeat 0.4s ease-out;
}

.view-obra {
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(10px);
	color: #fff;
	font-size: 0.7rem;
	text-transform: uppercase;
	letter-spacing: 2px;
	border: 1px solid rgba(255,255,255,0.4);
	padding: 0.6rem 1.5rem;
	transition: all 0.4s ease;
    text-decoration: none;
}

.view-obra:hover {
    background: #fff;
    color: #000;
}

.gallery-artwork-card:hover .artwork-info-overlay {
	opacity: 1;
}

@media (max-width: 1024px) {
	.masonry-grid { column-count: 2; }
}

@media (max-width: 768px) {
	.masonry-grid { column-count: 1; }
	.serie-title { font-size: 2.2rem; }
}
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		const header = document.querySelector('.immersive-header');
		if (!header) return;
		const artworks = JSON.parse(header.getAttribute('data-artworks') || '[]');
		const slide1 = document.getElementById('slide-1');
		const slide2 = document.getElementById('slide-2');
		let currentSlide = 0;
		let activeLayer = 1;

		if (slide1 && artworks.length > 0) slide1.style.backgroundImage = `url(${artworks[0]})`;
		
		if (artworks.length > 1) {
			setInterval(() => {
				currentSlide = (currentSlide + 1) % artworks.length;
				const nextUrl = artworks[currentSlide];
				if (activeLayer === 1) {
					if (slide2) { slide2.style.backgroundImage = `url(${nextUrl})`; slide2.classList.add('active'); }
					if (slide1) slide1.classList.remove('active');
					activeLayer = 2;
				} else {
					if (slide1) { slide1.style.backgroundImage = `url(${nextUrl})`; slide1.classList.add('active'); }
					if (slide2) slide2.classList.remove('active');
					activeLayer = 1;
				}
			}, 3000);
		}

        // Lógica de Likes
        const likeButtons = document.querySelectorAll('.like-btn');
        likeButtons.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const artworkId = btn.getAttribute('data-artwork-id');
                try {
                    const res = await fetch('/api/like', {
                        method: 'POST',
                        body: JSON.stringify({ artworkId })
                    });
                    const data = await res.json();
                    if (res.ok) {
                        const countEl = btn.querySelector('.likes-count');
                        if (countEl) countEl.textContent = (parseInt(countEl.textContent || '0') + 1).toString();
                        btn.classList.add('liked');
                        btn.classList.add('animating');
                        setTimeout(() => btn.classList.remove('animating'), 400);
                    } else {
                        alert(data.message || "Error al registrar like");
                    }
                } catch (err) {
                    console.error("Error liking:", err);
                }
            });
        });
	});
</script>
