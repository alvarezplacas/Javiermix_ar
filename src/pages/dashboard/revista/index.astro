---
// h:\Javiermix_web_v2\frontend\pages\dashboard\revista\index.astro
import AdminLayout from '@layouts/AdminLayout.astro';
import { getArticles } from '@conexion/directus';

export const prerender = false;

// Verificación de Sesión (SSR)
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
if (!adminToken) {
  return Astro.redirect('/dashboard/login');
}

let articles = [];
try {
  // Primero intentamos con el token (para ver borradores)
  articles = await getArticles(adminToken);
  
  // Si no devuelve nada, intentamos sin token (como el sitio público)
  if (!articles || articles.length === 0) {
    console.log('[Dashboard] No articles with token, retrying public-style...');
    articles = await getArticles();
  }
} catch (e) {
  console.error('[Dashboard] Error fetching articles:', e);
}
---

<AdminLayout title="Gestión de Revista">
  <div class="page-actions">
    <a href="/dashboard/revista/nueva" class="btn-primary">
      <i class="fas fa-plus"></i> NUEVA NOTA
    </a>
  </div>

  <div class="articles-container">
    {articles.length > 0 ? (
      <div class="articles-grid">
        {articles.map((article: any) => (
          <div class="article-card">
            <div class="article-info">
              <span class="article-date">
                {article.created_at ? new Date(article.created_at).toLocaleDateString() : 
                 article.date_created ? new Date(article.date_created).toLocaleDateString() : 'Sin fecha'}
              </span>
              <h3 class="article-title">{article.title || 'Sin título'}</h3>
              <p class="article-excerpt">
                {article.author || (article.user_created ? (article.user_created.first_name || 'Admin') : 'Javier Mix')}
              </p>
            </div>
            <div class="article-actions">
              <a href={`/dashboard/revista/editar/${article.id}`} class="btn-icon" data-tooltip="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <button class="btn-icon btn-delete" data-id={article.id} data-tooltip="Eliminar">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <i class="fas fa-newspaper"></i>
        <p>No hay artículos publicados aún.</p>
        <a href="/dashboard/revista/nueva" class="link-action">Crear mi primer artículo</a>
      </div>
    )}
  </div>
</AdminLayout>

<script>
  import { DirectusManager } from '@conexion/directus';
  const DIRECTUS_URL = DirectusManager.getBaseUrl();

  document.addEventListener('astro:page-load', () => {
    // Escuchar clics en botones de borrar
    const deleteButtons = document.querySelectorAll('.btn-delete');
    deleteButtons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (btn as HTMLElement).dataset.id;
        if (!id) return;

        if (confirm('¿Seguro que deseas eliminar esta nota?')) {
          try {
            const token = document.cookie.split('; ').find(row => row.startsWith('jhm_admin_token='))?.split('=')[1];
            // Llamar a la API local que maneja el bypass del token
            const res = await fetch(`/api/revista/delete?id=${id}`);

            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              alert(`Error al eliminar nota: ${data.message || 'Error desconocido'}`);
            }
          } catch (err) {
            console.error(err);
          }
        }
      });
    });

    // Logging de navegación para diagnóstico
    const editLinks = document.querySelectorAll('a[href*="/revista/editar/"]');
    editLinks.forEach(link => {
       link.addEventListener('click', (e) => {
           console.log(`[Dashboard] Navegando a edición: ${link.getAttribute('href')}`);
       });
    });
  });
</script>

<style>
  .page-actions {
    margin-bottom: 3rem;
    display: flex;
    justify-content: flex-end;
  }

  .btn-primary {
    background: var(--c-accent);
    color: #000;
    text-decoration: none;
    padding: 1rem 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    transition: transform 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .article-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--c-border);
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.3s;
  }

  .article-card:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .article-date {
    font-size: 0.65rem;
    color: var(--c-accent);
    letter-spacing: 1px;
    display: block;
    margin-bottom: 0.5rem;
  }

  .article-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--c-text);
  }

  .article-excerpt {
    margin: 0.3rem 0 0;
    font-size: 0.75rem;
    color: var(--c-muted);
  }

  .article-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-icon {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--c-muted);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .btn-icon:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }

  .btn-delete:hover {
    border-color: #ef4444;
    color: #ef4444;
  }

  .empty-state {
    text-align: center;
    padding: 8rem 0;
    border: 1px dashed var(--c-border);
    color: var(--c-muted);
  }

  .empty-state i {
    font-size: 3rem;
    margin-bottom: 2rem;
    opacity: 0.3;
  }

  .link-action {
    color: var(--c-accent);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 1rem;
    display: block;
  }
</style>
