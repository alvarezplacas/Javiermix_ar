---
// h:\Javiermix_web_v2\frontend\pages\dashboard\login.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Acceso Administrativo | Javier Mix">
  <main class="login-container">
    <div class="login-card">
      <div class="brand-header">
        <span class="brand-name">JAVIER MIX</span>
        <span class="brand-subtitle">FINE ART • BÓVEDA</span>
      </div>
      
      <h1 class="login-title">LOGIN</h1>
      
      <form id="login-form" class="login-form">
        <div class="input-group">
          <label for="email">USUARIO</label>
          <input type="email" id="email" name="email" placeholder="email@ejemplo.com" required />
        </div>
        
        <div class="input-group">
          <label for="password">CONTRASEÑA</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required />
        </div>
        
        <button type="submit" id="submit-btn" class="submit-btn">
          <span class="btn-text">ACCEDER AL PANEL</span>
          <div class="btn-loader"></div>
        </button>
      </form>
      
      <div id="login-feedback" class="feedback-message"></div>
    </div>
  </main>
</Layout>

<style>
  :root {
    --onyx: #0D0D0D;
    --gold: #C5A059;
    --travertine: #F2EFE9;
    --border-soft: rgba(197, 160, 89, 0.2);
  }

  .login-container {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--onyx);
    font-family: 'Inter', sans-serif;
    padding: 2rem;
  }

  .login-card {
    width: 100%;
    max-width: 450px;
    padding: 4rem 3rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-soft);
    backdrop-filter: blur(10px);
    text-align: center;
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    transition: transform 0.3s ease;
  }

  .brand-header {
    display: flex;
    flex-direction: column;
    margin-bottom: 3rem;
  }

  .brand-name {
    font-size: 1.8rem;
    letter-spacing: 0.5rem;
    font-weight: 200;
    color: var(--gold);
  }

  .brand-subtitle {
    font-size: 0.65rem;
    letter-spacing: 0.3rem;
    color: rgba(242, 239, 233, 0.5);
    margin-top: 0.5rem;
  }

  .login-title {
    font-size: 0.9rem;
    letter-spacing: 0.4rem;
    color: var(--travertine);
    margin-bottom: 2.5rem;
    font-weight: 400;
    opacity: 0.8;
  }

  .login-form {
    text-align: left;
  }

  .input-group {
    margin-bottom: 2rem;
  }

  .input-group label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15rem;
    color: var(--gold);
    margin-bottom: 0.8rem;
    font-weight: 600;
  }

  .input-group input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(242, 239, 233, 0.1);
    padding: 0.8rem 0;
    color: var(--travertine);
    font-size: 1rem;
    transition: border-color 0.3s ease;
    outline: none;
    font-family: 'Inter', sans-serif;
  }

  .input-group input:focus {
    border-color: var(--gold);
  }

  .submit-btn {
    width: 100%;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 1.2rem;
    margin-top: 1rem;
    cursor: pointer;
    font-weight: 600;
    letter-spacing: 0.2rem;
    font-size: 0.8rem;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    position: relative;
    overflow: hidden;
  }

  .submit-btn:hover {
    background: var(--gold);
    color: var(--onyx);
  }

  .feedback-message {
    margin-top: 2rem;
    font-size: 0.75rem;
    letter-spacing: 0.05rem;
    height: 1.2rem;
    color: #ef4444; /* Rojo para error */
  }

  .loading .btn-text { opacity: 0; }
  .loading .btn-loader {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 20px; height: 20px;
    border: 2px solid var(--gold);
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }
</style>

<script>
  import { loginAdmin } from '../../conexion/directus';

  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('login-form') as HTMLFormElement;
    const feedback = document.getElementById('login-feedback');
    const submitBtn = document.getElementById('submit-btn');
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const passInput = document.getElementById('password') as HTMLInputElement;

    // 🚀 [AUTO-LOGIN] Soporte para entrar vía URL (Facilidad para Javier)
    const urlParams = new URLSearchParams(window.location.search);
    const urlEmail = urlParams.get('email');
    const urlPass = urlParams.get('password');

    if (urlEmail && urlPass) {
        if (emailInput) emailInput.value = urlEmail;
        if (passInput) passInput.value = urlPass;
        
        // Limpiar URL por privacidad (quitar el PIN de la vista)
        const cleanUrl = window.location.pathname;
        window.history.replaceState({}, document.title, cleanUrl);

        // Si es el PIN maestro, entramos de inmediato
        if (urlPass === '2025' || urlPass === '2026') {
             triggerLogin();
        }
    }

    async function triggerLogin() {
      if (submitBtn?.classList.contains('loading')) return;

      submitBtn?.classList.add('loading');
      if (feedback) {
          feedback.style.color = '#C5A059';
          feedback.innerText = 'AUTENTICANDO...';
      }

      const email = emailInput?.value || '';
      const password = passInput?.value || '';

      try {
        // Bypass temporal para el usuario administrador (vía PIN)
        if (password === '2025' || password === '2026') {
           const expires = new Date();
           expires.setTime(expires.getTime() + (7 * 24 * 60 * 60 * 1000));
           document.cookie = `jhm_admin_token=LEGACY_BYPASS; path=/; expires=${expires.toUTCString()}; SameSite=Strict;`;
           
           if (feedback) {
             feedback.style.color = '#10b981';
             feedback.innerText = 'ACCESO CONCEDIDO. REDIRIGIENDO...';
           }
           setTimeout(() => window.location.href = '/dashboard', 600);
           return;
        }

        const result = await loginAdmin(email, password);
        if (result.success) {
          const expires = new Date();
          expires.setTime(expires.getTime() + (7 * 24 * 60 * 60 * 1000));
          document.cookie = `jhm_admin_token=${result.accessToken}; path=/; expires=${expires.toUTCString()}; SameSite=Strict;`;
          
          if (feedback) {
            feedback.style.color = '#10b981';
            feedback.innerText = 'ACCESO CONCEDIDO. REDIRIGIENDO...';
          }
          
          setTimeout(() => window.location.href = '/dashboard', 800);
        } else {
          if (feedback) {
              feedback.style.color = '#ef4444';
              feedback.innerText = result.message?.toUpperCase() || 'ACCESO DENEGADO';
          }
          submitBtn?.classList.remove('loading');
        }
      } catch (error) {
        if (feedback) feedback.innerText = 'ERROR DE CONEXIÓN';
        submitBtn?.classList.remove('loading');
      }
    }

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      triggerLogin();
    });
  });
</script>
