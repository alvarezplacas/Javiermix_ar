---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Laboratorio de Diseño 2026 | JavierMix">
  <main class="lab-portal">
    <header class="lab-header">
      <div class="badge">ESTÁNDAR 2026</div>
      <h1>Gabinete de Experimentación</h1>
      <p class="description">
        Un espacio dedicado a <span>redefinir</span> la forma en que el coleccionista interactúa con el arte fino. 
        Aquí exploramos interfaces inmersivas y tecnologías de vanguardia.
      </p>

      <div class="experiment-list">
        <!-- Experimento 01: Infinity Gallery -->
        <div class="experiment-card">
            <span class="exp-number">01</span>
            <div class="exp-content">
                <h2>Infinity Gallery 3D</h2>
                <p>Navegación inmersiva en profundidad con motor de atmósfera y escape lateral.</p>
                <a href="/laboratorio/profundidad" class="btn-lab-new">
                    <span class="pulse"></span>
                    INICIAR EXPERIENCIA
                </a>
            </div>
        </div>

        <!-- Experimento 02: Gabinete de Contexto -->
        <div class="experiment-card">
            <span class="exp-number">02</span>
            <div class="exp-content">
                <h2>Sincronía de Espacios</h2>
                <p>Exploración de la obra situada en ambientes reales. Interacción de hover comparativo.</p>
                <a href="/laboratorio/contexto" class="btn-lab-new">
                    <span class="pulse"></span>
                    VER CONTEXTOS
                </a>
            </div>
        </div>

        <!-- Experimento 03: Royal Gallery -->
        <div class="experiment-card">
            <span class="exp-number">03</span>
            <div class="exp-content">
                <h2>Royal Gallery: Pared Infinita</h2>
                <p>Inmersión en galería clásica con iluminación focalizada y desplazamiento lateral cinematográfico.</p>
                <a href="/laboratorio/galeria-real" class="btn-lab-new">
                    <span class="pulse"></span>
                    ENTRAR A LA GALERÍA
                </a>
            </div>
        </div>

        <!-- Futuros experimentos se añadirán aquí -->
      </div>
    </header>
  </main>
</Layout>

<style>
  :root {
    --lab-gold: #dcb14a;
    --transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lab-portal {
    min-height: 100vh;
    background: #030303;
    padding: 8rem 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .lab-header {
    max-width: 900px;
    width: 100%;
    text-align: center;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--lab-gold);
    color: black;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 3px;
    margin-bottom: 2rem;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    color: #fff;
    line-height: 1;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .description {
    color: rgba(255,255,255,0.4);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 5rem;
    line-height: 1.6;
  }

  .description span { color: var(--lab-gold); font-weight: 600; }

  /* 🧪 Experiment List */
  .experiment-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      align-items: center;
  }

  .experiment-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.05);
      padding: 3rem;
      width: 100%;
      max-width: 700px;
      display: flex;
      gap: 3rem;
      text-align: left;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
  }

  .experiment-card:hover {
      border-color: var(--lab-gold);
      background: rgba(220, 177, 74, 0.05);
      transform: translateY(-10px);
  }

  .exp-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 4rem;
      color: rgba(220, 177, 74, 0.2);
      line-height: 1;
  }

  .exp-content h2 {
      color: #fff;
      font-size: 1.8rem;
      margin-bottom: 1rem;
      letter-spacing: 2px;
  }

  .exp-content p {
      color: rgba(255,255,255,0.5);
      font-size: 0.9rem;
      margin-bottom: 2rem;
      line-height: 1.6;
  }

  .btn-lab-new {
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1rem 2rem;
      border: 1px solid var(--lab-gold);
      color: var(--lab-gold);
      text-decoration: none;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 3px;
      position: relative;
      transition: var(--transition);
  }

  .btn-lab-new:hover {
      background: var(--lab-gold);
      color: black;
  }

  .pulse {
      width: 8px;
      height: 8px;
      background: var(--lab-gold);
      border-radius: 50%;
      position: relative;
  }

  .pulse::after {
      content: '';
      position: absolute;
      inset: -4px;
      border: 1px solid var(--lab-gold);
      border-radius: 50%;
      animation: pulseAnim 2s infinite;
  }

  @keyframes pulseAnim {
      0% { transform: scale(1); opacity: 1; }
      100% { transform: scale(3); opacity: 0; }
  }

  @media (max-width: 768px) {
      .experiment-card { flex-direction: column; gap: 1rem; padding: 2rem; }
      .exp-number { font-size: 2.5rem; }
  }
</style>
