---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Laboratorio de Diseño 2026 | JavierMix">
  <main class="lab-portal">
    <!-- Navegación de Seguridad -->
    <nav class="lab-nav">
        <a href="/" class="back-link">
            <span class="nav-icon">←</span>
            VOLVER A LA CENTRAL
        </a>
        <div class="system-status">
            <span class="status-dot"></span>
            SYSTEM ONLINE: v.4.0.2
        </div>
    </nav>

    <div class="grid-overlay"></div>

    <header class="lab-header">
      <div class="badge">ESTÁNDAR JMX 2026</div>
      <h1>Gabinete de Experimentación</h1>
      <p class="description">
        Protocolos avanzados de visualización y curaduría digital. 
        Este espacio opera bajo el <span>Estándar de Oro</span> de JavierMix para la interacción humano-arte.
      </p>

      <div class="experiment-list">
        <!-- Experimento 01: Infinity Gallery -->
        <div class="experiment-card">
            <div class="card-header">
                <span class="exp-number">01</span>
                <div class="meta-tags">
                    <span class="tag">WebGL</span>
                    <span class="tag">3D Engine</span>
                </div>
            </div>
            <div class="exp-content">
                <h2>Infinity Gallery 3D</h2>
                <p>Navegación inmersiva en profundidad con motor de atmósfera y escape lateral. Optimizado para pantallas de alta fidelidad.</p>
                <div class="tech-specs">
                    <div class="spec"><span>LATENCIA:</span> 12ms</div>
                    <div class="spec"><span>ESTADO:</span> ESTABLE</div>
                </div>
                <a href="/laboratorio/profundidad" class="btn-lab-new">
                    <span class="pulse"></span>
                    INICIAR SECUENCIA
                </a>
            </div>
        </div>

        <!-- Experimento 02: Royal Gallery -->
        <div class="experiment-card featured">
            <div class="card-header">
                <span class="exp-number">02</span>
                <div class="meta-tags">
                    <span class="tag">Golden Master</span>
                    <span class="tag">OKLCH</span>
                </div>
            </div>
            <div class="exp-content">
                <h2>Royal Museum: Infinite Wall</h2>
                <p>Nuestra implementación más sofisticada. Iluminación focalizada, gestión de ambientes dinámica y motor de audio Directus.</p>
                <div class="tech-specs">
                    <div class="spec"><span>ILUMINACIÓN:</span> RAYTRACING CSS</div>
                    <div class="spec"><span>ESTADO:</span> PRODUCCIÓN</div>
                </div>
                <a href="/laboratorio/galeria-real" class="btn-lab-new gold">
                    <span class="pulse"></span>
                    ACCESO PRIORITARIO
                </a>
            </div>
        </div>

        <!-- Experimento 03: Gabinete de Contexto -->
        <div class="experiment-card">
            <div class="card-header">
                <span class="exp-number">03</span>
                <div class="meta-tags">
                    <span class="tag">Mockups</span>
                    <span class="tag">Responsive</span>
                </div>
            </div>
            <div class="exp-content">
                <h2>Sincronía de Espacios</h2>
                <p>Exploración de la obra situada en ambientes reales. Interacción de hover comparativo para visualización en sitio.</p>
                <div class="tech-specs">
                    <div class="spec"><span>RATIO:</span> 1:1 REAL</div>
                    <div class="spec"><span>ESTADO:</span> ALPHA</div>
                </div>
                <a href="/laboratorio/contexto" class="btn-lab-new">
                    <span class="pulse"></span>
                    VER CONTEXTOS
                </a>
            </div>
        </div>

        <!-- Experimento 04: AI Authentication (Placeholder) -->
        <div class="experiment-card locked">
            <div class="card-header">
                <span class="exp-number">04</span>
                <div class="meta-tags">
                    <span class="tag">IA</span>
                    <span class="tag">Crypto</span>
                </div>
            </div>
            <div class="exp-content">
                <h2>Autenticación Criptográfica</h2>
                <p>Verificación de procedencia mediante IA y protocolos de seguridad de grado militar. Próximamente.</p>
                <div class="tech-specs">
                    <div class="spec"><span>SEGURIDAD:</span> AES-256</div>
                    <div class="spec"><span>ESTADO:</span> ENCRIPTADO</div>
                </div>
                <button class="btn-lab-new disabled" disabled>
                    ACCESO RESTRINGIDO
                </button>
            </div>
        </div>
      </div>
    </header>
  </main>
</Layout>

<style>
  :root {
    --lab-gold: #dcb14a;
    --lab-bg: #030303;
    --transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lab-portal {
    min-height: 100vh;
    background: var(--lab-bg);
    padding: 10rem 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  .grid-overlay {
    position: fixed;
    inset: 0;
    background-image: linear-gradient(rgba(220, 177, 74, 0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(220, 177, 74, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    pointer-events: none;
    z-index: 1;
  }

  /* 🧭 Navegación */
  .lab-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 2rem 4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 100;
      background: linear-gradient(to bottom, var(--lab-bg) 0%, transparent 100%);
  }

  .back-link {
      color: #fff;
      text-decoration: none;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 3px;
      display: flex;
      align-items: center;
      gap: 1rem;
      opacity: 0.6;
      transition: var(--transition);
  }

  .back-link:hover { opacity: 1; color: var(--lab-gold); }

  .system-status {
      font-family: monospace;
      font-size: 0.6rem;
      color: rgba(255,255,255,0.4);
      display: flex;
      align-items: center;
      gap: 0.8rem;
      letter-spacing: 1px;
  }

  .status-dot {
      width: 6px;
      height: 6px;
      background: #00ff88;
      border-radius: 50%;
      box-shadow: 0 0 10px #00ff88;
  }

  .lab-header {
    max-width: 1000px;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--lab-gold);
    color: var(--lab-gold);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 3px;
    margin-bottom: 2rem;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .description {
    color: rgba(255,255,255,0.4);
    font-size: 1.1rem;
    max-width: 650px;
    margin: 0 auto 6rem;
    line-height: 1.6;
  }

  .description span { color: var(--lab-gold); font-weight: 600; font-style: italic; }

  /* 🧪 Experiment List */
  .experiment-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      width: 100%;
  }

  .experiment-card {
      background: rgba(255,255,255,0.01);
      border: 1px solid rgba(255,255,255,0.05);
      padding: 3rem;
      text-align: left;
      transition: var(--transition);
      position: relative;
      backdrop-filter: blur(10px);
  }

  .experiment-card.featured {
      background: rgba(220, 177, 74, 0.02);
      border-color: rgba(220, 177, 74, 0.15);
  }

  .experiment-card.locked { opacity: 0.4; pointer-events: none; filter: grayscale(1); }

  .experiment-card:hover {
      border-color: var(--lab-gold);
      background: rgba(220, 177, 74, 0.05);
      transform: translateY(-10px) scale(1.02);
  }

  .card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 2rem;
  }

  .exp-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem;
      color: rgba(220, 177, 74, 0.3);
      line-height: 1;
  }

  .meta-tags { display: flex; gap: 0.5rem; }
  .tag {
      font-size: 0.5rem;
      font-weight: 800;
      padding: 0.3rem 0.6rem;
      background: rgba(255,255,255,0.05);
      color: rgba(255,255,255,0.5);
      border-radius: 2px;
      letter-spacing: 1px;
  }

  .exp-content h2 {
      color: #fff;
      font-size: 1.6rem;
      margin-bottom: 1rem;
      letter-spacing: 1px;
      font-family: 'Cormorant Garamond', serif;
  }

  .exp-content p {
      color: rgba(255,255,255,0.5);
      font-size: 0.85rem;
      margin-bottom: 2rem;
      line-height: 1.6;
      min-height: 3.2rem;
  }

  .tech-specs {
      display: flex;
      gap: 2rem;
      margin-bottom: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.05);
  }

  .spec {
      font-family: monospace;
      font-size: 0.6rem;
      color: rgba(255,255,255,0.3);
  }

  .spec span { color: var(--lab-gold); margin-right: 5px; }

  .btn-lab-new {
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      padding: 1.2rem 2rem;
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      text-decoration: none;
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 3px;
      position: relative;
      transition: var(--transition);
      width: 100%;
      justify-content: center;
  }

  .btn-lab-new.gold {
      border-color: var(--lab-gold);
      color: var(--lab-gold);
  }

  .btn-lab-new:hover:not(.disabled) {
      background: #fff;
      color: #000;
      border-color: #fff;
  }

  .btn-lab-new.gold:hover {
      background: var(--lab-gold);
      color: black;
  }

  .btn-lab-new.disabled {
      border-color: rgba(255,255,255,0.05);
      color: rgba(255,255,255,0.2);
  }

  .pulse {
      width: 6px;
      height: 6px;
      background: var(--lab-gold);
      border-radius: 50%;
      position: relative;
  }

  .pulse::after {
      content: '';
      position: absolute;
      inset: -3px;
      border: 1px solid var(--lab-gold);
      border-radius: 50%;
      animation: pulseAnim 2s infinite;
  }

  @keyframes pulseAnim {
      0% { transform: scale(1); opacity: 1; }
      100% { transform: scale(3); opacity: 0; }
  }

  @media (max-width: 900px) {
      .experiment-list { grid-template-columns: 1fr; }
      .lab-nav { padding: 2rem; }
  }
</style>
</style>
