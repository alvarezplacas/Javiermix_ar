---
// src/pages/checkout.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Checkout | Secure Booking">
  <Header currentPath="" />

  <main class="checkout-main">
    <div class="checkout-grid">
      
      <!-- Columna Izquierda: Formulario -->
      <section class="checkout-form-section">
        <h1 class="checkout-title">Datos de Adquisición</h1>
        <p class="checkout-subtitle">Por favor complete sus datos para procesar la orden y coordinar el envío seguro (Fine Art Logistics).</p>
        
        <form id="checkout-form" class="checkout-form">
          <div class="form-group row">
            <input type="text" name="firstName" placeholder="NOMBRE" required />
            <input type="text" name="lastName" placeholder="APELLIDOS" required />
          </div>
          
          <div class="form-group row">
            <input type="email" name="email" placeholder="CORREO ELECTRÓNICO (Para recibos virtuales)" required />
            <input type="tel" name="phone" placeholder="TELÉFONO DE CONTACTO" required />
          </div>
          
          <div class="form-group">
            <input type="text" name="address" placeholder="DIRECCIÓN DE ENTREGA" required />
          </div>
          
          <div class="form-group row">
            <input type="text" name="city" placeholder="CIUDAD" required />
            <input type="text" name="country" placeholder="PAÍS" required />
          </div>
          
          <div class="form-group">
            <textarea name="notes" placeholder="INSTRUCCIONES ESPECIALES O NOTAS (EJ. 'Es un regalo para...')"></textarea>
          </div>

          <div id="checkout-feedback" class="feedback-msg"></div>
          
          <button type="submit" id="btn-submit-order" class="btn-submit">CONFIRMAR COMPRA <i class="fas fa-arrow-right"></i></button>
        </form>

        <!-- Bloque Oculto que se revela al confirmar la orden -->
        <div id="transfer-instructions" class="transfer-instructions" style="display: none;">
            <div class="success-icon"><i class="fas fa-check-circle"></i></div>
            <h2 class="checkout-title" style="font-size: 1.8rem;">Orden Recibida</h2>
            <p class="order-number">NÚMERO DE ORDEN: <strong id="dynamic-order-code">#XXX-XXXX</strong></p>
            
            <div class="bank-box">
                <h3>INSTRUCCIONES DE PAGO POR TRANSFERENCIA</h3>
                <p>Para asegurar su pieza de colección Fine Art, por favor realice una transferencia por el valor de <strong id="dynamic-total-price">U$D 0</strong> a la siguiente cuenta y **utilice el número de orden en el motivo/referencia**:</p>
                <div class="bank-details">
                    <div class="bd-row"><span>Billetera / Banco:</span> <strong>Mercado Pago</strong></div>
                    <div class="bd-row"><span>Titular:</span> <strong>Javier Hernan Alvarez</strong></div>
                    <div class="bd-row alias-row"><span>Alias:</span> <strong class="alias-code">cobromix</strong></div>
                </div>
                <p class="post-transfer-note">Una vez realizado el giro, el sistema lo verificará automáticamente o nos contactaremos directamente con usted para validar el envío y la emisión de su Certificado de Autenticidad A4. Mantenemos el inventario reservado temporalmente para usted.</p>
            </div>
            
            <a href="/" class="btn-submit" style="margin-top:2rem; width: max-content;">Volver a la Galería</a>
        </div>
      </section>

      <!-- Columna Derecha: Resumen -->
      <section class="checkout-summary-section">
        <div class="summary-box">
          <h2 class="summary-title">Resumen de Colección</h2>
          
          <div id="checkout-items" class="checkout-items">
            <!-- Rendered by JS -->
          </div>
          
          <hr class="summary-divider"/>
          
          <div class="summary-row">
            <span>SUBTOTAL</span>
            <span id="checkout-subtotal">U$D 0</span>
          </div>
          <div class="summary-row shipping-row">
            <span>ENVÍO</span>
            <span>A CONVENIR</span>
          </div>
          
          <hr class="summary-divider"/>
          
          <div class="summary-row total-row">
            <span>TOTAL</span>
            <span id="checkout-total">U$D 0</span>
          </div>

          <div class="security-badges">
            <i class="fas fa-lock"></i> Compra Segura Encriptada
            <br/><i class="fas fa-certificate"></i> Incluye Certificado A4 de Autenticidad
          </div>
        </div>
      </section>
      
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .checkout-main {
    min-height: 80vh;
    padding: 6rem 5% 8rem;
    max-width: 1400px;
    margin: 0 auto;
    font-family: var(--font-secondary);
  }

  .checkout-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
  }

  .checkout-title {
    font-family: var(--font-primary);
    font-size: 2.5rem;
    color: var(--color-white);
    margin: 0 0 0.5rem 0;
    font-weight: 300;
  }

  .checkout-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .checkout-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group.row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .checkout-form input, .checkout-form textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: var(--color-white);
    font-family: var(--font-secondary);
    font-size: 0.8rem;
    padding: 1rem 0;
    outline: none;
    transition: border-color 0.3s;
    letter-spacing: 1px;
  }

  .checkout-form textarea {
    resize: vertical;
    min-height: 80px;
  }

  .checkout-form input:focus, .checkout-form textarea:focus {
    border-color: var(--color-accent);
  }

  .btn-submit {
    margin-top: 2rem;
    background: var(--color-accent);
    color: var(--color-onyx-deep);
    border: none;
    padding: 1.2rem;
    font-family: var(--font-secondary);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn-submit:hover {
    background: var(--color-white);
    transform: translateY(-2px);
  }

  .btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Summary Box */
  .summary-box {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 3rem;
    border-radius: 4px;
    position: sticky;
    top: 100px;
  }

  .summary-title {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    color: var(--color-white);
    margin: 0 0 2rem 0;
    font-weight: 300;
    letter-spacing: 1px;
  }

  .summary-divider {
    border-color: rgba(255,255,255,0.05);
    margin: 1.5rem 0;
  }

  .checkout-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-height: 300px;
    overflow-y: auto;
  }

  :global(.chk-item) {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  :global(.chk-img) {
    width: 60px;
    height: 80px;
    object-fit: cover;
  }

  :global(.chk-info) {
    flex: 1;
  }

  :global(.chk-info h4) {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-white);
  }

  :global(.chk-info p) {
    margin: 0.2rem 0 0;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  :global(.chk-price) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-white);
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 1px;
    margin-bottom: 0.8rem;
  }

  .total-row {
    font-size: 1.2rem;
    color: var(--color-white);
    font-weight: 700;
  }

  .security-badges {
    margin-top: 3rem;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.8;
    text-align: center;
  }

  /* Transfer Success Section */
  .transfer-instructions {
      animation: fadeIn 0.8s ease-out forwards;
  }

  .success-icon {
      font-size: 3rem;
      color: #4a9e6a;
      margin-bottom: 1rem;
  }

  .order-number {
      font-family: var(--font-secondary);
      font-size: 0.8rem;
      color: var(--color-accent);
      letter-spacing: 2px;
  }

  .bank-box {
      margin-top: 2rem;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(189, 155, 83, 0.2);
      padding: 2.5rem;
      border-radius: 4px;
  }

  .bank-box h3 {
      font-family: var(--font-primary);
      color: var(--color-accent);
      margin: 0 0 1rem 0;
      font-size: 1.2rem;
  }

  .bank-box p {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      line-height: 1.6;
      margin-bottom: 2rem;
  }

  .bank-details {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background: rgba(0,0,0,0.3);
      padding: 1.5rem;
      border-radius: 4px;
  }

  .bd-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.9rem;
      color: var(--color-text-muted);
      border-bottom: 1px dashed rgba(255,255,255,0.1);
      padding-bottom: 0.5rem;
  }
  .bd-row strong { color: white; }

  .alias-row { border: none; padding-bottom: 0; align-items: center;}
  .alias-code {
      font-family: monospace;
      background: var(--color-accent);
      color: var(--color-onyx-deep);
      padding: 0.4rem 1rem;
      border-radius: 4px;
      font-size: 1rem;
  }

  .post-transfer-note {
      margin-top: 2rem !important;
      font-size: 0.75rem !important;
      opacity: 0.7;
      margin-bottom: 0 !important;
  }

  .feedback-msg {
    font-size: 0.8rem;
    text-align: center;
    min-height: 1.2rem;
    margin-top: 1rem;
    font-weight: 600;
  }

  @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .checkout-grid {
      grid-template-columns: 1fr;
    }
    .form-group.row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { cartStore, clearCart } from '../store/cartStore';

  document.addEventListener('astro:page-load', () => {
    const listWrapper = document.getElementById('checkout-items');
    const subtotalEl = document.getElementById('checkout-subtotal');
    const totalEl = document.getElementById('checkout-total');
    const form = document.getElementById('checkout-form');
    const btn = document.getElementById('btn-submit-order') as HTMLButtonElement | null;
    const feedback = document.getElementById('checkout-feedback');

    if (!listWrapper || typeof cartStore === 'undefined') return;

    // Load Cart Data
    cartStore.subscribe(cart => {
      const items = Object.values(cart);
      if (items.length === 0) {
        listWrapper.innerHTML = '<p style="font-size: 0.8rem; color: #888;">El carrito está vacío.</p>';
        if (btn) btn.disabled = true;
        if (subtotalEl) subtotalEl.innerText = `U$D 0`;
        if (totalEl) totalEl.innerText = `U$D 0`;
        return;
      }

      listWrapper.innerHTML = items.map(i => `
        <div class="chk-item">
          <img src="${i.image}" class="chk-img" />
          <div class="chk-info">
            <h4>${i.title}</h4>
            <p>${i.size} - Qty: ${i.quantity}</p>
          </div>
          <div class="chk-price">U$D ${i.price * i.quantity}</div>
        </div>
      `).join('');

      const total = items.reduce((sum, i) => sum + (i.price * i.quantity), 0);
      if (subtotalEl) subtotalEl.innerText = `U$D ${total}`;
      if (totalEl) totalEl.innerText = `U$D ${total}`;
    });

    // Form submission
    if (form && btn && feedback) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        btn.disabled = true;
        btn.innerHTML = 'PROCESANDO ORDEN SEGURO...';
        
        const fd = new FormData(form as HTMLFormElement);
        const cartValues = Object.values(cartStore.get());
        const totalAmount = cartValues.reduce((sum, i) => sum + (i.price * i.quantity), 0);

        const payload = {
            firstName: fd.get('firstName'),
            lastName: fd.get('lastName'),
            email: fd.get('email'),
            phone: fd.get('phone'),
            address: fd.get('address'),
            city: fd.get('city'),
            country: fd.get('country'),
            notes: fd.get('notes'),
            cartItems: cartValues,
            total: totalAmount
        };

        try {
            const res = await fetch('/api/public/submit-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const result = await res.json();

            if (res.ok && result.success) {
                clearCart();
                
                // Ocultar formulario y headers de instruccion
                form.style.display = 'none';
                (document.querySelector('.checkout-title') as HTMLElement).style.display = 'none';
                (document.querySelector('.checkout-subtitle') as HTMLElement).style.display = 'none';
                
                // Rellenar tickt y mostrar
                const ticketBlock = document.getElementById('transfer-instructions');
                const dynCode = document.getElementById('dynamic-order-code');
                const dynTotal = document.getElementById('dynamic-total-price');

                if (dynCode) dynCode.innerText = result.order_number;
                if (dynTotal) dynTotal.innerText = `U$D ${totalAmount}`;
                
                if (ticketBlock) ticketBlock.style.display = 'block';

            } else {
                feedback.innerText = result.error || 'Hubo un error al procesar. Por favor reintente.';
                btn.disabled = false;
                btn.innerHTML = `CONFIRMAR COMPRA <i class="fas fa-arrow-right"></i>`;
            }
        } catch (err) {
            feedback.innerText = 'Error de red. Verifique su conexión.';
            btn.disabled = false;
            btn.innerHTML = `CONFIRMAR COMPRA <i class="fas fa-arrow-right"></i>`;
        }
      });
    }
  });
</script>
