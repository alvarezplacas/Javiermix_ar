---
// h:\Javiermix_web_v2\frontend\pages\dashboard\certificados\index.astro
import AdminLayout from '@layouts/AdminLayout.astro';
import { getCertificates } from '@conexion/directus';

export const prerender = false;

// Verificación de Sesión (SSR)
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
if (!adminToken) {
  return Astro.redirect('/dashboard/login');
}

// 1. Obtener lista de certificados desde Directus (con relaciones)
const rawCerts = await getCertificates(adminToken);

const certs = rawCerts.map((c: any) => ({
    id: c.id,
    uuid: c.uuid,
    date: c.sale_date,
    edition: c.edition_number,
    obraTitle: c.artwork_id?.title || 'Obra no encontrada',
    collectorName: c.collector_id?.name || 'Anonimo'
}));
---

<AdminLayout title="Certificados de Autenticidad">
    <div class="certs-header">
        <p class="section-desc">Listado oficial de certificados generados por ventas en la plataforma.</p>
    </div>

    <div class="certs-list-container">
        {certs.length > 0 ? (
            <table class="certs-table">
                <thead>
                    <tr>
                        <th>OBRA</th>
                        <th>COLECCIONISTA</th>
                        <th>FECHA</th>
                        <th>EDICIÓN</th>
                        <th>ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    {certs.map(c => (
                        <tr>
                            <td>
                                <span class="obra-name">{c.obraTitle}</span>
                                <span class="uuid-tag">ID: {c.uuid.substring(0,8)}...</span>
                            </td>
                            <td>{c.collectorName}</td>
                            <td>{new Date(c.date!).toLocaleDateString('es-AR')}</td>
                            <td><span class="edition-badge">{c.edition}</span></td>
                            <td>
                                <div class="action-buttons">
                                    <a href={`/dashboard/certificados/${c.uuid}`} class="btn-icon" data-tooltip="Imprimir A4">
                                        <i class="fas fa-print"></i>
                                    </a>
                                    <a href={`/verificar/${c.uuid}`} target="_blank" class="btn-icon" data-tooltip="Verificar Online">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        ) : (
            <div class="empty-state">
                <i class="fas fa-certificate"></i>
                <h3>No hay certificados emitidos</h3>
                <p>Cuando se procese una venta, aparecerá aquí automáticamente.</p>
            </div>
        )}
    </div>
</AdminLayout>

<style>
    .certs-header { margin-bottom: 3rem; }
    .section-desc { color: var(--c-muted); font-size: 0.9rem; letter-spacing: 1px; }

    .certs-list-container {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--c-border);
        border-radius: 8px;
        overflow: hidden;
    }

    .certs-table { width: 100%; border-collapse: collapse; text-align: left; }
    .certs-table th { padding: 1.5rem 2rem; background: rgba(255,255,255,0.03); font-size: 0.65rem; letter-spacing: 2px; color: var(--c-accent); text-transform: uppercase; border-bottom: 1px solid var(--c-border); }
    .certs-table td { padding: 1.5rem 2rem; border-bottom: 1px solid var(--c-border); font-size: 0.85rem; color: var(--c-text); vertical-align: middle; }
    .certs-table tr:hover { background: rgba(255,255,255,0.01); }

    .obra-name { display: block; font-weight: 600; margin-bottom: 0.3rem; }
    .uuid-tag { font-size: 0.6rem; color: var(--c-muted); font-family: monospace; }

    .edition-badge { background: rgba(197, 160, 89, 0.1); color: var(--c-accent); padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.7rem; font-weight: 700; }

    .action-buttons { display: flex; gap: 1rem; }
    .btn-icon { color: var(--c-muted); transition: color 0.3s; font-size: 1.1rem; }
    .btn-icon:hover { color: var(--c-accent); }

    .empty-state { padding: 10rem 0; text-align: center; color: var(--c-muted); }
    .empty-state i { font-size: 4rem; opacity: 0.1; margin-bottom: 2rem; display: block; }
    .empty-state h3 { color: var(--c-text); margin-bottom: 0.5rem; letter-spacing: 1px; }
</style>
