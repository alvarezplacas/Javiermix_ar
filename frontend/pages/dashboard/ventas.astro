---
// h:\Javiermix_web_v2\frontend\dashboard\ventas.astro
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db, orders } from '@conexion/db';
import { desc } from 'drizzle-orm';

export const prerender = false;

// Verificación de Sesión (SSR)
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
if (!adminToken) {
  return Astro.redirect('/dashboard/login');
}

let history = [];
try {
    history = await db.select().from(orders).orderBy(desc(orders.created_at));
} catch (e) {
    console.error("Error fetching orders:", e);
}

const formatter = new Intl.DateTimeFormat('es-AR', { dateStyle: 'medium', timeStyle: 'short' });
---

<AdminLayout title="Ventas y Órdenes">
    <div class="header-actions">
        <h2 class="section-title">Control de Transferencias</h2>
    </div>

    <div class="panel">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Nº Orden</th>
                    <th>Cliente</th>
                    <th>Monto</th>
                    <th>Estado Pago</th>
                    <th>Fecha</th>
                </tr>
            </thead>
            <tbody>
                {history.map(order => (
                    <tr>
                        <td><strong class="order-id">{order.order_number}</strong></td>
                        <td>
                            <div class="col-cell">
                                <span class="col-name">{order.collector_name}</span>
                                <span class="col-email">{order.collector_email}</span>
                            </div>
                        </td>
                        <td><span class="price-badge">U$D {order.total_price}</span></td>
                        <td><span class={`status-badge ${order.payment_status}`}>{order.payment_status?.toUpperCase()}</span></td>
                        <td>{order.created_at ? formatter.format(new Date(order.created_at)) : 'N/A'}</td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
</AdminLayout>

<style>
    .header-actions { margin-bottom: 2rem; }
    .section-title { font-size: 1.2rem; color: #fff; font-weight: 400; }
    .panel { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden; }
    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table th, .admin-table td { padding: 1.5rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.02); }
    .admin-table th { font-size: 0.7rem; text-transform: uppercase; color: rgba(255,255,255,0.4); }
    .order-id { font-family: monospace; color: #fff; background: rgba(255,255,255,0.05); padding: 0.3rem 0.6rem; border-radius: 4px; }
    .col-cell { display: flex; flex-direction: column; }
    .col-name { color: #fff; font-weight: 600; }
    .col-email { font-size: 0.75rem; color: #888; }
    .price-badge { font-weight: 700; color: #4a9e6a; }
    .status-badge { font-size: 0.65rem; font-weight: 700; padding: 0.4rem 0.8rem; border-radius: 4px; }
    .status-badge.pending { background: rgba(224, 85, 85, 0.1); color: #e05555; }
    .status-badge.paid { background: rgba(74, 158, 106, 0.1); color: #4a9e6a; }
</style>
