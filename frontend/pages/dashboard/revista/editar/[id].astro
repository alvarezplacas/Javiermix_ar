---
// h:\Javiermix_web_v2\frontend\pages\dashboard\revista\editar\[id].astro
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getArticleDetails } from '../../../../conexion/directus';

export const prerender = false;

const { id } = Astro.params;

// Verificación de Sesión (SSR)
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
if (!adminToken) {
  return Astro.redirect('/dashboard/login');
}

const article = await getArticleDetails(id!, adminToken);

// Asegurar que media_json sea un array si el artículo existe
if (article) {
    if (typeof article.media_json === 'string') {
        try {
            article.media_json = JSON.parse(article.media_json);
        } catch(e) {
            article.media_json = [];
        }
    }
    if (!article.media_json) article.media_json = [];
}
---

<AdminLayout title={`Editar Nota: ${article?.title || 'No Encontrada'}`}>
  <!-- Mammoth.js for Word to HTML conversion -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>

  <div class="editor-header">
    <a href="/dashboard/revista" class="btn-back">
      <i class="fas fa-arrow-left"></i> VOLVER AL LISTADO
    </a>
    <div class="header-actions">
       <label for="word-upload" class="btn-secondary">
         <i class="fas fa-file-word"></i> IMPORTAR WORD (.docx)
       </label>
       <input type="file" id="word-upload" accept=".docx" style="display: none;" />
    </div>
  </div>

  <div class="editor-container">
    <form id="article-form" class="article-form">
      <input type="hidden" name="id" value={id} />
      
      <div class="form-main">
        {article ? (
        <div class="form-group">
          <label for="title">TÍTULO DE LA NOTA</label>
          <input type="text" id="title" name="title" value={article.title} required />
        </div>

        <div class="form-group">
          <label for="slug">SLUG (URL)</label>
          <input type="text" id="slug" name="slug" value={article.slug} required />
        </div>

        <div class="form-group">
          <label>CONTENIDO DEL ARTÍCULO</label>
          <div 
            id="quill-editor" 
            class="quill-wrapper" 
            data-initial-content={article.content_html || ''}
          ></div>
          <input type="hidden" name="content_html" id="content-html-input" />
        </div>

        <div class="form-grid-2">
          <div class="form-group">
            <label for="video_url">VIDEO URL (YOUTUBE/VIMEO)</label>
            <input type="text" id="video_url" name="video_url" value={article.video_url} />
          </div>
          <div class="form-group">
            <label for="tags">ETIQUETAS (SEPARADAS POR COMA)</label>
            <input type="text" id="tags" name="tags" value={article.tags} />
          </div>
        </div>
      </div>

      <aside class="form-sidebar">
        <div class="sidebar-card">
          <h4>Estado de Publicación</h4>
          <div class="form-group">
            <label for="status">Estado</label>
            <select name="status" id="status">
              <option value="draft" selected={article.status === 'draft'}>Borrador</option>
              <option value="published" selected={article.status === 'published'}>Publicado</option>
              <option value="archive" selected={article.status === 'archive'}>Archivado</option>
            </select>
          </div>
          <div class="form-group checkbox-group">
            <input type="checkbox" name="is_premium" id="is_premium" checked={article.is_premium} />
            <label for="is_premium" class="inline-label">CONTENIDO PREMIUM</label>
          </div>
          <button type="submit" class="btn-primary" id="btn-save">
            <i class="fas fa-save"></i> ACTUALIZAR NOTA
          </button>
        </div>

        <div class="sidebar-card">
          <h4>Configuración SEO</h4>
          <div class="form-group">
            <label for="seo_title">SEO TITLE</label>
            <input type="text" id="seo_title" name="seo_title" value={article.seo_title} />
          </div>
          <div class="form-group">
            <label for="seo_description">SEO DESCRIPTION</label>
            <textarea id="seo_description" name="seo_description" rows="3">{article.seo_description}</textarea>
          </div>
        </div>

        <div class="sidebar-card">
          <h4>Galería Multimedia</h4>
          <div class="media-upload-container">
            <div class="media-grid" id="media-preview-grid">
               {/* Pre-render existing media */}
               {Array.isArray(article.media_json) && article.media_json.map((fid: string) => (
                  <div class="media-item" data-id={fid}>
                    <img src={`/api/assets/${fid}?width=150&height=150&fit=cover`} />
                    <button type="button" class="remove-btn">×</button>
                  </div>
               ))}
            </div>
            <label for="multi-media-upload" class="image-upload-box">
              <i class="fas fa-plus"></i>
              <span>REEMPLAZAR / AÑADIR</span>
            </label>
            <input type="file" id="multi-media-upload" accept="image/*,video/mp4" multiple style="display: none;" />
          </div>
          <input type="hidden" name="media_json" id="media-json-input" value={JSON.stringify(article.media_json || [])} />
        </div>
      </aside>
    </form>
    ) : (
      <div class="error-box">
         <i class="fas fa-exclamation-triangle"></i>
         <p>No se pudo cargar la nota con ID: {id}. Es posible que haya sido eliminada o que no tengas permisos.</p>
         <a href="/dashboard/revista" class="btn-secondary">VOLVER AL LISTADO</a>
      </div>
    )}
    <div id="feedback" class="feedback-msg"></div>
  </div>
</AdminLayout>

<style>
  .error-box { text-align: center; padding: 4rem; background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px; width: 100%; grid-column: 1 / span 2; }
  .error-box i { font-size: 2rem; color: #ef4444; margin-bottom: 1rem; }
  .error-box p { margin-bottom: 2rem; color: var(--c-text); }
</style>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js" is:inline></script>

<script is:inline>
  function initQuillEditor() {
    const container = document.querySelector('#quill-editor');
    if (!container || container.querySelector('.ql-editor')) return;

    if (typeof Quill === 'undefined') {
        console.error("Quill no cargado todavía...");
        return;
    }

    const initialContent = container.getAttribute('data-initial-content') || '';

    window.quillInstance = new Quill('#quill-editor', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['link', 'blockquote', 'code-block'],
          ['clean']
        ]
      }
    });
    
    // Cargar contenido inicial de forma segura
    if (initialContent) {
        window.quillInstance.root.innerHTML = initialContent;
    }
  }

  document.addEventListener('DOMContentLoaded', initQuillEditor);
  document.addEventListener('astro:page-load', initQuillEditor);
</script>

<style is:global>
  .ql-toolbar { background: #1a1a1a !important; border-color: rgba(255,255,255,0.05) !important; border-top-left-radius: 4px; border-top-right-radius: 4px; }
  .ql-container { background: rgba(255,255,255,0.02) !important; border-color: rgba(255,255,255,0.05) !important; color: #fff !important; font-family: 'Inter', sans-serif !important; min-height: 400px; }
  .ql-stroke { stroke: #aaa !important; }
  .ql-fill { fill: #aaa !important; }
  .ql-picker { color: #aaa !important; }
</style>

<style>
  .editor-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
  .btn-secondary { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--c-text); padding: 0.6rem 1.2rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; }
  .btn-back { color: var(--c-muted); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 1px; display: flex; align-items: center; gap: 0.8rem; }
  .article-form { display: grid; grid-template-columns: 1fr 350px; gap: 3rem; }
  .form-group { margin-bottom: 2rem; }
  .form-group label { display: block; font-size: 0.65rem; letter-spacing: 2px; color: var(--c-accent); margin-bottom: 0.8rem; font-weight: 700; }
  input[type="text"], select, textarea { width: 100%; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 1rem; color: var(--c-text); border-radius: 4px; font-size: 0.9rem; font-family: inherit; }
  .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .sidebar-card { background: rgba(255,255,255,0.02); border: 1px solid var(--c-border); padding: 2rem; margin-bottom: 2rem; border-radius: 4px; }
  .sidebar-card h4 { margin: 0 0 1.5rem; font-size: 0.75rem; letter-spacing: 1px; color: var(--c-muted); text-transform: uppercase; }
  .btn-primary { width: 100%; background: var(--c-accent); color: #000; border: none; padding: 1rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 1px; cursor: pointer; border-radius: 4px; transition: all 0.3s; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .media-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; margin-bottom: 1rem; }
  .media-item { position: relative; aspect-ratio: 1; background: #000; border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
  .media-item img { width: 100%; height: 100%; object-fit: cover; }
  .remove-btn { position: absolute; top: 5px; right: 5px; background: rgba(239, 68, 68, 0.8); color: #fff; border: none; width: 22px; height: 22px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 5; }
  .image-upload-box { width: 100%; padding: 2rem; border: 1px dashed rgba(255,255,255,0.1); border-radius: 4px; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--c-muted); transition: all 0.3s; }
  .image-upload-box:hover { border-color: var(--c-accent); color: var(--c-accent); background: rgba(197, 160, 89, 0.05); }
  .feedback-msg { margin-top: 2rem; font-size: 0.8rem; font-weight: 600; text-align: center; }
</style>

<script>
  import { updateArticle, uploadFile } from '../../../../conexion/directus';

  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('article-form') as HTMLFormElement;
    const feedback = document.getElementById('feedback');
    const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
    const mediaGrid = document.getElementById('media-preview-grid');
    const mediaJsonInput = document.getElementById('media-json-input') as HTMLInputElement;
    const multiMediaUpload = document.getElementById('multi-media-upload') as HTMLInputElement;
    const wordUpload = document.getElementById('word-upload') as HTMLInputElement;

    // Generar slug automático
    const titleInput = document.getElementById('title') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;

    titleInput?.addEventListener('input', () => {
      slugInput.value = titleInput.value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9 ]/g, '')
        .replace(/\s+/g, '-');
    });

    let uploadedMedia = [];
    try {
        const rawMedia = mediaJsonInput?.value || '[]';
        uploadedMedia = typeof rawMedia === 'string' ? JSON.parse(rawMedia) : rawMedia;
    } catch(e) {
        uploadedMedia = [];
    }

    // Manejar clics en los botones de "Equis" existentes (borrar)
    mediaGrid?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.classList.contains('remove-btn')) {
            const item = target.closest('.media-item') as HTMLElement;
            const fid = item.dataset.id;
            if (fid) {
                uploadedMedia = uploadedMedia.filter((id: string) => id !== fid);
                mediaJsonInput.value = JSON.stringify(uploadedMedia);
                item.remove();
            }
        }
    });

    // Subida de nuevos archivos
    multiMediaUpload?.addEventListener('change', async (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (!files) return;

      const token = document.cookie.split('; ').find(row => row.startsWith('jhm_admin_token='))?.split('=')[1];

      for (const file of files) {
        // Preview local temporal
        const item = document.createElement('div');
        item.className = 'media-item';
        item.innerHTML = `<div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;font-size:8px;">Subiendo...</div>`;
        mediaGrid?.appendChild(item);

        const result = await uploadFile(file, token);
        if (result.success) {
            uploadedMedia.push(result.id);
            mediaJsonInput.value = JSON.stringify(uploadedMedia);
            
            item.innerHTML = `
                <img src="/api/assets/${result.id}?width=150&height=150&fit=cover" />
                <button type="button" class="remove-btn">×</button>
            `;
            item.dataset.id = result.id;
        } else {
            item.remove();
            alert("Error subiendo archivo");
        }
      }
    });

    // Import Word
    wordUpload?.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = async (event) => {
        const arrayBuffer = event.target?.result as ArrayBuffer;
        // @ts-ignore
        const result = await mammoth.convertToHtml({ arrayBuffer });
        // @ts-ignore
        if (window.quillInstance) window.quillInstance.root.innerHTML = result.value;
      };
      reader.readAsArrayBuffer(file);
    });

    // Enviar Formulario (UPDATE)
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btnSave) return;
      
      btnSave.disabled = true;
      btnSave.innerText = 'ACTUALIZANDO...';

      const formData = new FormData(form);
      const articleId = formData.get('id') as string;
      // @ts-ignore
      const content = window.quillInstance ? window.quillInstance.root.innerHTML : '';

      const updateData = {
        title: formData.get('title'),
        slug: formData.get('slug'),
        content_html: content,
        status: formData.get('status'),
        is_premium: formData.get('is_premium') === 'on',
        video_url: formData.get('video_url'),
        tags: formData.get('tags'),
        seo_title: formData.get('seo_title'),
        seo_description: formData.get('seo_description'),
        media_json: uploadedMedia,
        featured_image: uploadedMedia[0] || null
      };

      try {
        const token = document.cookie.split('; ').find(row => row.startsWith('jhm_admin_token='))?.split('=')[1];
        const result = await updateArticle(articleId, updateData, token);
        
        if (result.success) {
          if (feedback) {
            feedback.style.color = '#10b981';
            feedback.innerText = '¡ARTÍCULO ACTUALIZADO CON ÉXITO!';
          }
          setTimeout(() => window.location.href = '/dashboard/revista', 1500);
        } else {
          throw new Error(result.message);
        }
      } catch (err: any) {
        if (feedback) {
          feedback.style.color = '#ef4444';
          feedback.innerText = `ERROR: ${err.message}`;
        }
        btnSave.disabled = false;
        btnSave.innerText = 'REINTENTAR ACTUALIZACIÓN';
      }
    });
  });
</script>
