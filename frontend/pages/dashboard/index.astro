---
// h:\Javiermix_web_v2\frontend\pages\dashboard\index.astro
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;

// Verificación de Sesión (SSR)
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
if (!adminToken) {
  return Astro.redirect('/dashboard/login');
}
---

<AdminLayout title="Resumen Operativo">
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon"><i class="fas fa-shopping-cart"></i></div>
      <div class="metric-data">
        <span class="metric-label">ÓRDENES PENDIENTES</span>
        <span class="metric-value">0</span>
      </div>
      <div class="metric-chart-mini"></div>
    </div>

    <div class="metric-card">
      <div class="metric-icon"><i class="fas fa-eye"></i></div>
      <div class="metric-data">
        <span class="metric-label">VISITAS (HOY)</span>
        <span class="metric-value">---</span>
      </div>
      <div class="metric-chart-mini"></div>
    </div>

    <div class="metric-card">
      <div class="metric-icon"><i class="fas fa-newspaper"></i></div>
      <div class="metric-data">
        <span class="metric-label">ARTÍCULOS REVISTA</span>
        <span class="metric-value">--</span>
      </div>
      <div class="metric-chart-mini"></div>
    </div>
  </div>

  <div class="activity-section">
    <div class="section-header">
      <h2>ACTIVIDAD RECIENTE</h2>
      <button class="btn-refresh"><i class="fas fa-sync-alt"></i></button>
    </div>
    <div class="activity-list">
      <div class="empty-state">
        <i class="fas fa-satellite-dish"></i>
        <p>No hay actividad registrada en las últimas 24 horas.</p>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .metric-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    position: relative;
    overflow: hidden;
  }

  .metric-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--c-accent);
    opacity: 0.3;
  }

  .metric-icon {
    font-size: 2rem;
    color: var(--c-accent);
    opacity: 0.8;
  }

  .metric-data {
    display: flex;
    flex-direction: column;
  }

  .metric-label {
    font-size: 0.65rem;
    letter-spacing: 2px;
    color: var(--c-muted);
    font-weight: 600;
  }

  .metric-value {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--c-text);
  }

  .activity-section {
    background: rgba(255,255,255,0.01);
    border: 1px solid rgba(255,255,255,0.03);
    padding: 3rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 1rem;
  }

  .section-header h2 {
    font-size: 0.8rem;
    letter-spacing: 3px;
    color: var(--c-accent);
  }

  .btn-refresh {
    background: transparent;
    border: none;
    color: var(--c-muted);
    cursor: pointer;
    transition: color 0.3s;
  }

  .btn-refresh:hover { color: var(--c-accent); }

  .empty-state {
    text-align: center;
    padding: 5rem 0;
    color: var(--c-muted);
  }

  .empty-state i {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    opacity: 0.2;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.1; }
    50% { transform: scale(1.1); opacity: 0.3; }
    100% { transform: scale(1); opacity: 0.1; }
  }
</style>
