---
// h:\Javiermix_web_v2\frontend\pages\dashboard\obras\index.astro
import AdminLayout from '@layouts/AdminLayout.astro';
import { getArtworks, getCatalogoFiles } from '@conexion/directus';

// Verificación de Sesión (SSR)
const adminToken = Astro.cookies.get('jhm_admin_token')?.value;
if (!adminToken) {
  return Astro.redirect('/dashboard/login');
}

export const prerender = false;

// 1. Obtener datos
const dbArtworks = await getArtworks();
const rawFiles = await getCatalogoFiles();

// Filtrar para ignorar archivos técnicos (XMP) y muestras de ambiente (_2)
const catalogoFiles = rawFiles.filter((f: any) => {
    const isMedia = f.type?.startsWith('image/') || f.type?.startsWith('video/');
    const isSample = /_2\.[^.]+$/i.test(f.filename_download || '');
    return isMedia && !isSample;
});

// 2. Mapear obras registradas
const registeredFilesMap = new Map(dbArtworks.map((art: any) => [art.filename, art]));

// 3. Agrupar por Serie
const groupedBySeries: Record<string, any[]> = {};

catalogoFiles.forEach((file: any) => {
    const dbRecord = registeredFilesMap.get(file.id);
    const item = {
        fileId: file.id,
        filename_download: file.filename_download,
        type: file.type,
        serie: file.serie_name,
        dbRecord: dbRecord,
        title: dbRecord ? dbRecord.title : (file.title || file.filename_download),
        status: dbRecord ? dbRecord.status : 'unregistered'
    };
    
    if (!groupedBySeries[item.serie]) {
        groupedBySeries[item.serie] = [];
    }
    groupedBySeries[item.serie].push(item);
});

const seriesNames = Object.keys(groupedBySeries).sort();
---

<AdminLayout title="Catálogo de Obras">
  <div class="page-header">
    <div class="header-info">
      <h1 class="page-title">CATÁLOGO DE OBRAS</h1>
      <p class="page-subtitle">Haz clic en una obra para editar sus precios (30x45, 40x60, 60x90) e historia.</p>
    </div>
  </div>

  <section class="obras-container">
    {seriesNames.map((serieName) => (
      <div class="serie-stack">
        <button class="stack-header" onclick="this.nextElementSibling.classList.toggle('active'); this.querySelector('.chevron').classList.toggle('rotated')">
          <div class="stack-info">
            <span class="serie-label">SERIE</span>
            <span class="serie-title">{serieName}</span>
            <span class="item-count">({groupedBySeries[serieName].length} OBRAS)</span>
          </div>
          <i class="fas fa-chevron-down chevron"></i>
        </button>
        
        <div class="stack-content">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Vista</th>
                <th>Obra / Archivo</th>
                <th>Estado</th>
                <th>Inventario</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {groupedBySeries[serieName].map((item) => (
                <tr class={item.status === 'unregistered' ? 'row-pending' : 'row-registered'} 
                    onclick={item.dbRecord ? `window.location.href='/dashboard/obras/editar/${item.dbRecord.id}'` : `window.location.href='/dashboard/obras/nueva?fileId=${item.fileId}&title=${encodeURIComponent(item.title)}&serie=${encodeURIComponent(item.serie)}'`}
                >
                  <td>
                    <div class="artwork-preview">
                      {item.type.startsWith('image/') ? (
                        <img 
                          src={item.type === 'image/avif' 
                            ? `/api/assets/${item.fileId}` 
                            : `/api/assets/${item.fileId}?width=100&height=100&fit=cover`} 
                          alt={item.title} 
                          loading="lazy"
                        />
                      ) : (
                        <div class="video-placeholder"><i class="fas fa-video"></i></div>
                      )}
                    </div>
                  </td>
                  <td>
                    <div class="artwork-info">
                      <span class="artwork-title">{item.title}</span>
                      <span class="artwork-filename">{item.filename_download}</span>
                    </div>
                  </td>
                  <td>
                    {item.status === 'unregistered' ? (
                      <span class="status-tag pending">PENDIENTE</span>
                    ) : (
                      <span class={`status-tag ${item.status}`}>
                        {item.status.toUpperCase()}
                      </span>
                    )}
                  </td>
                  <td>
                    {item.dbRecord ? (
                        <div class="stock-info">
                            <span class={item.dbRecord.stock > 0 ? 'in-stock' : 'out-of-stock'}>
                                {item.dbRecord.stock > 0 ? `DISPONIBLE (${item.dbRecord.stock})` : 'SIN STOCK'}
                            </span>
                        </div>
                    ) : '-'}
                  </td>
                  <td>
                    <div class="row-actions" onclick="event.stopPropagation()">
                      {item.dbRecord ? (
                        <a href={`/dashboard/obras/editar/${item.dbRecord.id}`} class="btn-action">EDITAR</a>
                      ) : (
                        <a href={`/dashboard/obras/nueva?fileId=${item.fileId}&title=${encodeURIComponent(item.title)}&serie=${encodeURIComponent(item.serie)}`} class="btn-action primary">VINCULAR</a>
                      )}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </section>
</AdminLayout>

<style>
  .page-header { margin-bottom: 3rem; }
  .page-title { font-size: 2.5rem; font-weight: 800; color: var(--c-text); margin: 0; letter-spacing: -1px; }
  .page-subtitle { color: var(--c-muted); font-size: 0.9rem; margin-top: 0.5rem; }

  .serie-stack {
    margin-bottom: 1.5rem;
    border: 1px solid var(--c-border);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.01);
  }

  .stack-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    background: rgba(255,255,255,0.03);
    border: none;
    color: var(--c-text);
    cursor: pointer;
    transition: background 0.3s;
  }

  .stack-header:hover { background: rgba(255,255,255,0.06); }

  .stack-info { display: flex; align-items: center; gap: 1rem; }
  .serie-label { font-size: 0.6rem; font-weight: 900; color: var(--c-accent); background: rgba(197, 160, 89, 0.1); padding: 0.2rem 0.5rem; border-radius: 3px; }
  .serie-title { font-family: var(--f-display); font-size: 1.2rem; font-weight: 700; text-transform: uppercase; }
  .item-count { font-size: 0.8rem; color: var(--c-muted); }

  .chevron { transition: transform 0.3s; font-size: 0.8rem; }
  .chevron.rotated { transform: rotate(180deg); }

  .stack-content { display: none; }
  .stack-content.active { display: block; }

  .admin-table { width: 100%; border-collapse: collapse; }
  .admin-table th { text-align: left; padding: 1rem 2rem; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; color: var(--c-muted); border-bottom: 1px solid var(--c-border); background: rgba(0,0,0,0.2); }
  .admin-table tr { cursor: pointer; transition: all 0.2s; }
  .admin-table tr:hover { background: rgba(255,255,255,0.04) !important; }
  .admin-table td { padding: 1rem 2rem; border-bottom: 1px solid var(--c-border); }

  .row-pending { background: rgba(197, 160, 89, 0.03); }

  .artwork-preview { width: 60px; height: 60px; background: #000; border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
  .artwork-preview img { width: 100%; height: 100%; object-fit: cover; }
  .video-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #111; color: var(--c-muted); }

  .artwork-info { display: flex; flex-direction: column; }
  .artwork-title { font-weight: 700; color: var(--c-text); font-size: 1rem; }
  .artwork-filename { font-size: 0.7rem; color: var(--c-muted); font-family: monospace; }

  .status-tag { font-size: 0.6rem; font-weight: 800; padding: 0.3rem 0.6rem; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1); }
  .status-tag.published { color: #10b981; border-color: #10b98133; }
  .status-tag.pending { color: var(--c-accent); border-color: var(--c-accent); opacity: 0.8; }

  .stock-info { font-size: 0.75rem; font-weight: 700; }
  .in-stock { color: #10b981; }
  .out-of-stock { color: #ef4444; }

  .btn-action {
    text-decoration: none;
    font-size: 0.65rem;
    font-weight: 800;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    color: var(--c-text);
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.2s;
  }
  .btn-action.primary { background: var(--c-accent); color: #000; border: none; }
  .btn-action:hover { transform: scale(1.05); }
</style>
